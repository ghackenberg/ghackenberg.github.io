---
// GitHubWidget.astro
// Build-time server-side GitHub Widget using Astro Collections.
// Pre-renders content to static HTML at build time.

import { getEntry, getCollection } from "astro:content";
import { Image } from "astro:assets";

interface GitHubProfile {
  followers: number;
}

interface GitHubRepo {
  title: string;
  description: string;
  html_url: string;
  stars: number;
  language: string;
  image?: any;
  pubDate: Date;
  updatedAt?: string;
}

let profile: GitHubProfile | null = null;
let repos: GitHubRepo[] = [];
let buildError: string | null = null;
let syncRequired = false;

try {
  const profileEntry = await getEntry("github-profile", "profile");
  if (profileEntry) {
    profile = profileEntry.data;
  }

  const reposCollection = await getCollection("github-repos");
  if (reposCollection && reposCollection.length > 0) {
    const rawRepos = reposCollection.map(entry => {
      return {
        title: entry.data.title,
        description: entry.data.description,
        html_url: entry.data.html_url,
        stars: entry.data.stars,
        language: entry.data.language,
        image: entry.data.image,
        pubDate: entry.data.pubDate,
        updatedAt: entry.data.updatedAt
      };
    });
    repos = rawRepos.sort((a, b) => {
      const dateA = a.updatedAt ? new Date(a.updatedAt).getTime() : (a.pubDate ? a.pubDate.getTime() : 0);
      const dateB = b.updatedAt ? new Date(b.updatedAt).getTime() : (b.pubDate ? b.pubDate.getTime() : 0);
      return dateB - dateA;
    });
  }

  if (!profile || repos.length === 0) {
    syncRequired = true;
  }
} catch (error: any) {
  console.warn(`[GitHubWidget Build Warning] Failed to load data from collection: ${error.message || error}`);
  buildError = error.message || String(error);
}

// Language colors mapping
const languageColors: Record<string, string> = {
  TypeScript: "bg-blue-400",
  JavaScript: "bg-yellow-400",
  HTML: "bg-orange-500",
  CSS: "bg-purple-400",
  Astro: "bg-rose-500",
  Python: "bg-blue-500",
  Vue: "bg-emerald-500",
  React: "bg-sky-400",
  C: "bg-gray-400",
  "C++": "bg-pink-500",
  Java: "bg-red-400"
};

// Formulate a clean build timestamp
const buildDateStr = new Date().toLocaleDateString("en-US", {
  month: "short",
  day: "numeric"
});
---

{buildError ? (
  <!-- GitHub Error Card -->
  <div class="glass-card p-4 sm:p-6 rounded-3xl border border-red-500/20 h-full flex flex-col justify-between relative overflow-hidden group">
    <!-- Accent line for error state -->
    <div class="absolute top-0 left-0 right-0 h-1 bg-red-500/80"></div>
    
    <div>
      <!-- Widget Header -->
      <div class="flex items-center justify-between mb-6">
        <div class="flex items-center space-x-2">
          <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
          </svg>
          <span class="text-sm font-semibold tracking-wider uppercase text-red-500">GitHub Feed</span>
        </div>
        <span class="text-[10px] text-red-500 bg-red-500/10 px-2 py-0.5 rounded-full border border-red-500/20 font-semibold uppercase">
          Failed
        </span>
      </div>

      <div class="flex flex-col items-center justify-center text-center py-10">
        <div class="w-12 h-12 rounded-full bg-red-500/10 border border-red-500/20 flex items-center justify-center text-red-500 text-lg mb-4">
          ⚠️
        </div>
        <h4 class="text-sm font-bold text-white mb-2">Build-Time Error</h4>
        <p class="text-xs text-gray-400 leading-relaxed max-w-[220px]">
          Could not load local collection. {buildError}
        </p>
      </div>
    </div>

    <!-- Fallback CTA Button (Direct Profile Link) -->
    <div class="mt-6 pt-4 border-t border-white/5">
      <a 
        href="https://github.com/ghackenberg" 
        target="_blank" 
        rel="noopener noreferrer"
        class="w-full flex items-center justify-center space-x-2 py-2.5 text-xs font-semibold rounded-xl bg-white/5 hover:bg-white/10 text-gray-300 border border-white/10 hover:border-white/20 transition-all duration-300"
      >
        <span>Open Profile Link</span>
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
        </svg>
      </a>
    </div>
  </div>
) : syncRequired ? (
  <!-- GitHub Sync Required Card -->
  <div class="glass-card p-4 sm:p-6 rounded-3xl border border-yellow-500/20 h-full flex flex-col justify-between relative overflow-hidden group">
    <!-- Accent line for sync required state -->
    <div class="absolute top-0 left-0 right-0 h-1 bg-yellow-500/80"></div>
    
    <div>
      <!-- Widget Header -->
      <div class="flex items-center justify-between mb-6">
        <div class="flex items-center space-x-2">
          <svg class="w-6 h-6 text-yellow-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 6H16" />
          </svg>
          <span class="text-sm font-semibold tracking-wider uppercase text-yellow-500">GitHub Feed</span>
        </div>
        <span class="text-[10px] text-yellow-500 bg-yellow-500/10 px-2 py-0.5 rounded-full border border-yellow-500/20 font-semibold uppercase">
          Sync Required
        </span>
      </div>

      <div class="flex flex-col items-center justify-center text-center py-10">
        <div class="w-12 h-12 rounded-full bg-yellow-500/10 border border-yellow-500/20 flex items-center justify-center text-yellow-500 text-lg mb-4">
          ⚙️
        </div>
        <h4 class="text-sm font-bold text-white mb-2">No Local Data Found</h4>
        <p class="text-xs text-gray-400 leading-relaxed max-w-[220px]">
          Please run <code class="bg-white/10 px-1.5 py-0.5 rounded text-yellow-400 font-mono text-[11px]">npm run sync</code> locally to populate the GitHub feed.
        </p>
      </div>
    </div>

    <!-- Fallback CTA Button (Direct Profile Link) -->
    <div class="mt-6 pt-4 border-t border-white/5">
      <a 
        href="https://github.com/ghackenberg" 
        target="_blank" 
        rel="noopener noreferrer"
        class="w-full flex items-center justify-center space-x-2 py-2.5 text-xs font-semibold rounded-xl bg-white/5 hover:bg-white/10 text-gray-300 border border-white/10 hover:border-white/20 transition-all duration-300"
      >
        <span>Open Profile Link</span>
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
        </svg>
      </a>
    </div>
  </div>
) : profile && (
  <!-- GitHub Active Content Card -->
  <div class="glass-card p-4 sm:p-6 md:p-8 rounded-3xl border border-white/5 h-full relative overflow-hidden group">
    <!-- Brand accent header color block -->
    <div class="absolute top-0 left-0 right-0 h-1.5 bg-brand-blue opacity-50 group-hover:opacity-100 transition-opacity"></div>
    
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12">
      <!-- Left column: Profile info & stats -->
      <div class="lg:col-span-4 flex flex-col justify-between">
        <div>
          <!-- Widget Header -->
          <div class="flex items-center justify-between mb-6">
            <div class="flex items-center space-x-3">
              <svg class="w-7 h-7 text-brand-blue shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
              </svg>
              <span class="text-base font-bold tracking-wider uppercase text-brand-blue">GitHub Feed</span>
            </div>
            <span class="text-[10px] text-brand-blue bg-brand-blue/10 border border-brand-blue/20 font-medium px-2 py-0.5 rounded-full whitespace-nowrap">
              Sync: {buildDateStr}
            </span>
          </div>

          <p class="text-sm text-gray-400 mb-6 leading-relaxed">
            Follow my software projects, open-source contributions, and code repositories directly on GitHub.
          </p>

          <!-- Stats Grid -->
          <div class="grid grid-cols-2 gap-4 mb-6">
            <div class="bg-white/5 border border-white/5 rounded-2xl py-3 text-center">
              <p class="text-xs text-gray-500 font-semibold uppercase tracking-wider">Repositories</p>
              <p class="text-xl font-bold text-white font-mono mt-1">{repos.length}</p>
            </div>
            <div class="bg-white/5 border border-white/5 rounded-2xl py-3 text-center">
              <p class="text-xs text-gray-500 font-semibold uppercase tracking-wider">Followers</p>
              <p class="text-xl font-bold text-white font-mono mt-1">{profile.followers}</p>
            </div>
          </div>
        </div>

        <!-- Bottom CTA Button (Moved inside left col) -->
        <div class="pt-6 border-t border-white/5 mt-auto">
          <a 
            href="https://github.com/ghackenberg" 
            target="_blank" 
            rel="noopener noreferrer"
            class="w-full flex items-center justify-center space-x-2 py-3 text-sm font-semibold rounded-xl bg-brand-blue/10 hover:bg-brand-blue/25 text-brand-blue border border-brand-blue/20 hover:border-brand-blue/40 transition-all duration-300"
          >
            <span>Follow on GitHub</span>
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
            </svg>
          </a>
        </div>
      </div>

      <!-- Right column: Repositories list -->
      <div class="lg:col-span-8 flex flex-col justify-center">
        <p class="text-xs font-semibold text-gray-400 tracking-wider uppercase mb-3.5">Recent Repositories</p>
        <div class="space-y-3">
          {repos.slice(0, 3).map((repo) => (
            <a 
              href={repo.html_url} 
              target="_blank" 
              rel="noopener noreferrer"
              class="w-full flex flex-col sm:flex-row items-stretch rounded-2xl bg-white/5 hover:bg-white/10 border border-white/5 hover:border-brand-blue/30 transition-all duration-300 group/item cursor-pointer overflow-hidden p-0 sm:p-1 sm:pr-4"
            >
              <div class="relative w-full aspect-video sm:aspect-auto sm:h-auto sm:w-28 md:w-32 shrink-0 bg-gray-900 border-b sm:border-b-0 sm:border-r border-white/5 group-hover/item:border-brand-blue/30 flex items-center justify-center overflow-hidden rounded-t-2xl sm:rounded-t-none sm:rounded-l-xl">
                {repo.image ? (
                  <>
                    <Image 
                      src={repo.image} 
                      alt=""
                      width={480}
                      height={270}
                      class="absolute inset-0 w-full h-full object-cover group-hover/item:scale-105 transition-transform duration-300 z-0 will-change-transform pointer-events-none" 
                    />
                    <div class="absolute inset-0 bg-gradient-to-br from-[#111827] to-[#0b1329]/20 light:from-[#111827]/60 light:to-[#0b1329]/10 z-10 pointer-events-none"></div>
                  </>
                ) : (
                  <>
                    <div class="absolute inset-0 bg-gradient-to-br from-gray-800 to-blue-950/70 light:from-slate-200 light:to-slate-300/70 z-10"></div>
                    <svg class="w-8 h-8 text-brand-blue/60 group-hover/item:text-brand-blue/90 group-hover/item:scale-110 transition-all duration-300 z-20" fill="currentColor" viewBox="0 0 24 24">
                      <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
                    </svg>
                  </>
                )}
              </div>
              <div class="flex-grow min-w-0 p-4 sm:py-3.5 sm:px-0 sm:pl-4 sm:pr-2.5 select-none">
                <p class="text-sm sm:text-base font-bold text-white group-hover/item:text-brand-blue transition-colors line-clamp-1 font-mono leading-snug">
                  {repo.title}
                </p>
                <p class="text-xs sm:text-sm text-gray-400 line-clamp-2 mt-1 leading-relaxed font-sans font-normal">
                  {repo.description}
                </p>
                <div class="flex items-center space-x-3 text-xs text-gray-500 mt-2 font-medium select-none">
                  <div class="flex items-center space-x-1">
                    <span class={`w-2 h-2 rounded-full ${languageColors[repo.language] || 'bg-gray-400'}`}></span>
                    <span>{repo.language}</span>
                  </div>
                  <span>&bull;</span>
                  <span>⭐ {repo.stars}</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
)}
