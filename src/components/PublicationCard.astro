---
interface Props {
  id: string;
  title: string;
  author: string;
  pubDate: string;
  book?: string;
  tags: string[];
  icon?: string;
  publisherUrl?: string;
  activeTag?: string;
  linkLabel?: string;
}

const { 
  id, 
  title, 
  author, 
  pubDate, 
  book, 
  tags, 
  icon, 
  publisherUrl, 
  activeTag,
  linkLabel = "Abstract & Citation"
} = Astro.props;

function getPublisherDomain(url: string | undefined): string {
  if (!url) return "";
  try {
    const parsed = new URL(url);
    let hostname = parsed.hostname;
    if (hostname.startsWith("www.")) {
      hostname = hostname.substring(4);
    }
    if (hostname === "doi.org") {
      const path = parsed.pathname;
      if (path.includes("10.1109")) return "ieeexplore.ieee.org";
      if (path.includes("10.1145") || path.includes("10.5555")) return "dl.acm.org";
      if (path.includes("10.1007")) return "link.springer.com";
      if (path.includes("10.1016")) return "sciencedirect.com";
      if (path.includes("10.1117")) return "spiedigitallibrary.org";
      if (path.includes("10.3139")) return "hanser-elibrary.com";
      if (path.includes("10.1515")) return "degruyter.com";
      if (path.includes("10.5220")) return "scitepress.org";
      if (path.includes("10.1017")) return "cambridge.org";
    }
    return hostname;
  } catch (e) {
    return "Publisher Page";
  }
}
---

<div class="glass-card p-6 rounded-2xl border border-element-border group flex flex-col md:flex-row gap-6 items-start relative cursor-pointer hover:border-brand-purple/30 h-full w-full">
  <!-- Absolute overlay link for card clickability -->
  <a href={`/publications/${id}`} class="absolute inset-0 z-10" aria-label={title}></a>

  <!-- Icon -->
  <div class="w-12 h-12 md:w-16 md:h-16 rounded-xl overflow-hidden shrink-0 border border-element-border-medium bg-gray-900/50 flex items-center justify-center text-white/30 light:text-slate-900/40 group-hover:text-brand-purple/80 group-hover:border-brand-purple/30 transition-all duration-300 relative">
    {icon ? (
      <svg 
        class="absolute inset-0 w-full h-full group-hover:scale-105 transition-transform duration-300 z-0 will-change-transform pointer-events-none" 
        viewBox="0 0 100 100" 
        preserveAspectRatio="none"
        role="img"
        aria-label={`Publication icon: ${title}`}
      >
        <defs>
          <linearGradient id={`grad-pub-dark-${id.replace(/[^a-zA-Z0-9]/g, '-').toLowerCase()}`} x1="0" y1="0" x2="1" y2="1">
            <stop offset="0%" stop-color="#111827" stop-opacity="1" />
            <stop offset="100%" stop-color="#2e1e0a" stop-opacity="0.2" />
          </linearGradient>
          <linearGradient id={`grad-pub-light-${id.replace(/[^a-zA-Z0-9]/g, '-').toLowerCase()}`} x1="0" y1="0" x2="1" y2="1">
            <stop offset="0%" stop-color="#111827" stop-opacity="0.6" />
            <stop offset="100%" stop-color="#2e1e0a" stop-opacity="0.1" />
          </linearGradient>
        </defs>
        <image 
          href={icon} 
          x="0" 
          y="0" 
          width="100" 
          height="100" 
          preserveAspectRatio="xMidYMid slice" 
        />
        <rect 
          x="0" 
          y="0" 
          width="100" 
          height="100" 
          class="block light:hidden"
          fill={`url(#grad-pub-dark-${id.replace(/[^a-zA-Z0-9]/g, '-').toLowerCase()})`} 
        />
        <rect 
          x="0" 
          y="0" 
          width="100" 
          height="100" 
          class="hidden light:block"
          fill={`url(#grad-pub-light-${id.replace(/[^a-zA-Z0-9]/g, '-').toLowerCase()})`} 
        />
      </svg>
    ) : (
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 md:w-8 md:h-8">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
      </svg>
    )}
  </div>

  <!-- Details -->
  <div class="flex-grow flex flex-col h-full w-full">
    <h3 class="relative pr-6 text-lg font-bold text-gray-100 mb-2 group-hover:text-brand-purple transition-colors leading-snug">
      {title}
      <span 
        class="unread-dot hidden absolute top-[0.625em] -translate-y-1/2 right-0 w-2.5 h-2.5 rounded-full bg-brand-purple shadow-[0_0_8px_rgba(168,85,247,0.8)]" 
        data-item-url={`/publications/${id}`}
        title="Unread publication"
      ></span>
    </h3>
    
    <p class="text-gray-300 text-sm mb-2 font-normal">
      <span set:html={author} />
    </p>

    <p class="text-gray-400 text-xs mb-4 font-normal italic">
      {book && <span>{book}, </span>}
      <span>{pubDate}</span>
    </p>

    <div class="flex flex-wrap gap-2.5 items-center w-full mt-auto">
      {tags.map(tag => (
        <a 
          href={`/publications/tags/${tag}`}
          class={`text-[11px] px-2.5 py-1 rounded-lg bg-element-bg border border-element-border ${tag === activeTag ? 'text-brand-purple border-brand-purple/30 bg-brand-purple/5' : 'text-gray-400 hover:text-gray-100 hover:border-element-border-medium'} transition-all duration-200 relative z-20`}
        >
          #{tag}
        </a>
      ))}
      <div class="ml-auto flex items-center space-x-6 relative z-20">
        {publisherUrl && (
          <a 
            href={publisherUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="text-xs font-semibold text-brand-purple hover:text-brand-purple/85 flex items-center space-x-1 relative z-20 py-1"
          >
            <span>{getPublisherDomain(publisherUrl)}</span>
            <span>↗</span>
          </a>
        )}
        <span 
          class="text-xs font-semibold text-brand-purple group-hover:text-brand-purple/85 flex items-center space-x-1 transition-colors duration-300 cursor-pointer py-1"
        >
          <span>{linkLabel}</span>
          <span>&rarr;</span>
        </span>
      </div>
    </div>
  </div>
</div>
