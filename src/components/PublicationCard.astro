---
interface Props {
  id: string;
  title: string;
  author: string;
  pubDate: string;
  book?: string;
  tags: string[];
  icon?: string;
  publisherUrl?: string;
  activeTag?: string;
  linkLabel?: string;
}

const { 
  id, 
  title, 
  author, 
  pubDate, 
  book, 
  tags, 
  icon, 
  publisherUrl, 
  activeTag,
  linkLabel = "Abstract & Citation"
} = Astro.props;

function getPublisherDomain(url: string | undefined): string {
  if (!url) return "";
  try {
    const parsed = new URL(url);
    let hostname = parsed.hostname;
    if (hostname.startsWith("www.")) {
      hostname = hostname.substring(4);
    }
    if (hostname === "doi.org") {
      const path = parsed.pathname;
      if (path.includes("10.1109")) return "ieeexplore.ieee.org";
      if (path.includes("10.1145") || path.includes("10.5555")) return "dl.acm.org";
      if (path.includes("10.1007")) return "link.springer.com";
      if (path.includes("10.1016")) return "sciencedirect.com";
      if (path.includes("10.1117")) return "spiedigitallibrary.org";
      if (path.includes("10.3139")) return "hanser-elibrary.com";
      if (path.includes("10.1515")) return "degruyter.com";
      if (path.includes("10.5220")) return "scitepress.org";
      if (path.includes("10.1017")) return "cambridge.org";
    }
    return hostname;
  } catch (e) {
    return "Publisher Page";
  }
}
---

<div class="glass-card p-6 rounded-2xl border border-white/5 group flex flex-col md:flex-row gap-6 items-start relative cursor-pointer hover:border-brand-yellow/30 h-full w-full">
  <!-- Icon -->
  <div class="w-12 h-12 md:w-16 md:h-16 rounded-xl overflow-hidden shrink-0 border border-white/10 bg-gray-900/50 flex items-center justify-center text-white/30 group-hover:text-brand-yellow/80 group-hover:border-brand-yellow/30 transition-all duration-300 relative">
    {icon ? (
      <svg 
        class="absolute inset-0 w-full h-full group-hover:scale-105 transition-transform duration-300 z-0 will-change-transform pointer-events-none" 
        viewBox="0 0 100 100" 
        preserveAspectRatio="none"
      >
        <defs>
          <linearGradient id={`grad-pub-${id.replace(/[^a-zA-Z0-9]/g, '-').toLowerCase()}`} x1="0" y1="0" x2="1" y2="1">
            <stop offset="0%" stop-color="#111827" stop-opacity="1" />
            <stop offset="100%" stop-color="#2e1e0a" stop-opacity="0.2" />
          </linearGradient>
        </defs>
        <image 
          href={icon} 
          x="0" 
          y="0" 
          width="100" 
          height="100" 
          preserveAspectRatio="xMidYMid slice" 
        />
        <rect 
          x="0" 
          y="0" 
          width="100" 
          height="100" 
          fill={`url(#grad-pub-${id.replace(/[^a-zA-Z0-9]/g, '-').toLowerCase()})`} 
        />
      </svg>
    ) : (
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 md:w-8 md:h-8">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
      </svg>
    )}
  </div>

  <!-- Details -->
  <div class="flex-grow flex flex-col h-full w-full">
    <h3 class="text-lg font-bold text-white mb-2 group-hover:text-brand-yellow transition-colors leading-snug">
      <a href={`/publications/${id}`} class="after:absolute after:inset-0 after:z-10">
        {title}
      </a>
    </h3>
    
    <p class="text-gray-300 text-sm mb-2 font-normal">
      <span set:html={author} />
    </p>

    <p class="text-gray-400 text-xs mb-4 font-normal italic">
      {book && <span>{book}, </span>}
      <span>{pubDate}</span>
    </p>

    <div class="flex flex-wrap gap-2 items-center w-full mt-auto">
      {tags.map(tag => (
        <a 
          href={`/publications/tags/${tag}`}
          class={`text-xs font-medium ${tag === activeTag ? 'text-brand-yellow' : 'text-gray-500 hover:text-white'} transition-colors relative z-20`}
        >
          #{tag}
        </a>
      ))}
      <div class="ml-auto flex items-center space-x-4 relative z-20">
        {publisherUrl && (
          <a 
            href={publisherUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="text-xs font-semibold text-brand-blue hover:text-brand-blue/85 flex items-center space-x-1"
          >
            <span>{getPublisherDomain(publisherUrl)}</span>
            <span>↗</span>
          </a>
        )}
        <a 
          href={`/publications/${id}`} 
          class="text-xs font-semibold text-brand-yellow hover:text-brand-yellow/85 flex items-center space-x-1"
        >
          <span>{linkLabel}</span>
          <span>&rarr;</span>
        </a>
      </div>
    </div>
  </div>
</div>
