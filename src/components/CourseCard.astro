---
interface Props {
  title: string;
  description?: string;
  href: string;
  language: 'de' | 'en';
  screenshot?: any;
  tech: string;
  starCount?: number;
}

const { 
  title, 
  description, 
  href, 
  language, 
  screenshot, 
  tech, 
  starCount = 0 
} = Astro.props;

// Language colors from courses page
const languageColors: Record<string, string> = {
  TypeScript: "bg-blue-400",
  JavaScript: "bg-yellow-400",
  HTML: "bg-orange-500",
  CSS: "bg-purple-400",
  Astro: "bg-rose-500",
  Python: "bg-blue-500",
  Vue: "bg-emerald-500",
  React: "bg-sky-400",
  C: "bg-gray-400",
  "C++": "bg-pink-500",
  Java: "bg-red-400",
  "C#": "bg-violet-500",
  TeX: "bg-emerald-600",
  Mermaid: "bg-teal-400",
  "Jupyter Notebook": "bg-amber-600"
};
---

<a href={href} class="glass-card h-full rounded-2xl border border-white/5 flex flex-col group overflow-hidden relative cursor-pointer hover:border-brand-yellow/30">
  <!-- Card Header Banner (Preview or Placeholder) -->
  <div class="aspect-video w-full overflow-hidden bg-gray-950 flex items-center justify-center relative" style="transform: translate3d(0, 0, 0); backface-visibility: hidden; -webkit-backface-visibility: hidden;">
    {screenshot ? (
      <svg 
        class="absolute inset-0 w-full h-full group-hover:scale-105 transition-transform duration-500 z-0 will-change-transform pointer-events-none" 
        viewBox="0 0 160 90" 
        preserveAspectRatio="none"
      >
        <defs>
          <linearGradient id={`grad-course-${title.replace(/[^a-zA-Z0-9]/g, '-').toLowerCase()}`} x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#000000" stop-opacity="0" />
            <stop offset="60%" stop-color="#000000" stop-opacity="0.25" />
            <stop offset="100%" stop-color="#000000" stop-opacity="0.85" />
          </linearGradient>
        </defs>
        <image 
          href={screenshot.src} 
          x="0" 
          y="0" 
          width="160" 
          height="90" 
          preserveAspectRatio="xMidYMid slice" 
        />
        <rect 
          x="0" 
          y="0" 
          width="160" 
          height="90.5" 
          fill={`url(#grad-course-${title.replace(/[^a-zA-Z0-9]/g, '-').toLowerCase()})`} 
        />
      </svg>
    ) : (
      <>
        <!-- Premium gradient placeholder for missing preview -->
        <div class="absolute inset-0 bg-gradient-to-br from-brand-yellow/20 via-brand-purple/5 to-blue-950/40 group-hover:scale-105 transition-transform duration-500 z-0"></div>
        <div class="text-4xl select-none relative z-10 filter opacity-60 group-hover:scale-110 transition-transform duration-500">
          🎓
        </div>
      </>
    )}

    <!-- Instruction language badge -->
    <span class="absolute top-4 right-4 z-20 inline-flex items-center text-[10px] font-bold px-2 py-0.5 rounded bg-gray-950/80 text-white border border-white/10 uppercase select-none">
      {language}
    </span>
  </div>

  <!-- Details -->
  <div class="p-6 flex flex-col flex-grow border-t border-white/5">
    <div class="flex-grow flex flex-col">
      <h2 class="relative pr-6 text-lg font-bold text-white mb-2.5 group-hover:text-brand-yellow transition-colors leading-tight">
        {title}
        <span 
          class="unread-dot hidden absolute top-[0.625em] -translate-y-1/2 right-0 w-2.5 h-2.5 rounded-full bg-brand-yellow shadow-[0_0_8px_rgba(245,158,11,0.8)]" 
          data-item-url={href}
          title="Unread course"
        ></span>
      </h2>

      {description && (
        <p class="text-gray-400 text-xs leading-relaxed mb-6 font-normal line-clamp-3 flex-grow">
          {description}
        </p>
      )}
    </div>

    <!-- Card footer: Tech language + Stars -->
    <div class="flex items-center justify-between text-xs text-gray-500 border-t border-white/5 pt-4 mt-auto z-20">
      <div class="flex items-center space-x-1.5">
        <span class={`w-2.5 h-2.5 rounded-full ${languageColors[tech] || 'bg-gray-400'}`}></span>
        <span class="font-medium">{tech}</span>
      </div>
      {starCount > 0 && (
        <span class="font-semibold flex items-center space-x-1">
          <span>⭐</span>
          <span>{starCount}</span>
        </span>
      )}
    </div>
  </div>
</a>
