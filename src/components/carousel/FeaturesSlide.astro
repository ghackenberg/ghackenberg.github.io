---
// FeaturesSlide.astro
interface Feature {
  title: string;
  description: string;
}

interface Props {
  category: string;
  headerLabel?: string;
  title1: string;
  title2?: string;
  features: Feature[];
  index: number;
  total: number;
  theme?: string;
}

const {
  category,
  headerLabel = "",
  title1,
  title2,
  features = [],
  index,
  total,
  theme = "emerald"
} = Astro.props;

const themeMap = {
  emerald: {
    glow1: 'rgba(16, 185, 129, 0.12)',
    glow2: 'rgba(20, 184, 166, 0.08)',
    border: 'via-emerald-500',
    category: 'text-emerald-400',
    borderCol: 'border-emerald-500/80',
    textGradient: 'from-emerald-400 to-cyan-400'
  },
  purple: {
    glow1: 'rgba(168, 85, 247, 0.12)',
    glow2: 'rgba(236, 72, 153, 0.08)',
    border: 'via-purple-500',
    category: 'text-purple-400',
    borderCol: 'border-purple-500/80',
    textGradient: 'from-purple-400 to-pink-400'
  },
  cyan: {
    glow1: 'rgba(6, 182, 212, 0.12)',
    glow2: 'rgba(59, 130, 246, 0.08)',
    border: 'via-cyan-500',
    category: 'text-cyan-400',
    borderCol: 'border-cyan-500/80',
    textGradient: 'from-cyan-400 to-blue-400'
  },
  amber: {
    glow1: 'rgba(245, 158, 11, 0.12)',
    glow2: 'rgba(249, 115, 22, 0.08)',
    border: 'via-amber-500',
    category: 'text-amber-400',
    borderCol: 'border-amber-500/80',
    textGradient: 'from-amber-400 to-orange-400'
  }
};

const activeTheme = themeMap[theme as keyof typeof themeMap] || themeMap.emerald;
---

<div class="slide-page" style={`--glow-1: ${activeTheme.glow1}; --glow-2: ${activeTheme.glow2};`}>
  <!-- Grid overlay -->
  <div class="absolute inset-0 bg-[linear-gradient(to_right,#ffffff02_1px,transparent_1px),linear-gradient(to_bottom,#ffffff02_1px,transparent_1px)] bg-[size:40px_40px] pointer-events-none select-none"></div>
  
  <!-- Accent top border -->
  <div class={`absolute top-0 left-0 w-full h-[4px] bg-gradient-to-r from-transparent ${activeTheme.border} to-transparent opacity-80`}></div>

  <div class="flex justify-between items-center select-none z-10">
    <span class={`${activeTheme.category} font-bold tracking-[0.3em] text-sm uppercase font-['Outfit']`}>{category}</span>
    <span class="text-gray-500 font-semibold text-base font-mono">{headerLabel}</span>
  </div>
  
  <div class="my-auto space-y-6 z-10 w-full flex flex-col justify-center">
    <h2 class="text-5xl font-extrabold tracking-tight text-white leading-[1.15] font-['Outfit']">
      <span set:html={title1}></span>{title2 && <span class={`text-transparent bg-clip-text bg-gradient-to-r ${activeTheme.textGradient}`} set:html={title2}></span>}
    </h2>
    
    <div class="grid grid-cols-2 gap-6 mt-4">
      {features.map((f, i) => (
        <div class={`border-l-4 ${activeTheme.borderCol} border-t border-r border-b border-white/10 bg-zinc-950/40 p-6 rounded-2xl space-y-2 shadow-lg backdrop-blur-sm relative overflow-hidden`}>
          <div class="flex items-center space-x-2">
            <span class={`text-sm font-mono font-bold ${activeTheme.category} select-none`}>0{i+1}</span>
            <h3 class="font-bold text-white text-xl font-['Outfit']">{f.title}</h3>
          </div>
          <p class="text-base text-gray-300 leading-relaxed">{f.description}</p>
        </div>
      ))}
    </div>
  </div>
  
  <div class="flex justify-between items-center text-sm text-gray-500 select-none z-10 font-medium">
    <span class="tracking-wide">Swipe next ➔</span>
    <span class="font-mono">{index} / {total}</span>
  </div>
</div>
