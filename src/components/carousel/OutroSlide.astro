---
// OutroSlide.astro
interface Props {
  category?: string;
  headerLabel?: string;
  title1: string;
  title2?: string;
  description: string;
  icon?: string;
  ctaLabel?: string;
  footerLabel?: string;
  index: number;
  total: number;
  theme?: string;
}

const {
  category = "Open Source",
  headerLabel = "",
  title1,
  title2,
  description,
  icon = "globe",
  ctaLabel = "ghackenberg.github.io",
  footerLabel = "Link in the comments! 👇",
  index,
  total,
  theme = "emerald"
} = Astro.props;

const themeMap = {
  emerald: {
    glow1: 'rgba(16, 185, 129, 0.12)',
    glow2: 'rgba(20, 184, 166, 0.08)',
    border: 'via-emerald-500',
    category: 'text-emerald-400',
    textGradient: 'from-emerald-400 to-cyan-400',
    ctaBg: 'from-emerald-500/15 to-teal-500/15 border border-emerald-500/30 text-emerald-400',
    gradStart: '#34d399',
    gradEnd: '#22d3ee'
  },
  purple: {
    glow1: 'rgba(168, 85, 247, 0.12)',
    glow2: 'rgba(236, 72, 153, 0.08)',
    border: 'via-purple-500',
    category: 'text-purple-400',
    textGradient: 'from-purple-400 to-pink-400',
    ctaBg: 'from-purple-500/15 to-pink-500/15 border border-purple-500/30 text-purple-400',
    gradStart: '#c084fc',
    gradEnd: '#f472b6'
  },
  cyan: {
    glow1: 'rgba(6, 182, 212, 0.12)',
    glow2: 'rgba(59, 130, 246, 0.08)',
    border: 'via-cyan-500',
    category: 'text-cyan-400',
    textGradient: 'from-cyan-400 to-blue-400',
    ctaBg: 'from-cyan-500/15 to-blue-500/15 border border-cyan-500/30 text-cyan-400',
    gradStart: '#22d3ee',
    gradEnd: '#60a5fa'
  },
  amber: {
    glow1: 'rgba(245, 158, 11, 0.12)',
    glow2: 'rgba(249, 115, 22, 0.08)',
    border: 'via-amber-500',
    category: 'text-amber-400',
    textGradient: 'from-amber-400 to-orange-400',
    ctaBg: 'from-amber-500/15 to-orange-500/15 border border-amber-500/30 text-amber-400',
    gradStart: '#fbbf24',
    gradEnd: '#fb923c'
  }
};

const activeTheme = themeMap[theme as keyof typeof themeMap] || themeMap.emerald;

// Check if icon string matches a standard SVG name
const iconName = icon.toLowerCase().trim();
const isGlobe = iconName === 'globe' || iconName === '🌐';
const isCode = iconName === 'code' || iconName === '💻';
const isEducation = iconName === 'education' || iconName === '🎓' || iconName === 'graduation-cap';
const isTerminal = iconName === 'terminal';
const isBook = iconName === 'book';
const isLink = iconName === 'link';
---

<div class="slide-page" style={`--glow-1: ${activeTheme.glow1}; --glow-2: ${activeTheme.glow2};`}>
  <!-- Grid overlay -->
  <div class="absolute inset-0 bg-[linear-gradient(to_right,#ffffff02_1px,transparent_1px),linear-gradient(to_bottom,#ffffff02_1px,transparent_1px)] bg-[size:40px_40px] pointer-events-none select-none"></div>
  
  <!-- Accent top border -->
  <div class={`absolute top-0 left-0 w-full h-[4px] bg-gradient-to-r from-transparent ${activeTheme.border} to-transparent opacity-80`}></div>

  <div class="flex justify-between items-center select-none z-10">
    <span class={`${activeTheme.category} font-bold tracking-[0.3em] text-sm uppercase font-['Outfit']`}>{category}</span>
    <span class="text-gray-500 font-semibold text-base font-mono">{headerLabel}</span>
  </div>
  
  <div class="my-auto text-center flex flex-col items-center z-10 w-full">
    <!-- Unframed SVG Icon Badge with soft ambient radial glow -->
    <div class="relative select-none mb-8 flex items-center justify-center w-24 h-24">
      <!-- Ambient blur backdrop (no borders/rings) -->
      <div class="absolute inset-0 rounded-full opacity-20 blur-xl pointer-events-none" style={`background: radial-gradient(circle, ${activeTheme.gradStart} 0%, ${activeTheme.gradEnd} 100%);`}></div>
      <div class="absolute inset-2 rounded-full opacity-10 blur-md pointer-events-none" style={`background: radial-gradient(circle, ${activeTheme.gradStart} 0%, transparent 80%);`}></div>
      
      <!-- Icon content -->
      <div class={`${activeTheme.category} relative z-10 flex items-center justify-center`}>
        {isGlobe && (
          <svg class="w-20 h-20" fill="none" viewBox="0 0 24 24">
            <defs>
              <linearGradient id={`iconGrad-${index}`} x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color={activeTheme.gradStart} />
                <stop offset="100%" stop-color={activeTheme.gradEnd} />
              </linearGradient>
            </defs>
            <circle cx="12" cy="12" r="11" stroke={`url(#iconGrad-${index})`} stroke-width="0.8" stroke-dasharray="3 6" opacity="0.35" />
            <circle cx="12" cy="12" r="9" stroke={`url(#iconGrad-${index})`} stroke-width="1.6" />
            <path stroke={`url(#iconGrad-${index})`} stroke-width="1" opacity="0.45" stroke-linecap="round" stroke-linejoin="round" d="M12 3v18" />
            <path stroke={`url(#iconGrad-${index})`} stroke-width="1" opacity="0.45" stroke-linecap="round" stroke-linejoin="round" d="M12 3c-2.5 4-2.5 14 0 18" />
            <path stroke={`url(#iconGrad-${index})`} stroke-width="1" opacity="0.45" stroke-linecap="round" stroke-linejoin="round" d="M12 3c2.5 4 2.5 14 0 18" />
            <path stroke={`url(#iconGrad-${index})`} stroke-width="1" opacity="0.45" stroke-linecap="round" stroke-linejoin="round" d="M3 12h18" />
            <path stroke={`url(#iconGrad-${index})`} stroke-width="1" opacity="0.45" stroke-linecap="round" stroke-linejoin="round" d="M4.8 7.5h14.4" />
            <path stroke={`url(#iconGrad-${index})`} stroke-width="1" opacity="0.45" stroke-linecap="round" stroke-linejoin="round" d="M4.8 16.5h14.4" />
            <circle cx="12" cy="12" r="1.5" fill={`url(#iconGrad-${index})`} opacity="0.85" />
          </svg>
        )}
        {isCode && (
          <svg class="w-20 h-20" fill="none" viewBox="0 0 24 24">
            <defs>
              <linearGradient id={`iconGrad-${index}`} x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color={activeTheme.gradStart} />
                <stop offset="100%" stop-color={activeTheme.gradEnd} />
              </linearGradient>
            </defs>
            <circle cx="12" cy="12" r="11" stroke={`url(#iconGrad-${index})`} stroke-width="0.8" stroke-dasharray="3 6" opacity="0.35" />
            <path stroke={`url(#iconGrad-${index})`} stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" d="M8 7L3 12l5 5" />
            <path stroke={`url(#iconGrad-${index})`} stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" d="M16 7l5 5-5 5" />
            <path stroke={`url(#iconGrad-${index})`} stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" opacity="0.5" d="M10 17l4-10" />
            <circle cx="12" cy="4" r="1" fill={`url(#iconGrad-${index})`} opacity="0.6" />
            <circle cx="19" cy="8" r="1.5" fill={`url(#iconGrad-${index})`} opacity="0.8" />
            <circle cx="5" cy="16" r="1" fill={`url(#iconGrad-${index})`} opacity="0.6" />
          </svg>
        )}
        {isEducation && (
          <svg class="w-20 h-20" fill="none" viewBox="0 0 24 24">
            <defs>
              <linearGradient id={`iconGrad-${index}`} x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color={activeTheme.gradStart} />
                <stop offset="100%" stop-color={activeTheme.gradEnd} />
              </linearGradient>
            </defs>
            <circle cx="12" cy="12" r="11" stroke={`url(#iconGrad-${index})`} stroke-width="0.8" stroke-dasharray="3 6" opacity="0.35" />
            <path stroke={`url(#iconGrad-${index})`} stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" d="M12 5L3 10l9 5 9-5-9-5z" />
            <path stroke={`url(#iconGrad-${index})`} stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" d="M6 13v3c0 1.8 2.7 3.5 6 3.5s6-1.7 6-3.5v-3" />
            <path stroke={`url(#iconGrad-${index})`} stroke-width="1.0" stroke-linecap="round" stroke-linejoin="round" opacity="0.6" d="M17 10v5.5a1.25 1.25 0 11-2.5 0" />
            <circle cx="12" cy="12" r="1" fill={`url(#iconGrad-${index})`} opacity="0.7" />
          </svg>
        )}
        {isTerminal && (
          <svg class="w-20 h-20" fill="none" viewBox="0 0 24 24">
            <defs>
              <linearGradient id={`iconGrad-${index}`} x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color={activeTheme.gradStart} />
                <stop offset="100%" stop-color={activeTheme.gradEnd} />
              </linearGradient>
            </defs>
            <circle cx="12" cy="12" r="11" stroke={`url(#iconGrad-${index})`} stroke-width="0.8" stroke-dasharray="3 6" opacity="0.35" />
            <rect x="3" y="5" width="18" height="14" rx="2" stroke={`url(#iconGrad-${index})`} stroke-width="1.6" />
            <path stroke={`url(#iconGrad-${index})`} stroke-width="1.0" opacity="0.4" d="M3 9h18" />
            <circle cx="6" cy="7" r="0.75" fill={`url(#iconGrad-${index})`} opacity="0.6" />
            <circle cx="8.5" cy="7" r="0.75" fill={`url(#iconGrad-${index})`} opacity="0.6" />
            <circle cx="11" cy="7" r="0.75" fill={`url(#iconGrad-${index})`} opacity="0.6" />
            <path stroke={`url(#iconGrad-${index})`} stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" d="M6 12l2 2-2 2" />
            <line x1="9" y1="16" x2="13" y2="16" stroke={`url(#iconGrad-${index})`} stroke-width="1.4" stroke-linecap="round" />
            <circle cx="17" cy="13" r="1" fill={`url(#iconGrad-${index})`} opacity="0.5" />
            <path stroke={`url(#iconGrad-${index})`} stroke-width="1" opacity="0.4" d="M16 16.5h2" />
          </svg>
        )}
        {isBook && (
          <svg class="w-20 h-20" fill="none" viewBox="0 0 24 24">
            <defs>
              <linearGradient id={`iconGrad-${index}`} x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color={activeTheme.gradStart} />
                <stop offset="100%" stop-color={activeTheme.gradEnd} />
              </linearGradient>
            </defs>
            <circle cx="12" cy="12" r="11" stroke={`url(#iconGrad-${index})`} stroke-width="0.8" stroke-dasharray="3 6" opacity="0.35" />
            <path stroke={`url(#iconGrad-${index})`} stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
            <path stroke={`url(#iconGrad-${index})`} stroke-width="1" stroke-linecap="round" opacity="0.45" d="M6 7.5h3M6 10.5h3M6 13.5h3" />
            <path stroke={`url(#iconGrad-${index})`} stroke-width="1" stroke-linecap="round" opacity="0.45" d="M15 7.5h3M15 10.5h3M15 13.5h3" />
            <path stroke={`url(#iconGrad-${index})`} stroke-width="1" stroke-linecap="round" opacity="0.6" d="M12 6v6.5l1.5-1 1.5 1V6" />
          </svg>
        )}
        {isLink && (
          <svg class="w-20 h-20" fill="none" viewBox="0 0 24 24">
            <defs>
              <linearGradient id={`iconGrad-${index}`} x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color={activeTheme.gradStart} />
                <stop offset="100%" stop-color={activeTheme.gradEnd} />
              </linearGradient>
            </defs>
            <circle cx="12" cy="12" r="11" stroke={`url(#iconGrad-${index})`} stroke-width="0.8" stroke-dasharray="3 6" opacity="0.35" />
            <path stroke={`url(#iconGrad-${index})`} stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757" />
            <path stroke={`url(#iconGrad-${index})`} stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" d="M10.81 15.312a4.5 4.5 0 01-1.242-7.244l4.5-4.5a4.5 4.5 0 016.364 6.364l-1.757 1.757" opacity="0.85" />
            <circle cx="12" cy="12" r="1.5" fill={`url(#iconGrad-${index})`} opacity="0.6" />
          </svg>
        )}
        {!isGlobe && !isCode && !isEducation && !isTerminal && !isBook && !isLink && (
          <span class="text-5xl select-none">{icon}</span>
        )}
      </div>
    </div>
    
    <div class="space-y-4 mb-8">
      <h2 class="text-5xl font-extrabold tracking-tight text-white leading-[1.15] font-['Outfit']">
        <span set:html={title1}></span>{title2 && <span class={`text-transparent bg-clip-text bg-gradient-to-r ${activeTheme.textGradient}`} set:html={title2}></span>}
      </h2>
      <p class="text-xl text-gray-300 max-w-md mx-auto leading-relaxed">
        {description}
      </p>
    </div>
    
    <div class={`bg-gradient-to-r ${activeTheme.ctaBg} px-8 py-4 rounded-2xl font-mono text-lg font-bold shadow-lg tracking-wider select-all`}>
      {ctaLabel}
    </div>
  </div>
  
  <div class="flex justify-between items-center text-sm text-gray-500 w-full select-none z-10 font-medium">
    <span class={`${activeTheme.category} font-semibold`}>{footerLabel}</span>
    <span class="font-mono">{index} / {total}</span>
  </div>
</div>
