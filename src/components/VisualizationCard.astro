---
interface Props {
  title: string;
  description: string;
  href: string;
  engineId: string;
  badgeColor: string;
  screenshot?: any;
}

const { 
  title, 
  description, 
  href, 
  engineId, 
  badgeColor, 
  screenshot 
} = Astro.props;
---

<div class="glass-card rounded-2xl border border-white/5 overflow-hidden flex flex-col h-full group relative cursor-pointer hover:border-brand-purple/30">
  <!-- Screenshot -->
  <div class="aspect-video w-full overflow-hidden bg-gray-900 flex items-center justify-center relative" style="transform: translate3d(0, 0, 0); backface-visibility: hidden; -webkit-backface-visibility: hidden;">
    {screenshot && (
      <img 
        src={screenshot.src} 
        alt={title} 
        class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 z-0"
        loading="lazy"
      />
    )}
  </div>

  <!-- Details -->
  <div class="p-6 flex flex-col flex-grow border-t border-white/5">
    <div class="flex-grow flex flex-col">
      <span class={`inline-flex items-center text-[10px] font-semibold px-2 py-0.5 rounded-full border mb-4 tracking-wide uppercase self-start ${badgeColor}`}>
        {engineId} engine
      </span>
      
      <h2 class="text-xl font-bold text-white mb-3 group-hover:text-white transition-colors">
        {title}
      </h2>
      
      <p class="text-gray-400 text-sm leading-relaxed mb-6 font-normal flex-grow">
        {description}
      </p>
    </div>

    <a 
      href={href}
      class="px-5 py-3 rounded-xl bg-white/5 border border-white/10 hover:border-white/20 text-white font-semibold text-center text-sm transition-all duration-300 hover:bg-white/10 after:absolute after:inset-0 after:z-10 mt-auto"
    >
      Launch Visualization &rarr;
    </a>
  </div>
</div>
