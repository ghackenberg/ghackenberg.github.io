---
import { getImage } from "astro:assets";

interface Props {
  title: string;
  description: string;
  href: string;
  engineId: string;
  badgeColor: string;
  screenshot?: any;
}

const { 
  title, 
  description, 
  href, 
  engineId, 
  badgeColor, 
  screenshot 
} = Astro.props;

const optimizedScreenshot = screenshot ? await getImage({
  src: screenshot,
  format: 'webp',
  width: 640,
  quality: 80
}) : null;
---

<div class="glass-card rounded-2xl border border-white/5 overflow-hidden flex flex-col h-full group relative cursor-pointer hover:border-brand-green/30">
  <!-- Screenshot -->
  <div class="aspect-video w-full overflow-hidden bg-gray-900 flex items-center justify-center relative" style="transform: translate3d(0, 0, 0); backface-visibility: hidden; -webkit-backface-visibility: hidden;">
    {screenshot && (
      <svg 
        class="absolute inset-0 w-full h-full group-hover:scale-105 transition-transform duration-500 z-0 will-change-transform pointer-events-none" 
        viewBox="0 0 160 90" 
        preserveAspectRatio="none"
        role="img"
        aria-label={`Visualization preview: ${title}`}
      >
        <defs>
          <linearGradient id={`grad-vis-dark-${title.replace(/[^a-zA-Z0-9]/g, '-').toLowerCase()}`} x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#000000" stop-opacity="0" />
            <stop offset="60%" stop-color="#000000" stop-opacity="0.25" />
            <stop offset="100%" stop-color="#000000" stop-opacity="0.85" />
          </linearGradient>
          <linearGradient id={`grad-vis-light-${title.replace(/[^a-zA-Z0-9]/g, '-').toLowerCase()}`} x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#000000" stop-opacity="0" />
            <stop offset="60%" stop-color="#000000" stop-opacity="0.15" />
            <stop offset="100%" stop-color="#000000" stop-opacity="0.45" />
          </linearGradient>
        </defs>
        <image 
          href={optimizedScreenshot ? optimizedScreenshot.src : ''} 
          x="0" 
          y="0" 
          width="160" 
          height="90" 
          preserveAspectRatio="xMidYMid slice" 
        />
        <rect 
          x="0" 
          y="0" 
          width="160" 
          height="90.5" 
          class="block light:hidden"
          fill={`url(#grad-vis-dark-${title.replace(/[^a-zA-Z0-9]/g, '-').toLowerCase()})`} 
        />
        <rect 
          x="0" 
          y="0" 
          width="160" 
          height="90.5" 
          class="hidden light:block"
          fill={`url(#grad-vis-light-${title.replace(/[^a-zA-Z0-9]/g, '-').toLowerCase()})`} 
        />
      </svg>
    )}
  </div>

  <!-- Details -->
  <div class="p-6 flex flex-col flex-grow border-t border-white/5">
    <div class="flex-grow flex flex-col">
      <span class="inline-flex items-center text-[10px] font-semibold px-2 py-0.5 rounded-full border mb-4 tracking-wide uppercase self-start bg-brand-green/10 text-brand-green border-brand-green/20">
        {engineId} engine
      </span>
      
      <h2 class="relative pr-6 text-xl font-bold text-gray-100 mb-3 group-hover:text-brand-green transition-colors">
        {title}
        <span 
          class="unread-dot hidden absolute top-[0.625em] -translate-y-1/2 right-0 w-2.5 h-2.5 rounded-full bg-brand-green shadow-[0_0_8px_rgba(16,185,129,0.8)]" 
          data-item-url={href}
          title="Unread visualization"
        ></span>
      </h2>
      
      <p class="text-gray-400 text-sm leading-relaxed mb-6 font-normal flex-grow">
        {description}
      </p>
    </div>

    <a 
      href={href}
      class="px-5 py-3 rounded-xl bg-brand-green/10 border border-brand-green/20 hover:border-brand-green/30 text-brand-green font-semibold text-center text-sm transition-all duration-300 hover:bg-brand-green/20 after:absolute after:inset-0 after:z-10 mt-auto"
    >
      Launch Visualization &rarr;
    </a>
  </div>
</div>
