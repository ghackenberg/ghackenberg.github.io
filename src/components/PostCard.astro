---
import { getImage } from "astro:assets";

interface Props {
  id: string;
  title: string;
  description?: string;
  pubDate: Date;
  icon?: any;
  tags: string[];
  activeTag?: string;
}

const { 
  id, 
  title, 
  description, 
  pubDate, 
  icon, 
  tags, 
  activeTag 
} = Astro.props;

const optimizedIcon = icon ? await getImage({
  src: icon,
  format: 'webp',
  width: 192,
  quality: 80
}) : null;
---

<article class="glass-card p-6 rounded-2xl border border-white/5 flex flex-col md:flex-row gap-6 items-start group relative cursor-pointer hover:border-brand-blue/30 h-full w-full">
  {icon && (
    <div class="w-16 h-16 md:w-24 md:h-24 rounded-xl overflow-hidden shrink-0 border border-white/10 bg-gray-990/50 flex items-center justify-center relative">
      <svg 
        class="absolute inset-0 w-full h-full group-hover:scale-105 transition-transform duration-300 z-0 will-change-transform pointer-events-none" 
        viewBox="0 0 100 100" 
        preserveAspectRatio="none"
        role="img"
        aria-label={`Post icon: ${title}`}
      >
        <defs>
          <linearGradient id={`grad-post-dark-${id.replace(/[^a-zA-Z0-9]/g, '-').toLowerCase()}`} x1="0" y1="0" x2="1" y2="1">
            <stop offset="0%" stop-color="#111827" stop-opacity="1" />
            <stop offset="100%" stop-color="#0b1c3a" stop-opacity="0.2" />
          </linearGradient>
          <linearGradient id={`grad-post-light-${id.replace(/[^a-zA-Z0-9]/g, '-').toLowerCase()}`} x1="0" y1="0" x2="1" y2="1">
            <stop offset="0%" stop-color="#111827" stop-opacity="0.6" />
            <stop offset="100%" stop-color="#0b1c3a" stop-opacity="0.1" />
          </linearGradient>
        </defs>
        <image 
          href={optimizedIcon ? optimizedIcon.src : (typeof icon === 'string' ? icon : (icon?.src || ''))} 
          x="0" 
          y="0" 
          width="100" 
          height="100" 
          preserveAspectRatio="xMidYMid slice" 
        />
        <rect 
          x="0" 
          y="0" 
          width="100" 
          height="100" 
          class="block light:hidden"
          fill={`url(#grad-post-dark-${id.replace(/[^a-zA-Z0-9]/g, '-').toLowerCase()})`} 
        />
        <rect 
          x="0" 
          y="0" 
          width="100" 
          height="100" 
          class="hidden light:block"
          fill={`url(#grad-post-light-${id.replace(/[^a-zA-Z0-9]/g, '-').toLowerCase()})`} 
        />
      </svg>
    </div>
  )}
  
  <!-- Content -->
  <div class="flex-grow flex flex-col h-full w-full">
    <div class="flex items-center space-x-3 mb-2.5">
      <time class="text-xs font-semibold text-brand-blue/80">
        {pubDate.toLocaleDateString("en-US", {
          year: "numeric",
          month: "short",
          day: "numeric"
        })}
      </time>
      <span 
        class="unread-dot hidden w-2 h-2 rounded-full bg-brand-blue shadow-[0_0_8px_rgba(59,130,246,0.8)] shrink-0" 
        data-item-url={`/posts/${id}`}
        title="Unread post"
      ></span>
    </div>
    
    <h2 class="text-xl font-bold text-gray-100 mb-3 group-hover:text-brand-blue transition-colors">
      <a href={`/posts/${id}`} class="after:absolute after:inset-0 after:z-10">
        {title}
      </a>
    </h2>
    
    {description && (
      <p class="text-gray-400 text-sm leading-relaxed mb-4 font-normal flex-grow">
        {description}
      </p>
    )}

    <div class="flex flex-wrap gap-2 items-center mt-auto w-full">
      {tags.map(tag => (
        <a 
          href={`/posts/tags/${tag}`}
          class={`text-xs font-medium ${tag === activeTag ? 'text-brand-blue' : 'text-gray-500 hover:text-gray-100'} transition-colors relative z-20`}
        >
          #{tag}
        </a>
      ))}
      <a 
        href={`/posts/${id}`} 
        class="text-xs font-semibold text-brand-blue hover:text-brand-blue/85 ml-auto flex items-center space-x-1 relative z-20"
      >
        <span>Read More</span>
        <span>&rarr;</span>
      </a>
    </div>
  </div>
</article>
