---
// Background.astro
// Premium vector-style sky background with responsive day/night transitions,
// client-side astronomical moon phase rendering, twinkling starfield, shooting stars,
// floating clouds, and scroll/mouse parallax effects on atmospheric elements.
---
<div class="background-container fixed inset-0 overflow-hidden pointer-events-none z-0 select-none">
  <!-- 1. Sky Gradients -->
  <div class="sky-bg sky-bg-night"></div>
  <div class="sky-bg sky-bg-day"></div>

  <!-- 2. Twinkling Stars (Dark Mode Only) -->
  <svg id="bg-layer-stars" class="stars-svg absolute inset-0 w-full h-full" xmlns="http://www.w3.org/2000/svg">
    <g id="sparkling-stars" class="transition-opacity duration-700"></g>
  </svg>

  <!-- 3. Shooting Stars (Dark Mode Only) -->
  <div class="shooting-stars-container absolute inset-0">
    <div class="shooting-star shooting-star-1"></div>
    <div class="shooting-star shooting-star-2"></div>
    <div class="shooting-star shooting-star-3"></div>
  </div>

  <!-- 5. Interactive Ambient Glowing Orbs -->
  <div class="orbs-container absolute inset-0">
    <div class="orb-wrapper bg-glow-wrapper-1" data-speed-y="0.12" data-speed-x="0.06" data-scale="0.15" data-mouse-x="-30" data-mouse-y="-30">
      <div class="bg-glow-orb bg-brand-blue w-[55vmax] h-[55vmax] top-[-15%] left-[-15%]"></div>
    </div>
    <div class="orb-wrapper bg-glow-wrapper-2" data-speed-y="-0.1" data-speed-x="-0.06" data-scale="-0.08" data-mouse-x="40" data-mouse-y="40">
      <div class="bg-glow-orb bg-brand-purple w-[50vmax] h-[50vmax] top-[40%] right-[-15%]" style="animation-delay: -3s;"></div>
    </div>
    <div class="orb-wrapper bg-glow-wrapper-3" data-speed-y="0.08" data-speed-x="-0.08" data-scale="0.05" data-mouse-x="30" data-mouse-y="30">
      <div class="bg-glow-orb bg-brand-green w-[45vmax] h-[45vmax] top-[20%] left-[45%]" style="animation-delay: -9s;"></div>
    </div>
  </div>

  <!-- 4. Floating Clouds (Light Mode Only) -->
  <div id="bg-layer-clouds" class="clouds-container absolute inset-0 overflow-hidden">
    <!-- Cloud 1 (Standard) -->
    <div class="cloud cloud-1">
      <svg width="220" height="90" viewBox="0 0 220 90" fill="none" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <linearGradient id="cloud-grad-1" x1="0%" y1="0%" x2="0%" y2="100%">
            <stop offset="0%" stop-color="#ffffff" stop-opacity="0.9" />
            <stop offset="60%" stop-color="#e2e8f0" stop-opacity="0.75" />
            <stop offset="100%" stop-color="#cbd5e1" stop-opacity="0.5" />
          </linearGradient>
          <linearGradient id="cloud-highlight-1" x1="0%" y1="0%" x2="0%" y2="100%">
            <stop offset="0%" stop-color="#ffffff" stop-opacity="0.95" />
            <stop offset="100%" stop-color="#ffffff" stop-opacity="0" />
          </linearGradient>
        </defs>
        <path d="M40 70 A 25 25 0 0 1 60 30 A 35 35 0 0 1 125 25 A 30 30 0 0 1 175 40 A 22 22 0 0 1 200 70 Z" fill="#94a3b8" fill-opacity="0.2" transform="translate(0, 4)" />
        <path d="M40 70 A 25 25 0 0 1 60 30 A 35 35 0 0 1 125 25 A 30 30 0 0 1 175 40 A 22 22 0 0 1 200 70 Z" fill="url(#cloud-grad-1)" />
        <path d="M40 70 A 25 25 0 0 1 60 30 A 35 35 0 0 1 125 25 A 30 30 0 0 1 175 40" stroke="url(#cloud-highlight-1)" stroke-width="2.5" stroke-linecap="round" fill="none" />
      </svg>
    </div>
    
    <!-- Cloud 2 (Standard) -->
    <div class="cloud cloud-2">
      <svg width="260" height="100" viewBox="0 0 260 100" fill="none" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <linearGradient id="cloud-grad-2" x1="0%" y1="0%" x2="0%" y2="100%">
            <stop offset="0%" stop-color="#ffffff" stop-opacity="0.9" />
            <stop offset="65%" stop-color="#e2e8f0" stop-opacity="0.8" />
            <stop offset="100%" stop-color="#cbd5e1" stop-opacity="0.55" />
          </linearGradient>
          <linearGradient id="cloud-highlight-2" x1="0%" y1="0%" x2="0%" y2="100%">
            <stop offset="0%" stop-color="#ffffff" stop-opacity="0.95" />
            <stop offset="100%" stop-color="#ffffff" stop-opacity="0" />
          </linearGradient>
        </defs>
        <path d="M30 80 A 20 20 0 0 1 45 45 A 28 28 0 0 1 95 35 A 40 40 0 0 1 170 30 A 30 30 0 0 1 220 50 A 20 20 0 0 1 240 80 Z" fill="#94a3b8" fill-opacity="0.2" transform="translate(0, 4)" />
        <path d="M30 80 A 20 20 0 0 1 45 45 A 28 28 0 0 1 95 35 A 40 40 0 0 1 170 30 A 30 30 0 0 1 220 50 A 20 20 0 0 1 240 80 Z" fill="url(#cloud-grad-2)" />
        <path d="M30 80 A 20 20 0 0 1 45 45 A 28 28 0 0 1 95 35 A 40 40 0 0 1 170 30 A 30 30 0 0 1 220 50" stroke="url(#cloud-highlight-2)" stroke-width="2.5" stroke-linecap="round" fill="none" />
      </svg>
    </div>

    <!-- Cloud 3 (Standard) -->
    <div class="cloud cloud-3">
      <svg width="200" height="110" viewBox="0 0 200 110" fill="none" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <linearGradient id="cloud-grad-3" x1="0%" y1="0%" x2="0%" y2="100%">
            <stop offset="0%" stop-color="#ffffff" stop-opacity="0.9" />
            <stop offset="55%" stop-color="#e2e8f0" stop-opacity="0.75" />
            <stop offset="100%" stop-color="#cbd5e1" stop-opacity="0.5" />
          </linearGradient>
          <linearGradient id="cloud-highlight-3" x1="0%" y1="0%" x2="0%" y2="100%">
            <stop offset="0%" stop-color="#ffffff" stop-opacity="0.95" />
            <stop offset="100%" stop-color="#ffffff" stop-opacity="0" />
          </linearGradient>
        </defs>
        <path d="M25 90 A 22 22 0 0 1 40 50 A 32 32 0 0 1 90 25 A 35 35 0 0 1 150 45 A 25 25 0 0 1 180 90 Z" fill="#94a3b8" fill-opacity="0.2" transform="translate(0, 4)" />
        <path d="M25 90 A 22 22 0 0 1 40 50 A 32 32 0 0 1 90 25 A 35 35 0 0 1 150 45 A 25 25 0 0 1 180 90 Z" fill="url(#cloud-grad-3)" />
        <path d="M25 90 A 22 22 0 0 1 40 50 A 32 32 0 0 1 90 25 A 35 35 0 0 1 150 45" stroke="url(#cloud-highlight-3)" stroke-width="2.5" stroke-linecap="round" fill="none" />
      </svg>
    </div>

    <!-- Cloud 4 (Standard) -->
    <div class="cloud cloud-4">
      <svg width="150" height="70" viewBox="0 0 150 70" fill="none" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <linearGradient id="cloud-grad-4" x1="0%" y1="0%" x2="0%" y2="100%">
            <stop offset="0%" stop-color="#ffffff" stop-opacity="0.9" />
            <stop offset="70%" stop-color="#e2e8f0" stop-opacity="0.8" />
            <stop offset="100%" stop-color="#cbd5e1" stop-opacity="0.55" />
          </linearGradient>
          <linearGradient id="cloud-highlight-4" x1="0%" y1="0%" x2="0%" y2="100%">
            <stop offset="0%" stop-color="#ffffff" stop-opacity="0.95" />
            <stop offset="100%" stop-color="#ffffff" stop-opacity="0" />
          </linearGradient>
        </defs>
        <path d="M20 55 A 15 15 0 0 1 30 25 A 22 22 0 0 1 70 20 A 18 18 0 0 1 110 30 A 15 15 0 0 1 130 55 Z" fill="#94a3b8" fill-opacity="0.2" transform="translate(0, 3)" />
        <path d="M20 55 A 15 15 0 0 1 30 25 A 22 22 0 0 1 70 20 A 18 18 0 0 1 110 30 A 15 15 0 0 1 130 55 Z" fill="url(#cloud-grad-4)" />
        <path d="M20 55 A 15 15 0 0 1 30 25 A 22 22 0 0 1 70 20 A 18 18 0 0 1 110 30" stroke="url(#cloud-highlight-4)" stroke-width="2" stroke-linecap="round" fill="none" />
      </svg>
    </div>

    <!-- Cloud 5 (Large Screen Only) -->
    <div class="cloud cloud-5">
      <svg width="300" height="110" viewBox="0 0 300 110" fill="none" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <linearGradient id="cloud-grad-5" x1="0%" y1="0%" x2="0%" y2="100%">
            <stop offset="0%" stop-color="#ffffff" stop-opacity="0.9" />
            <stop offset="60%" stop-color="#e2e8f0" stop-opacity="0.75" />
            <stop offset="100%" stop-color="#cbd5e1" stop-opacity="0.5" />
          </linearGradient>
          <linearGradient id="cloud-highlight-5" x1="0%" y1="0%" x2="0%" y2="100%">
            <stop offset="0%" stop-color="#ffffff" stop-opacity="0.95" />
            <stop offset="100%" stop-color="#ffffff" stop-opacity="0" />
          </linearGradient>
        </defs>
        <path d="M35 90 A 25 25 0 0 1 55 50 A 35 35 0 0 1 115 35 A 45 45 0 0 1 200 30 A 35 35 0 0 1 255 50 A 25 25 0 0 1 275 90 Z" fill="#94a3b8" fill-opacity="0.2" transform="translate(0, 4)" />
        <path d="M35 90 A 25 25 0 0 1 55 50 A 35 35 0 0 1 115 35 A 45 45 0 0 1 200 30 A 35 35 0 0 1 255 50 A 25 25 0 0 1 275 90 Z" fill="url(#cloud-grad-5)" />
        <path d="M35 90 A 25 25 0 0 1 55 50 A 35 35 0 0 1 115 35 A 45 45 0 0 1 200 30 A 35 35 0 0 1 255 50" stroke="url(#cloud-highlight-5)" stroke-width="2.5" stroke-linecap="round" fill="none" />
      </svg>
    </div>

    <!-- Cloud 6 (Large Screen Only) -->
    <div class="cloud cloud-6">
      <svg width="240" height="95" viewBox="0 0 240 95" fill="none" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <linearGradient id="cloud-grad-6" x1="0%" y1="0%" x2="0%" y2="100%">
            <stop offset="0%" stop-color="#ffffff" stop-opacity="0.9" />
            <stop offset="65%" stop-color="#e2e8f0" stop-opacity="0.8" />
            <stop offset="100%" stop-color="#cbd5e1" stop-opacity="0.55" />
          </linearGradient>
          <linearGradient id="cloud-highlight-6" x1="0%" y1="0%" x2="0%" y2="100%">
            <stop offset="0%" stop-color="#ffffff" stop-opacity="0.95" />
            <stop offset="100%" stop-color="#ffffff" stop-opacity="0" />
          </linearGradient>
        </defs>
        <path d="M30 75 A 22 22 0 0 1 45 40 A 30 30 0 0 1 100 30 A 32 32 0 0 1 160 35 A 25 25 0 0 1 200 45 A 20 20 0 0 1 220 75 Z" fill="#94a3b8" fill-opacity="0.2" transform="translate(0, 4)" />
        <path d="M30 75 A 22 22 0 0 1 45 40 A 30 30 0 0 1 100 30 A 32 32 0 0 1 160 35 A 25 25 0 0 1 200 45 A 20 20 0 0 1 220 75 Z" fill="url(#cloud-grad-6)" />
        <path d="M30 75 A 22 22 0 0 1 45 40 A 30 30 0 0 1 100 30 A 32 32 0 0 1 160 35 A 25 25 0 0 1 200 45" stroke="url(#cloud-highlight-6)" stroke-width="2.5" stroke-linecap="round" fill="none" />
      </svg>
    </div>
  </div>
</div>

<style>
  /* Base Container */
  .background-container {
    width: 100%;
    height: 100vh;
  }

  /* Sky Gradients */
  .sky-bg {
    position: absolute;
    inset: 0;
    transition: opacity 1s cubic-bezier(0.4, 0, 0.2, 1);
    pointer-events: none;
  }
  .sky-bg-night {
    background: linear-gradient(to bottom, #020408 0%, #050b18 45%, #0c152a 100%);
    opacity: 1;
  }
  .sky-bg-day {
    background: linear-gradient(to bottom, #7dd3fc 0%, #bae6fd 50%, #f8fafc 100%);
    opacity: 0;
  }
  :global(.light) .sky-bg-night {
    opacity: 0;
  }
  :global(.light) .sky-bg-day {
    opacity: 1;
  }

  /* Orbs container visibility rules */
  .bg-glow-orb {
    position: absolute;
    border-radius: 60% 40% 55% 45%;
    filter: blur(14vmax);
    opacity: 0.18;
    pointer-events: none;
    z-index: 0;
    animation: pulse-slow 12s infinite alternate;
    transition: opacity 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }
  :global(.light) .bg-glow-orb {
    opacity: 0.04;
  }
  @keyframes pulse-slow {
    0% {
      transform: scale(1) translate(0px, 0px);
      opacity: 0.20;
    }
    50% {
      transform: scale(1.1) translate(20px, -20px);
      opacity: 0.28;
    }
    100% {
      transform: scale(0.9) translate(-20px, 20px);
      opacity: 0.14;
    }
  }

  /* Twinkling Stars */
  .stars-svg {
    pointer-events: none;
    will-change: transform;
  }
  :global(.light) .stars-svg {
    opacity: 0;
    transition: opacity 1s cubic-bezier(0.4, 0, 0.2, 1);
  }
  
  /* Twinkling CSS animation */
  :global(@keyframes twinkle) {
    0%, 100% { opacity: 0.25; transform: scale(0.8); }
    50% { opacity: 1; transform: scale(1.25); }
  }

  /* Shooting Stars */
  .shooting-stars-container {
    pointer-events: none;
    transition: opacity 1s cubic-bezier(0.4, 0, 0.2, 1);
    opacity: 1;
  }
  :global(.light) .shooting-stars-container {
    opacity: 0;
  }
  .shooting-star {
    position: absolute;
    width: 80px;
    height: 1.5px;
    background: linear-gradient(to left, rgba(255, 255, 255, 0) 0%, rgba(255, 255, 255, 0.95) 100%);
    opacity: 0;
    pointer-events: none;
  }
  .shooting-star-1 {
    top: 8%;
    left: 70%;
    animation: shoot-1 16s infinite ease-in-out;
  }
  .shooting-star-2 {
    top: 22%;
    left: 55%;
    animation: shoot-2 20s infinite ease-in-out;
    animation-delay: 5s;
  }
  .shooting-star-3 {
    top: 4%;
    left: 85%;
    animation: shoot-3 24s infinite ease-in-out;
    animation-delay: 11s;
  }
  @keyframes shoot-1 {
    0% { transform: rotate(-35deg) translateX(0) scaleX(0); opacity: 0; }
    1% { opacity: 0.85; transform: rotate(-35deg) translateX(0) scaleX(1); }
    3% { transform: rotate(-35deg) translateX(-350px) scaleX(1); opacity: 0; }
    100% { transform: rotate(-35deg) translateX(-350px) scaleX(0); opacity: 0; }
  }
  @keyframes shoot-2 {
    0% { transform: rotate(-38deg) translateX(0) scaleX(0); opacity: 0; }
    1% { opacity: 0.75; transform: rotate(-38deg) translateX(0) scaleX(1); }
    3% { transform: rotate(-38deg) translateX(-280px) scaleX(1); opacity: 0; }
    100% { transform: rotate(-38deg) translateX(-280px) scaleX(0); opacity: 0; }
  }
  @keyframes shoot-3 {
    0% { transform: rotate(-32deg) translateX(0) scaleX(0); opacity: 0; }
    1% { opacity: 0.9; transform: rotate(-32deg) translateX(0) scaleX(1); }
    3.5% { transform: rotate(-32deg) translateX(-420px) scaleX(1); opacity: 0; }
    100% { transform: rotate(-32deg) translateX(-420px) scaleX(0); opacity: 0; }
  }

  /* Floating Clouds */
  .clouds-container {
    pointer-events: none;
    transition: opacity 1s cubic-bezier(0.4, 0, 0.2, 1);
    opacity: 0;
    will-change: transform;
  }
  :global(.light) .clouds-container {
    opacity: 0.7; /* Slightly more visible for the premium gradient clouds */
  }
  .cloud {
    position: absolute;
    pointer-events: none;
  }
  .cloud-1 {
    top: 5%;
    animation: float-cloud-anim 110s linear infinite;
    animation-delay: -20s;
  }
  .cloud-2 {
    top: 18%;
    animation: float-cloud-anim 150s linear infinite;
    animation-delay: -80s;
  }
  .cloud-3 {
    top: 24%;
    animation: float-cloud-anim 180s linear infinite;
    animation-delay: -135s;
  }
  .cloud-4 {
    top: 10%;
    animation: float-cloud-anim 95s linear infinite;
    animation-delay: -45s;
  }
  .cloud-5 {
    top: 14%;
    display: none;
    animation: float-cloud-anim 160s linear infinite;
    animation-delay: -110s;
  }
  .cloud-6 {
    top: 27%;
    display: none;
    animation: float-cloud-anim 130s linear infinite;
    animation-delay: -50s;
  }
  @media (min-width: 1024px) {
    .cloud-5, .cloud-6 {
      display: block;
    }
  }
  @keyframes float-cloud-anim {
    0% { transform: translate3d(-320px, 0, 0); }
    100% { transform: translate3d(105vw, 0, 0); }
  }

</style>

<script>
  function initBackground() {
    const starsLayer = document.getElementById('bg-layer-stars');
    const cloudsLayer = document.getElementById('bg-layer-clouds');
    const wrappers = document.querySelectorAll('.orb-wrapper');

    if (!starsLayer && !cloudsLayer && wrappers.length === 0) {
      return;
    }

    let targetScrollY = window.scrollY;
    let currentScrollY = window.scrollY;
    
    let targetMouseX = 0.5; // normalized 0 to 1
    let targetMouseY = 0.5;
    let currentMouseX = 0.5;
    let currentMouseY = 0.5;

    let ticking = false;

    // Scroll listener
    const onScroll = () => {
      targetScrollY = window.scrollY || document.documentElement.scrollTop;
      requestTick();
    };

    // Mouse movement listener
    const onMouseMove = (e: MouseEvent) => {
      targetMouseX = e.clientX / window.innerWidth;
      targetMouseY = e.clientY / window.innerHeight;
      requestTick();
    };

    // Touch listener for mobile
    const onTouchMove = (e: TouchEvent) => {
      if (e.touches && e.touches[0]) {
        targetMouseX = e.touches[0].clientX / window.innerWidth;
        targetMouseY = e.touches[0].clientY / window.innerHeight;
        requestTick();
      }
    };

    const requestTick = () => {
      if (!ticking) {
        requestAnimationFrame(updateFrame);
        ticking = true;
      }
    };

    const updateFrame = () => {
      const maxScroll = document.documentElement.scrollHeight - window.innerHeight;
      
      const scrollLerp = 0.08;
      const mouseLerp = 0.08;

      currentScrollY += (targetScrollY - currentScrollY) * scrollLerp;
      currentMouseX += (targetMouseX - currentMouseX) * mouseLerp;
      currentMouseY += (targetMouseY - currentMouseY) * mouseLerp;

      const scrollPct = maxScroll > 0 ? currentScrollY / maxScroll : 0;
      
      // Normalized offset from center (-0.5 to 0.5)
      const normMouseX = currentMouseX - 0.5;
      const normMouseY = currentMouseY - 0.5;

      // 1. Celestial & Sky Parallax (Scroll Only)
      if (starsLayer) {
        starsLayer.style.transform = `translate3d(0, ${-currentScrollY * 0.03}px, 0)`;
      }
      if (cloudsLayer) {
        cloudsLayer.style.transform = `translate3d(0, ${-currentScrollY * 0.08}px, 0)`;
      }

      // 2. Orbs Parallax & Mouse Interactivity (Scroll + Mouse/Touch)
      wrappers.forEach(wrapper => {
        const speedY = parseFloat(wrapper.getAttribute('data-speed-y') || '0');
        const speedX = parseFloat(wrapper.getAttribute('data-speed-x') || '0');
        const scaleDelta = parseFloat(wrapper.getAttribute('data-scale') || '0');
        const mouseFactorX = parseFloat(wrapper.getAttribute('data-mouse-x') || '0');
        const mouseFactorY = parseFloat(wrapper.getAttribute('data-mouse-y') || '0');
        
        // Scroll drift translation
        const scrollYShift = currentScrollY * speedY;
        const scrollXShift = currentScrollY * speedX;
        
        // Mouse/Touch drift translation (scaled by factor)
        const mouseXShift = normMouseX * mouseFactorX * 8; 
        const mouseYShift = normMouseY * mouseFactorY * 8;
        
        const totalX = scrollXShift + mouseXShift;
        const totalY = scrollYShift + mouseYShift;
        const scale = 1 + (scrollPct * scaleDelta);
        
        (wrapper as HTMLElement).style.transform = `translate3d(${totalX}px, ${totalY}px, 0) scale(${scale})`;
      });

      const scrollDiff = Math.abs(targetScrollY - currentScrollY);
      const mouseDiffX = Math.abs(targetMouseX - currentMouseX);
      const mouseDiffY = Math.abs(targetMouseY - currentMouseY);

      // Keep animation loop ticking if there's any active movement
      if (scrollDiff > 0.05 || mouseDiffX > 0.001 || mouseDiffY > 0.001) {
        requestAnimationFrame(updateFrame);
      } else {
        ticking = false;
      }
    };

    // Attach listeners
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('mousemove', onMouseMove, { passive: true });
    window.addEventListener('touchmove', onTouchMove, { passive: true });

    // Initial frame run
    requestTick();

    // Starfield Generator
    const starsGroup = document.getElementById('sparkling-stars');
    if (starsGroup) {
      starsGroup.innerHTML = '';
      const numStars = 70;
      for (let i = 0; i < numStars; i++) {
        const cx = Math.random() * 100; // percent
        const cy = Math.random() * 65;  // upper 65% of sky
        const r = Math.random() * 1.1 + 0.5; // size between 0.5px and 1.6px
        const delay = Math.random() * 6; // staggered delay
        const duration = Math.random() * 3 + 2.5; // star twinkle speed
        
        const star = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
        star.setAttribute('cx', `${cx}%`);
        star.setAttribute('cy', `${cy}%`);
        star.setAttribute('r', r.toString());
        star.setAttribute('fill', '#ffffff');
        star.setAttribute('opacity', (Math.random() * 0.6 + 0.3).toString());
        
        // CSS Twinkle styling
        star.style.transformOrigin = `${cx}% ${cy}%`;
        star.style.transformBox = 'fill-box';
        star.style.animation = `twinkle ${duration}s infinite ease-in-out ${delay}s`;
        
        starsGroup.appendChild(star);
      }
    }

  }

  // Initialize immediately
  initBackground();
  
  // Re-run setup on View Transition navigation
  document.addEventListener('astro:page-load', initBackground);
</script>
