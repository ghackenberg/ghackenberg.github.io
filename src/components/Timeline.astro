                        {role.employmentType && (
                          <>
                            <span>&bull;</span>
                            <span>{role.employmentType}</span>
                          </>
                        )}
                        {role.location && role.location !== group.location && (
                          <>
                            <span>&bull;</span>
                            <span>{role.location}</span>
                          </>
                        )}
                      </div>
                      <div class="text-gray-400 text-sm md:text-base leading-relaxed font-normal prose prose-invert max-w-none">
                        <role.Content />
                      </div>
                    </div>
                  </div>
                ))}
