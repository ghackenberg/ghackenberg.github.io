              <stop offset="100%" stop-color="#0f172a" />
            </linearGradient>
          </defs>
          <rect width="100" height="100" rx="24" fill="url(#mannheimGrad)" />
          <path d="M30 45 L50 35 L70 45 L70 65 L30 65 Z" fill="none" stroke="#fbbf24" stroke-width="4" stroke-linejoin="round" />
          <path d="M40 65 L40 55 L60 55 L60 65" fill="none" stroke="#fbbf24" stroke-width="4" />
