                  <stop offset="100%" stop-color={colors[group.color as keyof typeof colors] || '#3b82f6'} />
                </linearGradient>
              </defs>
              <line x1="1" y1="0" x2="1" y2="100%" stroke="url(#dash-grad-top)" stroke-width="2" stroke-dasharray="4,4" />
            </svg>
          )}
          <div 
            data-lifeline-segment
            data-color={group.color}
            style={`top: ${index === 0 ? '104px' : '0px'}; bottom: ${index === companyGroups.length - 1 ? '104px' : '0px'}; background: ${getFallbackGradient(group.color, group.roles.length, index === 0, index === companyGroups.length - 1)}`}
            class="absolute left-[48px] -translate-x-1/2 w-[2px] z-10 opacity-25 group-hover:opacity-100 transition-opacity duration-300"
          ></div>
          {index === companyGroups.length - 1 && (
            <svg
              data-lifeline-dashed-bottom
              class="absolute left-[48px] -translate-x-1/2 bottom-0 w-[2px] z-10 opacity-25 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none overflow-visible"
              style="height: 104px;"
            >
              <defs>
                <linearGradient id="dash-grad-bottom" x1="0" y1="0" x2="0" y2="100%" gradientUnits="userSpaceOnUse">
                  <stop offset="0%" stop-color={colors[group.color as keyof typeof colors] || '#3b82f6'} />
                  <stop offset="100%" stop-color="rgba(255, 255, 255, 0.8)" />
                </linearGradient>
              </defs>
              <line x1="1" y1="0" x2="1" y2="100%" stroke="url(#dash-grad-bottom)" stroke-width="2" stroke-dasharray="4,4" />
            </svg>
          )}

            <div>
              <!-- Company Header -->
              <div class="flex gap-5 items-start mb-6">
                <!-- Logo Container -->
                <div class="w-12 h-12 rounded-xl flex items-center justify-center bg-gray-950 border border-white/10 shrink-0 overflow-hidden shadow-inner relative z-20 timeline-logo-container">
                  {isSelfEmployed ? (
                    <img src="/favicon.svg" alt={group.company} class="w-7 h-7 object-contain" />
                  ) : (
                    <svg viewBox="0 0 100 100" class="w-full h-full" set:html={svgContent}></svg>
                  )}
                </div>
                
                <div class="min-w-0">
                  <h3 class="text-lg md:text-xl font-bold text-white tracking-tight mb-1 group-hover:text-transparent group-hover:bg-clip-text group-hover:bg-gradient-to-r group-hover:from-white group-hover:to-gray-300 transition-all">
                    {group.company}
                  </h3>
                  <div class="flex flex-wrap gap-x-3 gap-y-1 items-center text-xs font-semibold text-gray-400">
                    <span class="px-2.5 py-0.5 rounded-full bg-white/5 border border-white/10 text-gray-300">
                      {group.companyPeriodStr}
                    </span>
                    {group.location && (
                      <span class="text-gray-500 font-medium flex items-center">
