                      data-role-dot
                      data-color={role.color}
                      class={`absolute -left-[35px] top-1.5 w-3.5 h-3.5 rounded-full bg-gray-900 light:bg-white border-2 z-20 transition-all duration-300 group-hover/role:scale-110 ${roleDotColors[role.color]}`}
                    ></span>
                    
                    <div class="w-full min-w-0">
                      <h4 class="text-base font-bold text-white mb-1 group-hover/role:text-transparent group-hover/role:bg-clip-text group-hover/role:bg-gradient-to-r group-hover/role:from-white group-hover/role:to-gray-300 transition-all">
                        {role.title}
                      </h4>
