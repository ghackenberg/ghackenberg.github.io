            </linearGradient>
          </defs>
          <rect width="100" height="100" rx="24" fill="url(#rwthGrad)" />
          <text x="50" y="63" font-family="'Outfit', 'Inter', system-ui, sans-serif" font-weight="900" font-size="30" fill="#ffffff" text-anchor="middle" letter-spacing="-1.5">RWTH</text>
        `;
      } else if (nameLower.includes('siemens')) {
        svgContent = `
          <defs>
            <linearGradient id="siemensGrad" x1="0%" y1="0%" x2="100%" y2="100%">
