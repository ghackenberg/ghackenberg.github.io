      } else if (nameLower.includes('rwth') || nameLower.includes('aachen')) {
        svgContent = `
          <defs>
            <linearGradient id="rwthGrad" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" stop-color="#1e40af" />
