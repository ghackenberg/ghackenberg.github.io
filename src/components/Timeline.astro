---
import { getCollection, render } from 'astro:content';

const experiences = await getCollection('experiences');

const monthNames = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];

// Helper to calculate and format duration
function getDurationStr(totalMonths: number) {
  const years = Math.floor(totalMonths / 12);
  const remainingMonths = totalMonths % 12;
  let durationStr = "";
  if (years > 0) {
    durationStr += `${years} yr${years > 1 ? 's' : ''}`;
  }
  if (remainingMonths > 0) {
    if (durationStr) durationStr += " ";
    durationStr += `${remainingMonths} mo${remainingMonths > 1 ? 's' : ''}`;
  }
  return durationStr;
}

// Process and compile details for all roles
const processedRoles = await Promise.all(experiences.map(async (entry) => {
  const { Content } = await render(entry);
  
  const startMonth = entry.data.startMonth;
  const startYear = entry.data.startYear;
  const endMonth = entry.data.endMonth ?? null;
  const endYear = entry.data.endYear ?? null;
  
  const startDate = new Date(startYear, startMonth - 1);
  const endDate = endYear ? new Date(endYear, endMonth! - 1) : new Date();
  
  const startStr = `${monthNames[startMonth - 1]} ${startYear}`;
  const endStr = endYear ? `${monthNames[endMonth! - 1]} ${endYear}` : "Present";
  
  const totalMonths = (endDate.getFullYear() - startDate.getFullYear()) * 12 + (endDate.getMonth() - startDate.getMonth()) + 1;
  const durationStr = getDurationStr(totalMonths);
  const displayPeriod = `${startStr} - ${endStr} · ${durationStr}`;
  
  return {
    id: entry.id,
    title: entry.data.title,
    company: entry.data.company,
    employmentType: entry.data.employmentType,
    startMonth,
    startYear,
    endMonth,
    endYear,
    location: entry.data.location,
    color: entry.data.color || 'blue',
    order: entry.data.order ?? 0,
    Content,
    startDate,
    endDate,
    isCurrent: !endYear,
    totalMonths,
    displayPeriod,
    durationStr
  };
}));

// Group roles by company name
const groupsMap: Record<string, typeof processedRoles> = {};
processedRoles.forEach(role => {
  if (!groupsMap[role.company]) {
    groupsMap[role.company] = [];
  }
  groupsMap[role.company].push(role);
});

// Build company group objects with aggregated durations and proper inner sorting
const companyGroups = Object.entries(groupsMap).map(([companyName, roles]) => {
  // Sort roles inside the company (newest first)
  roles.sort((a, b) => {
    if (a.isCurrent && !b.isCurrent) return -1;
    if (!a.isCurrent && b.isCurrent) return 1;
    
    if (!a.isCurrent && !b.isCurrent) {
      if (a.endYear !== b.endYear) {
        return (b.endYear ?? 0) - (a.endYear ?? 0);
      }
      if (a.endMonth !== b.endMonth) {
        return (b.endMonth ?? 0) - (a.endMonth ?? 0);
      }
    }
    
    if (a.startYear !== b.startYear) {
      return b.startYear - a.startYear;
    }
    return b.startMonth - a.startMonth;
  });
  
  // Calculate company-wide min/max dates for total tenure duration
  let minStartDate = roles[0].startDate;
  let maxEndDate = roles[0].endDate;
  let isCurrent = false;
  
  roles.forEach(r => {
    if (r.startDate < minStartDate) {
      minStartDate = r.startDate;
    }
    if (r.isCurrent) {
      isCurrent = true;
      maxEndDate = new Date();
    } else if (!isCurrent && r.endDate > maxEndDate) {
      maxEndDate = r.endDate;
    }
  });
  
  const minStartYear = roles[roles.length - 1].startYear;
  const minStartMonth = roles[roles.length - 1].startMonth;
  
  let maxEndYear: number | null = null;
  let maxEndMonth: number | null = null;
  
  if (!isCurrent) {
    let latestRole = roles[0];
    roles.forEach(r => {
      if (r.endYear && (!latestRole.endYear || r.endYear > latestRole.endYear || (r.endYear === latestRole.endYear && (r.endMonth ?? 0) > (latestRole.endMonth ?? 0)))) {
        latestRole = r;
      }
    });
    maxEndYear = latestRole.endYear;
    maxEndMonth = latestRole.endMonth;
  }
  
  const startStr = `${monthNames[minStartMonth - 1]} ${minStartYear}`;
  const endStr = isCurrent ? "Present" : `${monthNames[maxEndMonth! - 1]} ${maxEndYear}`;
  
  const totalMonths = (maxEndDate.getFullYear() - minStartDate.getFullYear()) * 12 + (maxEndDate.getMonth() - minStartDate.getMonth()) + 1;
  const totalDurationStr = getDurationStr(totalMonths);
  const companyPeriodStr = `${startStr} - ${endStr} · ${totalDurationStr}`;
  
  const location = roles[0].location;
  const color = roles[0].color; // Color of the newest active role
  
  return {
    company: companyName,
    roles,
    companyPeriodStr,
    location,
    color,
    isCurrent,
    maxEndDate
  };
});

// Sort company groups: ongoing first (newest start first), then past groups (newest end first)
companyGroups.sort((a, b) => {
  if (a.isCurrent && !b.isCurrent) return -1;
  if (!a.isCurrent && b.isCurrent) return 1;
  
  if (a.isCurrent && b.isCurrent) {
    return b.roles[0].startDate.getTime() - a.roles[0].startDate.getTime();
  }
  
  return b.maxEndDate.getTime() - a.maxEndDate.getTime();
});

const cardBorderColors = {
  blue: 'hover:border-brand-blue/30 border-white/5',
  yellow: 'hover:border-brand-yellow/30 border-white/5',
  purple: 'hover:border-brand-purple/30 border-white/5',
  green: 'hover:border-brand-green/30 border-white/5'
};

const cardGlows = {
  blue: 'bg-brand-blue/5',
  yellow: 'bg-brand-yellow/5',
  purple: 'bg-brand-purple/5',
  green: 'bg-brand-green/5'
};

const roleDotColors = {
  blue: 'border-brand-blue group-hover/role:ring-4 group-hover/role:ring-brand-blue/20',
  yellow: 'border-brand-yellow group-hover/role:ring-4 group-hover/role:ring-brand-yellow/20',
  purple: 'border-brand-purple group-hover/role:ring-4 group-hover/role:ring-brand-purple/20',
  green: 'border-brand-green group-hover/role:ring-4 group-hover/role:ring-brand-green/20'
};

const colors = {
  blue: '#3b82f6',
  yellow: '#f59e0b',
  purple: '#a855f7',
  green: '#10b981'
};

function getFallbackGradient(groupColor: string, rolesCount: number, isFirstCard: boolean = false, isLastCard: boolean = false) {
  const color = colors[groupColor as keyof typeof colors] || '#3b82f6';
  
  if (isFirstCard && isLastCard) {
    return `linear-gradient(to bottom, ${color} 0%, ${color} 100%)`;
  }
  if (isFirstCard) {
    return `linear-gradient(to bottom, ${color} 0%, rgba(255, 255, 255, 0.8) 100%)`;
  }
  if (isLastCard) {
    return `linear-gradient(to bottom, rgba(255, 255, 255, 0.8) 0%, ${color} 100%)`;
  }
  
  if (rolesCount === 1) {
    return `linear-gradient(to bottom, rgba(255, 255, 255, 0.8) 0%, ${color} 40%, rgba(255, 255, 255, 0.8) 100%)`;
  } else {
    return `linear-gradient(to bottom, rgba(255, 255, 255, 0.8) 0%, ${color} 30%, ${color} 70%, rgba(255, 255, 255, 0.8) 100%)`;
  }
}
---

<div data-timeline-container class="relative space-y-8 py-2">
  <!-- Continuous background white line -->
  <div class="absolute left-[49px] -translate-x-1/2 top-2 bottom-2 w-[2px] bg-white/10 light:bg-slate-200 z-0 pointer-events-none rounded-full"></div>
  {companyGroups.map((group, index) => {
    const isLast = index === companyGroups.length - 1;
    // Determine the SVG logo or image to render
    const nameLower = group.company.toLowerCase();
    const isSelfEmployed = nameLower.includes('georg hackenberg');
    
    let svgContent = '';
    if (!isSelfEmployed) {
