</div>

<script>
  const colors = {
    blue: '#3b82f6',
    yellow: '#f59e0b',
    purple: '#a855f7',
    green: '#10b981'
  };

  function updateLifelineGradients() {
    const container = document.querySelector('[data-timeline-container]');
    if (!container) return;
    const cards = container.querySelectorAll('.glass-card');
    cards.forEach((card, cardIndex) => {
      const segment = card.querySelector('[data-lifeline-segment]') as HTMLElement;
      if (!segment) return;

      const dots = card.querySelectorAll('[data-role-dot]');
      const cardRect = card.getBoundingClientRect();
      const cardHeight = cardRect.height;
      
      if (cardHeight <= 0) return;

      const isFirstCard = cardIndex === 0;
      const isLastCard = cardIndex === cards.length - 1;

      let firstDotCenterYFromCardTop = 0;
      let lastDotCenterYFromCardTop = 0;
      if (dots.length > 0) {
        const firstDotRect = dots[0].getBoundingClientRect();
        firstDotCenterYFromCardTop = firstDotRect.top + firstDotRect.height / 2 - cardRect.top;

        const lastDotRect = dots[dots.length - 1].getBoundingClientRect();
        lastDotCenterYFromCardTop = lastDotRect.top + lastDotRect.height / 2 - cardRect.top;
      }

      // 1. Position and scale dashed top/bottom lines
      if (isFirstCard) {
        const dashedTop = card.querySelector('[data-lifeline-dashed-top]') as HTMLElement;
        if (dashedTop) {
          dashedTop.style.height = `${firstDotCenterYFromCardTop}px`;
          const firstDotColorKey = dots.length > 0 ? (dots[0].getAttribute('data-color') || 'blue') : 'blue';
          const firstDotColor = colors[firstDotColorKey as keyof typeof colors] || colors.blue;
          
          const stop = dashedTop.querySelector('linearGradient stop[offset="100%"]');
          if (stop) {
            stop.setAttribute('stop-color', firstDotColor);
          }
        }
      }
      if (isLastCard) {
        const dashedBottom = card.querySelector('[data-lifeline-dashed-bottom]') as HTMLElement;
        if (dashedBottom) {
          dashedBottom.style.top = `${lastDotCenterYFromCardTop}px`;
          dashedBottom.style.height = `${cardHeight - lastDotCenterYFromCardTop}px`;
          const lastDotColorKey = dots.length > 0 ? (dots[dots.length - 1].getAttribute('data-color') || 'blue') : 'blue';
          const lastDotColor = colors[lastDotColorKey as keyof typeof colors] || colors.blue;
          
          const stop = dashedBottom.querySelector('linearGradient stop[offset="0%"]');
          if (stop) {
            stop.setAttribute('stop-color', lastDotColor);
          }
        }
      }

      // 2. Position and scale solid segment
      const segmentTop = isFirstCard ? firstDotCenterYFromCardTop : 0;
      const segmentBottom = isLastCard ? lastDotCenterYFromCardTop : cardHeight;
      const segmentHeight = segmentBottom - segmentTop;

      segment.style.top = `${segmentTop}px`;
      segment.style.bottom = `${cardHeight - segmentBottom}px`;

      if (segmentHeight <= 0) {
        const colorKey = segment.getAttribute('data-color') || 'blue';
        const color = colors[colorKey as keyof typeof colors] || colors.blue;
        segment.style.background = color;
        return;
      }

      // 3. Build gradient stops
      const stops: string[] = [];
      const isLight = document.documentElement.classList.contains('light');
      const fadeColor = isLight ? 'rgba(248, 250, 252, 0.8)' : 'rgba(255, 255, 255, 0.8)';
      
      if (!isFirstCard) {
        // Start with white/light-gray at top
        stops.push(`${fadeColor} 0%`);
      }

      dots.forEach((dot, dotIndex) => {
        const dotRect = dot.getBoundingClientRect();
        const dotCenterY = dotRect.top + dotRect.height / 2;
        const relativeY = dotCenterY - (cardRect.top + segmentTop);
        const percent = Math.max(0, Math.min(100, (relativeY / segmentHeight) * 100));
        const colorKey = dot.getAttribute('data-color') || segment.getAttribute('data-color') || 'blue';
        const color = colors[colorKey as keyof typeof colors] || colors.blue;
        
        if (isFirstCard && dotIndex === 0) {
          stops.push(`${color} 0%`);
        } else if (isLastCard && dotIndex === dots.length - 1) {
          stops.push(`${color} 100%`);
        } else {
          stops.push(`${color} ${percent.toFixed(1)}%`);
        }
      });

      if (!isLastCard) {
        // End with white/light-gray at bottom
        stops.push(`${fadeColor} 100%`);
      }

      // Apply the gradient
      segment.style.background = `linear-gradient(to bottom, ${stops.join(', ')})`;
    });
  }

  // Run on DOM load and Astro page load
  document.addEventListener('DOMContentLoaded', updateLifelineGradients);
  document.addEventListener('astro:page-load', updateLifelineGradients);
  // Listen for theme toggle events
  window.addEventListener('theme-changed', updateLifelineGradients);
  // Run immediately in case DOM is already ready
  updateLifelineGradients();
  // Update on window resize to ensure correct coordinates
  window.addEventListener('resize', updateLifelineGradients);
</script>
