              <stop offset="100%" stop-color="#1f2937" />
            </linearGradient>
          </defs>
          <rect width="100" height="100" rx="24" fill="url(#defaultGrad)" />
          <path d="M50 25 L80 40 L50 55 L20 40 Z" fill="none" stroke="#ffffff" stroke-width="4" />
          <path d="M30 45 V65 C30 70, 50 75, 50 75 C50 75, 70 70, 70 65 V45" fill="none" stroke="#ffffff" stroke-width="4" />
        `;
      }
    }

    return (
      <div class="relative group rounded-2xl">
        <!-- Interactive Glow Element -->
        <div class={`absolute top-0 right-0 w-32 h-32 rounded-full filter blur-3xl opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none ${cardGlows[group.color]}`}></div>
        
        <div class={`glass-card relative p-6 rounded-2xl border transition-all duration-300 ${cardBorderColors[group.color]}`}>
          <!-- Continuous Lifeline Segment -->
          {index === 0 && (
            <svg
              data-lifeline-dashed-top
              class="absolute left-[48px] -translate-x-1/2 top-0 w-[2px] z-10 opacity-25 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none overflow-visible"
              style="height: 104px;"
            >
              <defs>
                <linearGradient id="dash-grad-top" x1="0" y1="0" x2="0" y2="100%" gradientUnits="userSpaceOnUse">
