---
import { getImage } from "astro:assets";

interface Props {
  title: string;
  tagline: string;
  description: string;
  href: string;
  tags: string[];
  accentColor?: 'blue' | 'yellow' | 'purple' | 'green';
  screenshot?: any;
  screenshotLight?: any;
}

const { 
  title, 
  tagline, 
  description, 
  href, 
  tags, 
  accentColor = 'blue',
  screenshot,
  screenshotLight
} = Astro.props;

const optimizedScreenshot = screenshot ? await getImage({
  src: screenshot,
  format: 'webp',
  width: 640,
  quality: 80
}) : null;

const optimizedScreenshotLight = screenshotLight ? await getImage({
  src: screenshotLight,
  format: 'webp',
  width: 640,
  quality: 80
}) : null;

// Dynamically assign classes based on color-coding preferences
const colorClasses = {
  blue: {
    border: 'hover:border-brand-blue/40 border-white/5',
    glow: 'group-hover:bg-brand-blue/10',
    tagBg: 'bg-brand-blue/10 text-brand-blue border-brand-blue/20',
    linkText: 'text-brand-blue hover:text-brand-blue/80',
    btnBg: 'bg-brand-blue/10 text-brand-blue hover:bg-brand-blue/25',
    iconColor: 'text-brand-blue'
  },
  yellow: {
    border: 'hover:border-brand-yellow/40 border-white/5',
    glow: 'group-hover:bg-brand-yellow/10',
    tagBg: 'bg-brand-yellow/10 text-brand-yellow border-brand-yellow/20',
    linkText: 'text-brand-yellow hover:text-brand-yellow/80',
    btnBg: 'bg-brand-yellow/10 text-brand-yellow hover:bg-brand-yellow/25',
    iconColor: 'text-brand-yellow'
  },
  purple: {
    border: 'hover:border-brand-purple/40 border-white/5',
    glow: 'group-hover:bg-brand-purple/10',
    tagBg: 'bg-brand-purple/10 text-brand-purple border-brand-purple/20',
    linkText: 'text-brand-purple hover:text-brand-purple/80',
    btnBg: 'bg-brand-purple/10 text-brand-purple hover:bg-brand-purple/25',
    iconColor: 'text-brand-purple'
  },
  green: {
    border: 'hover:border-brand-green/40 border-white/5',
    glow: 'group-hover:bg-brand-green/10',
    tagBg: 'bg-brand-green/10 text-brand-green border-brand-green/20',
    linkText: 'text-brand-green hover:text-brand-green/80',
    btnBg: 'bg-brand-green/10 text-brand-green hover:bg-brand-green/25',
    iconColor: 'text-brand-green'
  }
}[accentColor];

const dotColorClass = {
  blue: 'bg-brand-blue shadow-[0_0_8px_rgba(59,130,246,0.8)]',
  yellow: 'bg-brand-yellow shadow-[0_0_8px_rgba(245,158,11,0.8)]',
  purple: 'bg-brand-purple shadow-[0_0_8px_rgba(168,85,247,0.8)]',
  green: 'bg-brand-green shadow-[0_0_8px_rgba(16,185,129,0.8)]'
}[accentColor];
---

<a 
  href={href} 
  class={`glass-card h-full rounded-2xl border flex flex-col group overflow-hidden relative cursor-pointer ${colorClasses.border}`}
>
  <!-- Interactive Glow Element -->
  <div class={`absolute top-0 right-0 w-32 h-32 rounded-full filter blur-3xl opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none ${colorClasses.glow}`}></div>
  
  <!-- Card Header Banner (Preview or Placeholder) -->
  <div class="aspect-video w-full overflow-hidden bg-gray-950 flex items-center justify-center relative" style="transform: translate3d(0, 0, 0); backface-visibility: hidden; -webkit-backface-visibility: hidden;">
    {screenshot ? (
      <svg 
        class="absolute inset-0 w-full h-full group-hover:scale-105 transition-transform duration-500 z-0 will-change-transform pointer-events-none" 
        viewBox="0 0 160 90" 
        preserveAspectRatio="none"
        role="img"
        aria-label={`Project preview: ${title}`}
      >
        <defs>
          <linearGradient id={`grad-project-dark-${title.replace(/[^a-zA-Z0-9]/g, '-').toLowerCase()}`} x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#000000" stop-opacity="0" />
            <stop offset="60%" stop-color="#000000" stop-opacity="0.25" />
            <stop offset="100%" stop-color="#000000" stop-opacity="0.85" />
          </linearGradient>
          <linearGradient id={`grad-project-light-${title.replace(/[^a-zA-Z0-9]/g, '-').toLowerCase()}`} x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#000000" stop-opacity="0" />
            <stop offset="60%" stop-color="#000000" stop-opacity="0.15" />
            <stop offset="100%" stop-color="#000000" stop-opacity="0.45" />
          </linearGradient>
        </defs>
        <image 
          href={optimizedScreenshot ? optimizedScreenshot.src : ''} 
          x="0" 
          y="0" 
          width="160" 
          height="90" 
          preserveAspectRatio="xMidYMid slice" 
        />
        <rect 
          x="0" 
          y="0" 
          width="160" 
          height="90.5" 
          class="block light:hidden"
          fill={`url(#grad-project-dark-${title.replace(/[^a-zA-Z0-9]/g, '-').toLowerCase()})`} 
        />
        <rect 
          x="0" 
          y="0" 
          width="160" 
          height="90.5" 
          class="hidden light:block"
          fill={`url(#grad-project-light-${title.replace(/[^a-zA-Z0-9]/g, '-').toLowerCase()})`} 
        />
      </svg>
    ) : (
      <>
        <!-- Premium gradient placeholder for missing preview -->
        <div class={`absolute inset-0 bg-gradient-to-br from-brand-${accentColor}/20 via-brand-purple/5 to-blue-950/40 light:to-slate-100/40 group-hover:scale-105 transition-transform duration-500 z-0`}></div>
        <div class="text-4xl select-none relative z-10 filter opacity-60 group-hover:scale-110 transition-transform duration-500">
          🚀
        </div>
      </>
    )}
  </div>

  <!-- Content Padding Wrapper -->
  <div class="p-6 md:p-8 flex flex-col flex-grow border-t border-white/5">
    <div class="flex-grow flex flex-col">
      <!-- Header -->
      <div class="flex items-start justify-between mb-4 w-full">
        <div class="w-full">
          <h3 class={`relative pr-6 text-xl md:text-2xl font-bold text-white tracking-tight group-hover:text-brand-${accentColor} transition-all duration-300`}>
            {title}
            <span 
              class={`unread-dot hidden absolute top-[0.625em] -translate-y-1/2 right-0 w-2.5 h-2.5 rounded-full ${dotColorClass}`} 
              data-item-url={href}
              title="Unread project"
            ></span>
          </h3>
          <p class={`text-sm font-semibold tracking-wide mt-1 uppercase ${colorClasses.iconColor}`}>
            {tagline}
          </p>
        </div>
      </div>
      
      <!-- Description -->
      <p class="text-gray-400 text-sm md:text-base leading-relaxed mb-6 font-normal flex-grow">
        {description}
      </p>
    </div>

    <!-- Tech tags & actions footer -->
    <div class="mt-auto">
      <div class="flex flex-wrap gap-2 mb-6">
        {tags.map(tag => (
          <span class={`text-xs px-3 py-1 rounded-full border font-medium ${colorClasses.tagBg}`}>
            {tag}
          </span>
        ))}
      </div>
      
      <span 
        class={`inline-flex items-center text-sm font-bold tracking-wide group-hover:translate-x-1 transition-transform duration-300 ${colorClasses.linkText}`}
      >
        Learn more
        <svg class="w-4 h-4 ml-1.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"></path>
        </svg>
      </span>
    </div>
  </div>
</a>
