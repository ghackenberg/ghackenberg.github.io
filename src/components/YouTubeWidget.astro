---
// YouTubeWidget.astro
// Build-time server-side YouTube Widget using Astro Collections.
// Pre-renders content to static HTML.

import { getEntry, getCollection } from "astro:content";
import { Image } from "astro:assets";
import { formatCount } from "../scripts/format";

interface YouTubeVideo {
  title: string;
  id?: string | null;
  pubDate: Date;
  image: any;
  description: string;
  views: number;
  likes: number;
}

interface YouTubeStats {
  subscribers: string;
}

let videos: YouTubeVideo[] = [];
let stats: YouTubeStats | null = null;
let buildError: string | null = null;
let syncRequired = false;

try {
  const profileEntry = await getEntry("youtube-profile", "profile");
  if (profileEntry) {
    stats = profileEntry.data;
  }

  const videosCollection = await getCollection("youtube-videos");
  if (videosCollection && videosCollection.length > 0) {
    const publishedVideos = videosCollection.filter(entry => entry.id);
    const rawVideos = publishedVideos.map(entry => {
      return {
        title: entry.data.title,
        id: entry.id,
        pubDate: entry.data.pubDate,
        image: entry.data.image,
        description: entry.data.description || "",
        views: entry.data.views,
        likes: entry.data.likes
      };
    });
    videos = rawVideos.sort((a, b) => {
      const dateA = a.pubDate ? a.pubDate.getTime() : 0;
      const dateB = b.pubDate ? b.pubDate.getTime() : 0;
      return dateB - dateA;
    });
  }

  if (!stats || videos.length === 0) {
    syncRequired = true;
  }
} catch (error: any) {
  console.warn(`[YouTubeWidget Build Warning] Failed to load data from collection: ${error.message || error}`);
  buildError = error.message || String(error);
}

const buildDateStr = new Date().toLocaleDateString("en-US", {
  month: "short",
  day: "numeric"
});
---

{buildError ? (
  <!-- YouTube Error Card -->
  <div class="glass-card p-4 sm:p-6 rounded-3xl border border-red-500/20 h-full flex flex-col justify-between relative overflow-hidden group">
    <!-- Accent line for error state -->
    <div class="absolute top-0 left-0 right-0 h-1 bg-red-500/80"></div>
    
    <div>
      <!-- Widget Header -->
      <div class="flex items-center justify-between mb-6">
        <div class="flex items-center space-x-2">
          <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
          </svg>
          <span class="text-sm font-semibold tracking-wider uppercase text-red-500">YouTube Feed</span>
        </div>
        <span class="text-[10px] text-red-500 bg-red-500/10 px-2 py-0.5 rounded-full border border-red-500/20 font-semibold uppercase">
          Failed
        </span>
      </div>

      <div class="flex flex-col items-center justify-center text-center py-10">
        <div class="w-12 h-12 rounded-full bg-red-500/10 border border-red-500/20 flex items-center justify-center text-red-500 text-lg mb-4">
          ⚠️
        </div>
        <h4 class="text-sm font-bold text-white mb-2">Build-Time Error</h4>
        <p class="text-xs text-gray-400 leading-relaxed max-w-[220px]">
          Could not load local collection. {buildError}
        </p>
      </div>
    </div>

    <!-- Fallback CTA Button (Direct Channel Link) -->
    <div class="mt-6 pt-4 border-t border-white/5">
      <a 
        href="https://youtube.com/@georghackenberg" 
        target="_blank" 
        rel="noopener noreferrer"
        class="w-full flex items-center justify-center space-x-2 py-2.5 text-xs font-semibold rounded-xl bg-white/5 hover:bg-white/10 text-gray-300 border border-white/10 hover:border-white/20 transition-all duration-300"
      >
        <span>Open YouTube Channel</span>
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
        </svg>
      </a>
    </div>
  </div>
) : syncRequired ? (
  <!-- YouTube Sync Required Card -->
  <div class="glass-card p-4 sm:p-6 rounded-3xl border border-yellow-500/20 h-full flex flex-col justify-between relative overflow-hidden group">
    <!-- Accent line for sync required state -->
    <div class="absolute top-0 left-0 right-0 h-1 bg-yellow-500/80"></div>
    
    <div>
      <!-- Widget Header -->
      <div class="flex items-center justify-between mb-6">
        <div class="flex items-center space-x-2">
          <svg class="w-6 h-6 text-yellow-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 6H16" />
          </svg>
          <span class="text-sm font-semibold tracking-wider uppercase text-yellow-500">YouTube Feed</span>
        </div>
        <span class="text-[10px] text-yellow-500 bg-yellow-500/10 px-2 py-0.5 rounded-full border border-yellow-500/20 font-semibold uppercase">
          Sync Required
        </span>
      </div>

      <div class="flex flex-col items-center justify-center text-center py-10">
        <div class="w-12 h-12 rounded-full bg-yellow-500/10 border border-yellow-500/20 flex items-center justify-center text-yellow-500 text-lg mb-4">
          ⚙️
        </div>
        <h4 class="text-sm font-bold text-white mb-2">No Local Data Found</h4>
        <p class="text-xs text-gray-400 leading-relaxed max-w-[220px]">
          Please run <code class="bg-white/10 px-1.5 py-0.5 rounded text-yellow-400 font-mono text-[11px]">npm run sync</code> locally to populate the YouTube feed.
        </p>
      </div>
    </div>

    <!-- Fallback CTA Button (Direct Channel Link) -->
    <div class="mt-6 pt-4 border-t border-white/5">
      <a 
        href="https://youtube.com/@georghackenberg" 
        target="_blank" 
        rel="noopener noreferrer"
        class="w-full flex items-center justify-center space-x-2 py-2.5 text-xs font-semibold rounded-xl bg-white/5 hover:bg-white/10 text-gray-300 border border-white/10 hover:border-white/20 transition-all duration-300"
      >
        <span>Open YouTube Channel</span>
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
        </svg>
      </a>
    </div>
  </div>
) : stats && videos.length > 0 && (
  <!-- YouTube Active Content Card -->
  <div class="glass-card p-4 sm:p-6 md:p-8 rounded-3xl border border-white/5 h-full relative overflow-hidden group">
    <!-- Brand accent header color block -->
    <div class="absolute top-0 left-0 right-0 h-1.5 bg-brand-green opacity-50 group-hover:opacity-100 transition-opacity"></div>
    
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12">
      <!-- Left column: Channel info & stats -->
      <div class="lg:col-span-4 flex flex-col justify-between">
        <div>
          <!-- Widget Header -->
          <div class="flex items-center justify-between mb-6">
            <div class="flex items-center space-x-3">
              <svg class="w-7 h-7 text-brand-green shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M23.498 6.163a3.003 3.003 0 0 0-2.11-2.11C19.518 3.545 12 3.545 12 3.545s-7.518 0-9.388.507a3.003 3.003 0 0 0-2.11 2.11C0 8.033 0 12 0 12s0 3.967.502 5.837a3.003 3.003 0 0 0 2.11 2.11c1.87.507 9.388.507 9.388.507s7.518 0 9.388-.507a3.003 3.003 0 0 0 2.11-2.11C24 15.967 24 12 24 12s0-3.967-.502-5.837zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
              </svg>
              <span class="text-base font-bold tracking-wider uppercase text-brand-green">YouTube Feed</span>
            </div>
            <span class="text-[10px] text-brand-green bg-brand-green/10 border border-brand-green/20 font-medium px-2 py-0.5 rounded-full whitespace-nowrap">
              Sync: {buildDateStr}
            </span>
          </div>

          <p class="text-sm text-gray-400 mb-6 leading-relaxed">
            Watch coding lectures, live demos, and screencasts mapping software development and industrial informatics.
          </p>

          <!-- Stats Grid -->
          <div class="grid grid-cols-2 gap-4 mb-6">
            <div class="bg-white/5 border border-white/5 rounded-2xl py-3 text-center">
              <p class="text-xs text-gray-500 font-semibold uppercase tracking-wider">Videos</p>
              <p class="text-xl font-bold text-white font-mono mt-1">{videos.length}</p>
            </div>
            <div class="bg-white/5 border border-white/5 rounded-2xl py-3 text-center">
              <p class="text-xs text-gray-500 font-semibold uppercase tracking-wider">Subscribers</p>
              <p class="text-xl font-bold text-white font-mono mt-1">{stats.subscribers}</p>
            </div>
          </div>
        </div>

        <!-- Bottom CTA Button (Moved inside left col) -->
        <div class="pt-6 border-t border-white/5 mt-auto">
          <a 
            href="https://youtube.com/@georghackenberg" 
            target="_blank" 
            rel="noopener noreferrer"
            class="w-full flex items-center justify-center space-x-2 py-3 text-sm font-semibold rounded-xl bg-brand-green/10 hover:bg-brand-green/25 text-brand-green border border-brand-green/20 hover:border-brand-green/40 transition-all duration-300"
          >
            <span>Subscribe on YouTube</span>
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
            </svg>
          </a>
        </div>
      </div>

      <!-- Right column: Recent Video Feed -->
      <div class="lg:col-span-8 flex flex-col justify-center">
        <p class="text-xs font-semibold text-gray-400 tracking-wider uppercase mb-3.5">Recent Videos</p>
        <div class="space-y-3">
          {videos.slice(0, 3).map((video) => (
            <a 
              href={`https://youtube.com/watch?v=${video.id}`}
              target="_blank" 
              rel="noopener noreferrer"
              class="w-full flex flex-col sm:flex-row items-stretch rounded-2xl bg-white/5 hover:bg-white/10 border border-white/5 hover:border-brand-green/30 transition-all duration-300 group/item cursor-pointer overflow-hidden p-0"
            >
              <div class="relative w-full aspect-video sm:aspect-auto sm:h-auto sm:w-28 md:w-32 shrink-0 bg-gray-900 light:bg-slate-100 border-b sm:border-b-0 sm:border-r border-white/5 group-hover/item:border-brand-green/30 flex items-center justify-center overflow-hidden rounded-t-2xl sm:rounded-tr-none sm:rounded-l-2xl">
                {video.image ? (
                  <>
                    <Image 
                      src={video.image} 
                      alt=""
                      width={480}
                      height={360}
                      class="absolute inset-0 w-full h-full object-cover group-hover/item:scale-105 transition-transform duration-300 z-0 will-change-transform pointer-events-none" 
                    />
                    <div class="absolute inset-0 bg-gradient-to-br from-[#111827] to-[#051e14]/40 light:from-[#111827]/60 light:to-[#051e14]/20 z-10 pointer-events-none"></div>
                    <div class="absolute inset-0 flex items-center justify-center z-20 opacity-70 group-hover/item:opacity-100 transition-opacity pointer-events-none">
                      <svg class="w-6 h-6 text-brand-green group-hover/item:scale-110 transition-transform" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M8 5v14l11-7z" />
                      </svg>
                    </div>
                  </>
                ) : (
                  <>
                    <div class="absolute inset-0 bg-gradient-to-br from-green-900/60 to-emerald-950/80 light:from-green-100/60 light:to-emerald-50/80 z-10"></div>
                    <svg class="w-6 h-6 text-brand-green/50 group-hover/item:text-brand-green/80 transition-colors z-20" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M23.498 6.163a3.003 3.003 0 0 0-2.11-2.11C19.518 3.545 12 3.545 12 3.545s-7.518 0-9.388.507a3.003 3.003 0 0 0 2.11 2.11C0 8.033 0 12 0 12s0 3.967.502 5.837a3.003 3.003 0 0 0 2.11 2.11c1.87.507 9.388.507 9.388.507s7.518 0 9.388-.507a3.003 3.003 0 0 0 2.11-2.11C24 15.967 24 12 24 12s0-3.967-.502-5.837zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
                    </svg>
                  </>
                )}
              </div>
              <div class="flex-grow min-w-0 p-4 sm:py-3.5 sm:pl-4 sm:pr-4 select-none">
                <p class="text-sm sm:text-base font-semibold text-white group-hover/item:text-brand-green transition-colors line-clamp-1 font-sans leading-snug">
                  {video.title}
                </p>
                <p class="text-xs sm:text-sm text-gray-400 line-clamp-2 mt-1 leading-relaxed font-sans font-normal">
                  {video.description}
                </p>
                <div class="flex items-center space-x-2 text-xs text-gray-500 mt-2 font-medium select-none">
                  <span>👁️ {formatCount(video.views)}</span>
                  <span>&bull;</span>
                  <span>👍 {formatCount(video.likes)}</span>
                  <span>&bull;</span>
                  <span>{new Date(video.pubDate).toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })}</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
)}
