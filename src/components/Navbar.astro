---
const { pathname } = Astro.url;
const normalizedPathname = pathname.replace(/\/$/, "") || "/";

const isActive = (href: string) => {
  if (href === "/") {
    return normalizedPathname === "/";
  }
  return normalizedPathname.startsWith(href);
};

const navItems = [
  { label: "Home", href: "/" },
  { label: "Posts", href: "/posts", badgeColor: "bg-brand-blue text-white shadow-brand-blue/20" },
  { label: "Courses", href: "/courses", badgeColor: "bg-brand-blue text-white shadow-brand-blue/20" },
  { label: "Projects", href: "/projects", badgeColor: "bg-brand-blue text-white shadow-brand-blue/20" },
  { label: "Services", href: "/services", badgeColor: "bg-brand-blue text-white shadow-brand-blue/20" },
  { label: "Papers", href: "/publications", badgeColor: "bg-brand-blue text-white shadow-brand-blue/20" },
  { label: "Demos", href: "/visualizations", badgeColor: "bg-brand-blue text-white shadow-brand-blue/20" }
];
---

<div class="sticky top-0 left-0 right-0 z-50 w-full">
  <header class="transition-all duration-300 w-full glass-panel border-b border-white/5 py-4 backdrop-blur-md">
  <div class="max-w-6xl mx-auto px-4 md:px-8 flex items-center justify-between">
    
    <!-- Logo / Brand -->
    <a href="/" class="flex items-center space-x-2 group">
      <span class="text-xl font-extrabold tracking-tight bg-clip-text text-transparent bg-gradient-to-r from-brand-blue via-brand-purple to-brand-yellow group-hover:opacity-80 transition-opacity">
        GH.
      </span>
      <span class="font-semibold text-sm text-gray-300 tracking-wide group-hover:text-gray-100 transition-colors nav-logo-name">
        Georg Hackenberg
      </span>
    </a>

    <!-- Desktop Navigation Links -->
    <nav class="hidden nav:flex items-center space-x-6">
      {navItems.map(item => {
        const active = isActive(item.href);
        return (
          <a 
            href={item.href} 
            class={`relative py-1 text-xs nav:text-sm font-medium transition-all duration-200 flex items-center gap-1.5 hover:scale-105 ${
              active 
                ? "text-brand-blue font-semibold" 
                : "text-gray-400 hover:text-gray-100"
            }`}
          >
            <span>{item.label}</span>
            {item.badgeColor && (
              <span 
                class={`nav-badge hidden px-1.5 py-0.5 text-[9px] font-extrabold rounded-full ${item.badgeColor} shadow-md`}
                data-section={item.href.replace(/^\//, '')}
              >
              </span>
            )}
            {active && (
              <span class="absolute bottom-0 left-0 right-0 h-[2px] bg-brand-blue rounded-full shadow-[0_0_8px_rgba(59,130,246,0.8)]" />
            )}
          </a>
        );
      })}
      <a 
        href="/#contact" 
        class="text-xs font-semibold px-4 py-2 rounded-full bg-brand-blue/10 hover:bg-brand-blue/20 text-brand-blue border border-brand-blue/30 transition-all duration-300 hover:shadow-lg hover:shadow-brand-blue/10 hover:scale-105"
      >
        Get In Touch
      </a>

      <!-- Theme Cycle Button Desktop -->
      <button 
        id="theme-cycle-btn-desktop"
        class="w-9 h-9 rounded-full border border-element-border-medium bg-element-bg/50 hover:bg-element-bg text-gray-400 hover:text-gray-100 flex items-center justify-center transition-all duration-200 cursor-pointer active:scale-90 ml-2"
        aria-label="Cycle theme"
      >
        <svg class="w-5 h-5 theme-icon-system" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
        <svg class="w-5 h-5 theme-icon-light" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707m12.728 0l-.707-.707M6.343 6.343l-.707-.707M14 12a2 2 0 11-4 0 2 2 0 014 0z" />
        </svg>
        <svg class="w-5 h-5 theme-icon-dark" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
        </svg>
      </button>
    </nav>

    <!-- Theme Toggle Mobile -->
    <div class="flex items-center space-x-2 nav:hidden">
      <!-- Theme Cycle Button Mobile -->
      <button 
        id="theme-cycle-btn-mobile"
        class="w-11 h-11 rounded-full border border-element-border-medium bg-element-bg/50 hover:bg-element-bg text-gray-400 hover:text-gray-100 flex items-center justify-center transition-all duration-200 cursor-pointer active:scale-90 mr-1"
        aria-label="Cycle theme"
      >
        <svg class="w-5 h-5 theme-icon-system" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
        <svg class="w-5 h-5 theme-icon-light" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707m12.728 0l-.707-.707M6.343 6.343l-.707-.707M14 12a2 2 0 11-4 0 2 2 0 014 0z" />
        </svg>
        <svg class="w-5 h-5 theme-icon-dark" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
        </svg>
      </button>

      <!-- Mobile Menu Button -->
      <button 
        id="mobile-menu-btn" 
        class="text-gray-400 hover:text-gray-100 focus:outline-none p-2.5 rounded-lg hover:bg-element-bg"
        aria-label="Toggle Menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path id="hamburger-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
          <path id="close-icon" class="hidden" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>
  </div>

  </header>

  <!-- Mobile Dropdown Menu -->
  <div 
    id="mobile-menu" 
    class="hidden nav:hidden glass-panel border-b border-element-border absolute top-full left-0 right-0 py-6 px-6 flex flex-col space-y-4 shadow-xl shadow-black/30"
  >
    {navItems.map(item => {
      const active = isActive(item.href);
      return (
        <a 
          href={item.href} 
          class={`text-base font-medium transition-colors py-1 flex items-center justify-between ${
            active 
              ? "text-brand-blue font-semibold border-l-2 border-brand-blue pl-3 -ml-3" 
              : "text-gray-300 hover:text-gray-100"
          }`}
        >
          <span>{item.label}</span>
          {item.badgeColor && (
            <span 
              class={`nav-badge hidden px-2 py-0.5 text-[10px] font-extrabold rounded-full ${item.badgeColor} shadow-md`}
              data-section={item.href.replace(/^\//, '')}
            >
            </span>
          )}
        </a>
      );
    })}
    <a 
      href="/#contact" 
      class="text-sm font-bold text-center py-2.5 rounded-lg bg-brand-blue text-slate-950 shadow-lg shadow-brand-blue/20 hover:bg-brand-blue/95 transition-all block"
    >
      Get In Touch
    </a>
  </div>
</div>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const hamburger = document.getElementById('hamburger-icon');
  const closeIcon = document.getElementById('close-icon');
  
  if (btn && menu && hamburger && closeIcon) {
    btn.addEventListener('click', () => {
      menu.classList.toggle('hidden');
      hamburger.classList.toggle('hidden');
      closeIcon.classList.toggle('hidden');
    });

    // Close menu when a link is clicked
    const links = menu.querySelectorAll('a');
    links.forEach(link => {
      link.addEventListener('click', () => {
        menu.classList.add('hidden');
        hamburger.classList.remove('hidden');
        closeIcon.classList.add('hidden');
      });
    });
  }

  // Header scroll dynamic visual styling
  window.addEventListener('scroll', () => {
    const header = document.querySelector('header');
    if (header) {
      if (window.scrollY > 50) {
        header.classList.remove('py-4');
        header.classList.add('py-3', 'navbar-scrolled', 'shadow-lg');
      } else {
        header.classList.remove('py-3', 'navbar-scrolled', 'shadow-lg');
        header.classList.add('py-4');
      }
    }
  });

  // Theme Toggle Client Logic
  const initThemeToggle = () => {
    const setTheme = (setting: string) => {
      document.documentElement.setAttribute('data-theme-setting', setting);
      localStorage.setItem('theme', setting);

      let activeTheme = setting;
      if (setting === 'system') {
        const systemIsLight = window.matchMedia && window.matchMedia('(prefers-color-scheme: light)').matches;
        activeTheme = systemIsLight ? 'light' : 'dark';
      }

      if (activeTheme === 'light') {
        document.documentElement.classList.add('light');
      } else {
        document.documentElement.classList.remove('light');
      }

      // Dispatch custom event for Plausible / timelines / graphs
      window.dispatchEvent(new CustomEvent('theme-changed', { 
        detail: { 
          themeSetting: setting,
          resolvedTheme: activeTheme,
          trigger: 'manual'
        } 
      }));
    };

    const cycleTheme = () => {
      const currentSetting = document.documentElement.getAttribute('data-theme-setting') || 'system';
      let nextSetting = 'system';
      if (currentSetting === 'system') {
        nextSetting = 'light';
      } else if (currentSetting === 'light') {
        nextSetting = 'dark';
      } else if (currentSetting === 'dark') {
        nextSetting = 'system';
      }
      setTheme(nextSetting);
    };

    // Clean listeners by replacing elements with clones to avoid memory leaks/double-listeners
    const desktopBtn = document.getElementById('theme-cycle-btn-desktop');
    const mobileBtn = document.getElementById('theme-cycle-btn-mobile');
    
    if (desktopBtn) {
      const clone = desktopBtn.cloneNode(true);
      desktopBtn.replaceWith(clone);
    }
    if (mobileBtn) {
      const clone = mobileBtn.cloneNode(true);
      mobileBtn.replaceWith(clone);
    }

    // Bind click handlers to newly cloned elements
    const newDesktopBtn = document.getElementById('theme-cycle-btn-desktop');
    const newMobileBtn = document.getElementById('theme-cycle-btn-mobile');

    if (newDesktopBtn) {
      newDesktopBtn.addEventListener('click', cycleTheme);
    }
    if (newMobileBtn) {
      newMobileBtn.addEventListener('click', cycleTheme);
    }
  };

  // Initialize immediately
  initThemeToggle();

  // Re-run if Astro uses page load events
  document.addEventListener('astro:page-load', initThemeToggle);
</script>

<style is:global>
  /* Theme Cycle Button Icons Visibility */
  .theme-icon-system,
  .theme-icon-light,
  .theme-icon-dark {
    display: none !important;
  }

  html[data-theme-setting="system"] .theme-icon-system {
    display: block !important;
  }
  html[data-theme-setting="light"] .theme-icon-light {
    display: block !important;
  }
  html[data-theme-setting="dark"] .theme-icon-dark {
    display: block !important;
  }
</style>
