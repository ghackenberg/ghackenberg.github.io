---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import { getCollection } from "astro:content";

const visualizations = await getCollection("visualizations");
---

<Layout title="Visualizations | Dr. Georg Hackenberg" description="Interactive graph visualizations showing relationships between articles, publications, and tags on Georg Hackenberg's website.">
  <Navbar />

  <main class="flex-grow max-w-6xl mx-auto px-4 md:px-8 py-12 md:py-20 w-full relative z-10">
    <div class="mb-12">
      <span class="inline-flex items-center text-xs font-semibold px-3 py-1 rounded-full bg-brand-purple/10 text-brand-purple border border-brand-purple/20 mb-6 tracking-wider uppercase">
        Interactive Graphs
      </span>
      <h1 class="text-4xl md:text-6xl font-extrabold tracking-tight text-white mb-6">
        Live Content <span class="bg-clip-text text-transparent bg-gradient-to-r from-brand-purple via-brand-blue to-brand-green">Visualizations</span>
      </h1>
      <p class="text-gray-400 text-base md:text-lg max-w-2xl font-normal leading-relaxed">
        Explore the relationships between different blog posts, publications, and their topics. These interactive graphs are rendered in real-time using different graph engines.
      </p>
    </div>

    <!-- Visualizations Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {visualizations.map(vis => (
        <div class="glass-card rounded-3xl border border-white/5 overflow-hidden flex flex-col h-full group relative cursor-pointer hover:border-brand-purple/30">
          <!-- Screenshot -->
          <div class="aspect-video w-full overflow-hidden border-b border-white/5 bg-gray-900 flex items-center justify-center relative">
            {vis.data.screenshot && (
              <img 
                src={vis.data.screenshot.src} 
                alt={vis.data.title} 
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
              />
            )}
          </div>

          <!-- Info -->
          <div class="p-6 flex flex-col flex-grow justify-between">
            <div>
              <span class={`inline-flex items-center text-[10px] font-semibold px-2 py-0.5 rounded-full border mb-4 tracking-wide uppercase ${vis.data.badgeColor}`}>
                {vis.id} engine
              </span>
              
              <h2 class="text-xl font-bold text-white mb-3 group-hover:text-white transition-colors">
                {vis.data.title}
              </h2>
              
              <p class="text-gray-400 text-sm leading-relaxed mb-6 font-normal">
                {vis.data.description}
              </p>
            </div>

            <a 
              href={`/visualizations/${vis.id}`}
              class="px-5 py-3 rounded-xl bg-white/5 border border-white/10 hover:border-white/20 text-white font-semibold text-center text-sm transition-all duration-300 hover:bg-white/10 after:absolute after:inset-0 after:z-10"
            >
              Launch Visualization &rarr;
            </a>
          </div>
        </div>
      ))}
    </div>
  </main>
</Layout>

