---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import { getCollection } from "astro:content";
import VisualizationCard from "../../components/VisualizationCard.astro";

const visualizations = await getCollection("visualizations");
---

<Layout title="Visualizations | Dr. Georg Hackenberg" description="Interactive graph visualizations showing relationships between articles, publications, and tags on Georg Hackenberg's website.">
  <Navbar />

  <main class="flex-grow max-w-6xl mx-auto px-4 md:px-8 py-12 md:py-20 w-full relative z-10">
    <div class="mb-12">
      <span class="inline-flex items-center text-xs font-semibold px-3 py-1 rounded-full bg-brand-purple/10 text-brand-purple border border-brand-purple/20 mb-6 tracking-wider uppercase">
        Interactive Graphs
      </span>
      <h1 class="text-4xl md:text-6xl font-extrabold tracking-tight text-white mb-6">
        Live Content <span class="bg-clip-text text-transparent bg-gradient-to-r from-brand-purple via-brand-blue to-brand-green">Visualizations</span>
      </h1>
      <p class="text-gray-400 text-base md:text-lg max-w-2xl font-normal leading-relaxed">
        Explore the relationships between different blog posts, publications, and their topics. These interactive graphs are rendered in real-time using different graph engines.
      </p>
    </div>

    <!-- Visualizations Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {visualizations.map(vis => (
        <VisualizationCard
          title={vis.data.title}
          description={vis.data.description}
          href={`/visualizations/${vis.id}`}
          engineId={vis.id}
          badgeColor={vis.data.badgeColor}
          screenshot={vis.data.screenshot}
        />
      ))}
    </div>
  </main>
</Layout>

