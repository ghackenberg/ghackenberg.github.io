---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const visualizations = await getCollection("visualizations");
  return visualizations.map(vis => ({
    params: { slug: vis.id },
    props: { type: vis.id, title: vis.data.title, screenshot: vis.data.screenshot }
  }));
}

const { type, title, screenshot } = Astro.props;

const posts = await getCollection("posts");
const publications = await getCollection("publications");

// Calculate tags
const tagPosts: Record<string, number> = {};
posts.forEach(p => {
  p.data.tags.forEach(t => {
    tagPosts[t] = (tagPosts[t] || 0) + 1;
  });
});

const tagPubs: Record<string, number> = {};
publications.forEach(p => {
  p.data.tags.forEach(t => {
    tagPubs[t] = (tagPubs[t] || 0) + 1;
  });
});

const allTags = Array.from(new Set([...Object.keys(tagPosts), ...Object.keys(tagPubs)]));

// Prepare payload for Cytoscape
const cytoscapeElements = [];
allTags.forEach(tag => {
  const count = (tagPosts[tag] || 0) + (tagPubs[tag] || 0);
  cytoscapeElements.push({
    data: {
      id: tag,
      name: tag,
      color: "#3b82f6", // Blue
      size: (Math.log(count) + 1) * 15 + 10
    }
  });
});

posts.forEach(post => {
  const path = `/posts/${post.id}`;
  cytoscapeElements.push({
    data: {
      id: path,
      name: post.data.title,
      color: "#10b981", // Green
      size: 15
    }
  });
  post.data.tags.forEach(tag => {
    cytoscapeElements.push({
      data: {
        id: `${path}--${tag}`,
        source: path,
        target: tag
      }
    });
  });
});

publications.forEach(pub => {
  const path = `/publications/${pub.id}`;
  cytoscapeElements.push({
    data: {
      id: path,
      name: pub.data.title,
      color: "#f59e0b", // Yellow
      size: 15
    }
  });
  pub.data.tags.forEach(tag => {
    cytoscapeElements.push({
      data: {
        id: `${path}--${tag}`,
        source: path,
        target: tag
      }
    });
  });
});

// Prepare payload for D3
const d3Nodes = [];
const d3Connections = [];
allTags.forEach(tag => {
  const count = (tagPosts[tag] || 0) + (tagPubs[tag] || 0);
  d3Nodes.push({ id: tag, name: tag, size: Math.log(count) + 1, group: 0 });
});
posts.forEach(post => {
  const path = `/posts/${post.id}`;
  d3Nodes.push({ id: path, name: post.data.title, size: 1, group: 1 });
  post.data.tags.forEach(tag => {
    d3Connections.push({ sourceId: path, targetId: tag });
  });
});
publications.forEach(pub => {
  const path = `/publications/${pub.id}`;
  d3Nodes.push({ id: path, name: pub.data.title, size: 1, group: 2 });
  pub.data.tags.forEach(tag => {
    d3Connections.push({ sourceId: path, targetId: tag });
  });
});

// Prepare payload for Sigma
const sigmaNodes = [];
const sigmaEdges = [];
allTags.forEach(tag => {
  const count = (tagPosts[tag] || 0) + (tagPubs[tag] || 0);
  sigmaNodes.push({
    id: tag,
    label: tag,
    x: Math.random(),
    y: Math.random(),
    size: Math.log(count) + 1,
    color: "#3b82f6"
  });
});
posts.forEach(post => {
  const path = `/posts/${post.id}`;
  sigmaNodes.push({
    id: path,
    label: post.data.title,
    x: Math.random(),
    y: Math.random(),
    size: 1,
    color: "#10b981"
  });
  post.data.tags.forEach(tag => {
    sigmaEdges.push({
      id: `${path}--${tag}`,
      source: path,
      target: tag,
      size: 1,
      color: "rgba(255,255,255,0.07)"
    });
  });
});
publications.forEach(pub => {
  const path = `/publications/${pub.id}`;
  sigmaNodes.push({
    id: path,
    label: pub.data.title,
    x: Math.random(),
    y: Math.random(),
    size: 1,
    color: "#f59e0b"
  });
  pub.data.tags.forEach(tag => {
    sigmaEdges.push({
      id: `${path}--${tag}`,
      source: path,
      target: tag,
      size: 1,
      color: "rgba(255,255,255,0.07)"
    });
  });
});

const payload = {
  cytoscape: { elements: cytoscapeElements },
  d3: { nodes: d3Nodes, connections: d3Connections },
  sigma: { nodes: sigmaNodes, edges: sigmaEdges },
  "3d-force": { nodes: d3Nodes, connections: d3Connections },
  "vis-network": { nodes: d3Nodes, connections: d3Connections }
};

---

<Layout 
  title={`${title} Graph Visualization | Dr. Georg Hackenberg`} 
  description={`An interactive network diagram mapping the connections between blog posts, academic publications, and tags on Dr. Georg Hackenberg's website using ${title}.`}
  image={screenshot?.src}
>
  <Navbar />

  <main class="flex-grow max-w-6xl mx-auto px-4 md:px-8 py-12 md:py-16 w-full relative z-10 flex flex-col h-[calc(100vh-80px)]">
    <!-- Back Button -->
    <a 
      href="/visualizations" 
      class="inline-flex items-center space-x-2 text-xs font-semibold px-4 py-2 rounded-xl bg-white/5 border border-white/10 hover:border-white/20 text-gray-300 hover:text-white transition-all mb-8 cursor-pointer self-start"
    >
      <span>&larr;</span>
      <span>Back to Visualizations</span>
    </a>

    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6 shrink-0">
      <div>
        <h1 class="text-2xl md:text-3xl font-extrabold text-white tracking-tight flex items-center gap-3">
          {title}
          <span class="text-xs px-2.5 py-0.5 rounded-full bg-white/5 border border-white/10 text-gray-400 font-semibold tracking-wide uppercase">
            Interactive
          </span>
        </h1>
      </div>

      <!-- Engine Selector Tabs -->
      <div class="flex flex-wrap gap-1 bg-white/5 border border-white/5 p-1 rounded-xl self-start sm:self-auto">
        <a 
          href="/visualizations/cytoscape" 
          class={`px-4 py-2 rounded-lg text-xs font-bold transition-all ${type === 'cytoscape' ? 'bg-brand-blue text-gray-950 shadow-md' : 'text-gray-400 hover:text-white'}`}
        >
          Cytoscape
        </a>
        <a 
          href="/visualizations/d3" 
          class={`px-4 py-2 rounded-lg text-xs font-bold transition-all ${type === 'd3' ? 'bg-brand-purple text-gray-950 shadow-md' : 'text-gray-400 hover:text-white'}`}
        >
          D3
        </a>
        <a 
          href="/visualizations/sigma" 
          class={`px-4 py-2 rounded-lg text-xs font-bold transition-all ${type === 'sigma' ? 'bg-brand-green text-gray-950 shadow-md' : 'text-gray-400 hover:text-white'}`}
        >
          Sigma
        </a>
        <a 
          href="/visualizations/3d-force" 
          class={`px-4 py-2 rounded-lg text-xs font-bold transition-all ${type === '3d-force' ? 'bg-brand-yellow text-gray-950 shadow-md' : 'text-gray-400 hover:text-white'}`}
        >
          3D Force
        </a>
        <a 
          href="/visualizations/vis-network" 
          class={`px-4 py-2 rounded-lg text-xs font-bold transition-all ${type === 'vis-network' ? 'bg-brand-blue text-gray-950 shadow-md' : 'text-gray-400 hover:text-white'}`}
        >
          Vis.js
        </a>
      </div>
    </div>

    <!-- Graph Panel Area -->
    <div class="flex-grow w-full relative min-h-[450px] rounded-3xl border border-white/5 bg-gray-950/60 backdrop-blur-md overflow-hidden flex flex-col md:flex-row shadow-2xl">
      <!-- Sidebar Legend & Control -->
      <div class="w-full md:w-64 border-b md:border-b-0 md:border-r border-white/5 p-5 shrink-0 bg-gray-950/40 relative z-20 flex flex-col justify-between">
        <div class="space-y-6">
          <div>
            <h2 class="text-xs font-bold text-gray-500 uppercase tracking-widest mb-3">Graph Legend</h2>
            <div class="space-y-2.5">
              <div class="flex items-center space-x-3 text-xs">
                <span class="w-3.5 h-3.5 rounded-full bg-brand-blue border border-white/20 shadow-lg shadow-brand-blue/20"></span>
                <span class="text-gray-300 font-medium">Topic Tags (blue)</span>
              </div>
              <div class="flex items-center space-x-3 text-xs">
                <span class="w-3.5 h-3.5 rounded-full bg-brand-green border border-white/20 shadow-lg shadow-brand-green/20"></span>
                <span class="text-gray-300 font-medium">Blog Posts (green)</span>
              </div>
              <div class="flex items-center space-x-3 text-xs">
                <span class="w-3.5 h-3.5 rounded-full bg-brand-yellow border border-white/20 shadow-lg shadow-brand-yellow/20"></span>
                <span class="text-gray-300 font-medium">Publications (yellow)</span>
              </div>
            </div>
          </div>

          <div class="border-t border-white/5 pt-4">
            <h2 class="text-xs font-bold text-gray-500 uppercase tracking-widest mb-2.5">Interaction</h2>
            <ul class="space-y-1.5 text-xs text-gray-400 list-disc pl-4 font-normal leading-relaxed">
              <li>Drag nodes to rearrange them</li>
              <li>Pinch/scroll wheel to zoom</li>
              <li>Click / Double-click a post or publication node to navigate directly to it</li>
            </ul>
          </div>
        </div>

        <div class="pt-6 text-[10px] text-gray-500 font-medium">
          Built with {title} &amp; Astro.
        </div>
      </div>

      <!-- Graph Rendering Canvas -->
      <div id="canvas" class="flex-grow w-full h-full relative z-10">
        <!-- Render Loading Placeholder -->
        <div id="canvas-loading" class="absolute inset-0 flex items-center justify-center bg-gray-950/80 z-30 transition-opacity duration-300">
          <div class="flex flex-col items-center space-y-4">
            <div class="w-8 h-8 rounded-full border-2 border-brand-green/20 border-t-brand-green animate-spin"></div>
            <span class="text-xs text-gray-400 font-semibold uppercase tracking-wider">Loading Network Graph...</span>
          </div>
        </div>
      </div>
    </div>
  </main>

  <!-- Expose Astro variables to global scope for client script -->
  <script is:inline define:vars={{ type, payload }}>
    window.GRAPH_TYPE = type;
    window.GRAPH_PAYLOAD = payload;
  </script>

  <!-- Inject Graph Boot Scripts -->
  <script type="module" is:inline>
    const type = window.GRAPH_TYPE;
    const payload = window.GRAPH_PAYLOAD;

    window.addEventListener('DOMContentLoaded', () => {
      const container = document.getElementById('canvas');
      const loading = document.getElementById('canvas-loading');
      if (!container) return;

      let activeInstance = null;

      async function runInit() {
        if (activeInstance) {
          if (typeof activeInstance.destroy === 'function') {
            activeInstance.destroy();
          } else if (typeof activeInstance.kill === 'function') {
            activeInstance.kill();
          }
          activeInstance = null;
        }
        container.innerHTML = '';

        try {
          if (type === 'cytoscape') {
            const { default: cytoscape } = await import('https://cdn.jsdelivr.net/npm/cytoscape@3.31.0/+esm');
            activeInstance = initCytoscape(cytoscape);
          } else if (type === 'd3') {
            const d3 = await import('https://cdn.jsdelivr.net/npm/d3@7.9.0/+esm');
            activeInstance = initD3(d3);
          } else if (type === 'sigma') {
            const [
              { Sigma },
              { Graph },
              { default: forceAtlas2 }
            ] = await Promise.all([
              import('https://cdn.jsdelivr.net/npm/sigma@2.4.0/+esm'),
              import('https://cdn.jsdelivr.net/npm/graphology@0.25.4/+esm'),
              import('https://cdn.jsdelivr.net/npm/graphology-layout-forceatlas2@0.10.1/+esm')
            ]);
            activeInstance = initSigma(Sigma, Graph, forceAtlas2);
          } else if (type === '3d-force') {
            const { default: ForceGraph3D } = await import('https://cdn.jsdelivr.net/npm/3d-force-graph@1.73.0/+esm');
            activeInstance = init3DForce(ForceGraph3D);
          } else if (type === 'vis-network') {
            const vis = await import('https://unpkg.com/vis-network@9.1.9/standalone/esm/index.js');
            activeInstance = initVisNetwork(vis);
          }
        } catch (e) {
          console.error("Failed to load visualization: ", e);
        }
      }

      setTimeout(async () => {
        await runInit();
        if (loading) {
          loading.style.opacity = '0';
          setTimeout(() => loading.remove(), 300);
        }
      }, 100);

      window.addEventListener('theme-changed', runInit);

      function initCytoscape(cytoscape) {
        const isLight = document.documentElement.classList.contains('light');
        const cy = cytoscape({
          container: container,
          elements: payload.cytoscape.elements,
          style: [
            {
              selector: 'node',
              style: {
                'background-color': 'data(color)',
                'label': 'data(name)',
                'width': 'data(size)',
                'height': 'data(size)',
                'color': isLight ? '#0f172a' : '#f3f4f6',
                'font-size': '10px',
                'font-family': 'Outfit, Inter, sans-serif',
                'font-weight': '600',
                'text-valign': 'center',
                'text-halign': 'right',
                'text-margin-x': 4,
                'border-width': '2px',
                'border-color': isLight ? '#ffffff' : '#030712',
                'overlay-opacity': 0,
                'transition-property': 'background-color, border-color, width, height',
                'transition-duration': '0.2s'
              }
            },
            {
              selector: 'edge',
              style: {
                'width': 1.5,
                'line-color': isLight ? 'rgba(15, 23, 42, 0.08)' : 'rgba(255,255,255,0.06)',
                'target-arrow-color': isLight ? 'rgba(15, 23, 42, 0.12)' : 'rgba(255,255,255,0.1)',
                'curve-style': 'bezier'
              }
            },
            {
              selector: 'node:selected',
              style: {
                'border-width': '3px',
                'border-color': '#10b981'
              }
            }
          ],
          layout: {
            name: 'cose',
            idealEdgeLength: 100,
            nodeOverlap: 20,
            refresh: 20,
            fit: true,
            padding: 30,
            randomize: true,
            componentSpacing: 100,
            nodeRepulsion: 400000,
            edgeElasticity: 100,
            nestingFactor: 5,
            gravity: 80,
            numIter: 1000,
            initialTemp: 200,
            coolingFactor: 0.95,
            minTemp: 1.0
          }
        });

        cy.on('tap', 'node', function(evt) {
          const node = evt.target;
          const id = node.id();
          if (id.startsWith('/posts/') || id.startsWith('/publications/')) {
            window.location.href = id;
          }
        });

        return cy;
      }

      function initD3(d3) {
        const isLight = document.documentElement.classList.contains('light');
        const width = container.offsetWidth;
        const height = container.offsetHeight;
        
        const nodes = payload.d3.nodes.map(n => ({ ...n }));
        nodes.forEach(n => {
          n.x = Math.random() * width;
          n.y = Math.random() * height;
        });

        const links = payload.d3.connections.map(c => ({
          source: c.sourceId,
          target: c.targetId
        })).filter(l => nodes.some(n => n.id === l.source) && nodes.some(n => n.id === l.target));

        const svg = d3.select("#canvas").append("svg")
          .attr("width", width)
          .attr("height", height);

        const svgGroup = svg.append("g");

        const zoom = d3.zoom()
          .scaleExtent([0.3, 8])
          .on("zoom", (event) => {
            svgGroup.attr("transform", event.transform);
          });

        svg.call(zoom);

        const simulation = d3.forceSimulation(nodes)
          .force("link", d3.forceLink(links).id(d => d.id).distance(90))
          .force("charge", d3.forceManyBody().strength(-250))
          .force("center", d3.forceCenter(width / 2, height / 2));

        const link = svgGroup.selectAll(".link")
          .data(links)
          .enter().append("line")
          .style("stroke", isLight ? "rgba(15, 23, 42, 0.08)" : "rgba(255,255,255,0.06)")
          .style("stroke-width", "1px");

        const node = svgGroup.selectAll(".node")
          .data(nodes)
          .enter().append("g")
          .call(d3.drag()
            .on("start", (event, d) => {
              if (!event.active) simulation.alphaTarget(0.3).restart();
              d.fx = d.x;
              d.fy = d.y;
            })
            .on("drag", (event, d) => {
              d.fx = event.x;
              d.fy = event.y;
            })
            .on("end", (event, d) => {
              if (!event.active) simulation.alphaTarget(0);
              d.fx = null;
              d.fy = null;
            }));

        const colors = ["#3b82f6", "#10b981", "#f59e0b"]; // blue, green, yellow
        
        node.append("circle")
          .attr("r", d => d.size * 6 + 4)
          .style("fill", d => colors[d.group])
          .style("stroke", isLight ? "#ffffff" : "#030712")
          .style("stroke-width", "1.5px");

        node.append("text")
          .attr("dx", d => d.size * 6 + 8)
          .attr("dy", ".35em")
          .text(d => d.name)
          .style("fill", isLight ? "#334155" : "#9ca3af")
          .style("font-size", "9px")
          .style("font-family", "Outfit, Inter, sans-serif")
          .style("font-weight", "500")
          .style("pointer-events", "none");

        node.on("dblclick", (event, d) => {
          if (d.id.startsWith('/posts/') || d.id.startsWith('/publications/')) {
            window.location.href = d.id;
          }
        });

        simulation.on("tick", () => {
          link.attr("x1", d => d.source.x)
              .attr("y1", d => d.source.y)
              .attr("x2", d => d.target.x)
              .attr("y2", d => d.target.y);

          node.attr("transform", d => `translate(${d.x},${d.y})`);
        });

        return {
          destroy: () => {
            simulation.stop();
          }
        };
      }

      function initSigma(Sigma, Graph, forceAtlas2) {
        const isLight = document.documentElement.classList.contains('light');
        const graph = new Graph();
        
        const nodes = payload.sigma.nodes;
        const edges = payload.sigma.edges;

        nodes.forEach(n => {
          graph.addNode(n.id, {
            label: n.label,
            x: n.x,
            y: n.y,
            size: n.size * 3 + 2,
            color: n.color
          });
        });

        edges.forEach(e => {
          graph.addEdge(e.source, e.target, {
            size: 1,
            color: isLight ? 'rgba(15, 23, 42, 0.08)' : 'rgba(255, 255, 255, 0.08)'
          });
        });

        forceAtlas2.assign(graph, {
          iterations: 100,
          settings: {
            gravity: 1
          }
        });

        const s = new Sigma(graph, container, {
          defaultNodeColor: '#3b82f6',
          defaultEdgeColor: isLight ? 'rgba(15, 23, 42, 0.08)' : 'rgba(255, 255, 255, 0.08)',
          labelColor: { color: isLight ? '#0f172a' : '#f3f4f6' },
          labelFont: 'Outfit, Inter, sans-serif',
          labelSize: 10
        });

        s.on('clickNode', ({ node }) => {
          if (node.startsWith('/posts/') || node.startsWith('/publications/')) {
            window.location.href = node;
          }
        });

        return {
          kill: () => {
            s.kill();
          }
        };
      }

      function init3DForce(ForceGraph3D) {
        const isLight = document.documentElement.classList.contains('light');
        const nodes = payload['3d-force'].nodes;
        const connections = payload['3d-force'].connections;
        const colors = ["#3b82f6", "#10b981", "#f59e0b"]; // blue, green, yellow
        
        const gData = {
          nodes: nodes.map(n => ({
            id: n.id,
            name: n.name,
            val: n.size * 5 + 3,
            color: colors[n.group]
          })),
          links: connections.map(c => ({
            source: c.sourceId,
            target: c.targetId
          }))
        };

        const Graph = ForceGraph3D()(container)
          .graphData(gData)
          .backgroundColor(isLight ? '#f8fafc' : '#090d16')
          .showNavInfo(false)
          .nodeLabel('name')
          .nodeVal('val')
          .nodeColor('color')
          .linkColor(isLight ? () => 'rgba(15, 23, 42, 0.15)' : () => 'rgba(255,255,255,0.08)')
          .linkWidth(1.2)
          .linkDirectionalParticles(2)
          .linkDirectionalParticleWidth(1.5)
          .linkDirectionalParticleSpeed(0.006)
          .onNodeClick(node => {
            if (node.id.startsWith('/posts/') || node.id.startsWith('/publications/')) {
              window.location.href = node.id;
            }
          });

        Graph.d3Force('charge').strength(-120);

        const resizeObserver = new ResizeObserver(entries => {
          for (let entry of entries) {
            const { width, height } = entry.contentRect;
            Graph.width(width).height(height);
          }
        });
        resizeObserver.observe(container);

        return {
          destroy: () => {
            resizeObserver.disconnect();
            if (Graph) {
              Graph.pauseAnimation();
              Graph.graphData({ nodes: [], links: [] });
            }
          }
        };
      }

      function initVisNetwork(vis) {
        const isLight = document.documentElement.classList.contains('light');
        const nodes = payload['vis-network'].nodes;
        const connections = payload['vis-network'].connections;
        
        const colors = [
          { 
            background: '#3b82f6', 
            border: isLight ? '#2563eb' : '#60a5fa', 
            highlight: { background: '#2563eb', border: '#1d4ed8' } 
          },
          { 
            background: '#10b981', 
            border: isLight ? '#059669' : '#34d399', 
            highlight: { background: '#059669', border: '#047857' } 
          },
          { 
            background: '#f59e0b', 
            border: isLight ? '#d97706' : '#fbbf24', 
            highlight: { background: '#d97706', border: '#b45309' } 
          }
        ];

        const visNodes = new vis.DataSet(nodes.map(n => ({
          id: n.id,
          label: n.name,
          value: n.size * 6 + 4,
          color: colors[n.group],
          font: {
            color: isLight ? '#334155' : '#e2e8f0',
            size: 11,
            face: 'Outfit, Inter, sans-serif'
          }
        })));

        const visEdges = new vis.DataSet(connections.map(c => ({
          from: c.sourceId,
          to: c.targetId,
          color: {
            color: isLight ? 'rgba(15, 23, 42, 0.08)' : 'rgba(255,255,255,0.08)',
            highlight: isLight ? 'rgba(15, 23, 42, 0.25)' : 'rgba(255,255,255,0.25)'
          }
        })));

        const data = {
          nodes: visNodes,
          edges: visEdges
        };

        const options = {
          nodes: {
            shape: 'dot',
            scaling: {
              min: 8,
              max: 20
            },
            borderWidth: 1.5,
            borderWidthSelected: 3
          },
          edges: {
            width: 1,
            smooth: {
              type: 'continuous',
              forceDirection: 'none',
              roundness: 0.5
            }
          },
          physics: {
            solver: 'forceAtlas2Based',
            forceAtlas2Based: {
              gravitationalConstant: -50,
              centralGravity: 0.01,
              springLength: 80,
              springConstant: 0.08,
              damping: 0.4
            },
            stabilization: {
              iterations: 150,
              updateInterval: 25
            }
          },
          interaction: {
            hover: true,
            tooltipDelay: 200,
            zoomView: true,
            dragView: true
          }
        };

        const network = new vis.Network(container, data, options);

        network.on("click", function (params) {
          if (params.nodes.length > 0) {
            const id = params.nodes[0];
            if (id.startsWith('/posts/') || id.startsWith('/publications/')) {
              window.location.href = id;
            }
          }
        });

        return {
          destroy: () => {
            network.destroy();
          }
        };
      }
    });
  </script>
</Layout>

<style>
  /* Ensure canvas takes all available dimensions */
  #canvas {
    outline: none;
  }
</style>
