---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import { getCollection } from "astro:content";
import { getImage } from "astro:assets";

export async function getStaticPaths() {
  const visualizations = await getCollection("visualizations");
  return visualizations.map(vis => ({
    params: { slug: vis.id },
    props: { type: vis.id, title: vis.data.title, screenshot: vis.data.screenshot }
  }));
}

const { type, title, screenshot } = Astro.props;

const optimizedScreenshot = screenshot ? await getImage({
  src: screenshot,
  format: 'webp',
  width: 1200,
  quality: 85
}) : null;

const posts = await getCollection("posts");
const publications = await getCollection("publications");

// Calculate tags
const tagPosts: Record<string, number> = {};
posts.forEach(p => {
  p.data.tags.forEach(t => {
    tagPosts[t] = (tagPosts[t] || 0) + 1;
  });
});

const tagPubs: Record<string, number> = {};
publications.forEach(p => {
  p.data.tags.forEach(t => {
    tagPubs[t] = (tagPubs[t] || 0) + 1;
  });
});

const allTags = Array.from(new Set([...Object.keys(tagPosts), ...Object.keys(tagPubs)]));

// Prepare payload for Cytoscape
const cytoscapeElements = [];
allTags.forEach(tag => {
  const count = (tagPosts[tag] || 0) + (tagPubs[tag] || 0);
  cytoscapeElements.push({
    data: {
      id: tag,
      name: tag,
      color: "#3b82f6", // Blue
      size: (Math.log(count) + 1) * 15 + 10
    }
  });
});

posts.forEach(post => {
  const path = `/posts/${post.id}`;
  cytoscapeElements.push({
    data: {
      id: path,
      name: post.data.title,
      color: "#10b981", // Green
      size: 15
    }
  });
  post.data.tags.forEach(tag => {
    cytoscapeElements.push({
      data: {
        id: `${path}--${tag}`,
        source: path,
        target: tag
      }
    });
  });
});

publications.forEach(pub => {
  const path = `/publications/${pub.id}`;
  cytoscapeElements.push({
    data: {
      id: path,
      name: pub.data.title,
      color: "#f59e0b", // Yellow
      size: 15
    }
  });
  pub.data.tags.forEach(tag => {
    cytoscapeElements.push({
      data: {
        id: `${path}--${tag}`,
        source: path,
        target: tag
      }
    });
  });
});

// Prepare payload for D3
const d3Nodes = [];
const d3Connections = [];
allTags.forEach(tag => {
  const count = (tagPosts[tag] || 0) + (tagPubs[tag] || 0);
  d3Nodes.push({ id: tag, name: tag, size: Math.log(count) + 1, group: 0 });
});
posts.forEach(post => {
  const path = `/posts/${post.id}`;
  d3Nodes.push({ id: path, name: post.data.title, size: 1, group: 1 });
  post.data.tags.forEach(tag => {
    d3Connections.push({ sourceId: path, targetId: tag });
  });
});
publications.forEach(pub => {
  const path = `/publications/${pub.id}`;
  d3Nodes.push({ id: path, name: pub.data.title, size: 1, group: 2 });
  pub.data.tags.forEach(tag => {
    d3Connections.push({ sourceId: path, targetId: tag });
  });
});

// Prepare payload for Sigma
const sigmaNodes = [];
const sigmaEdges = [];
allTags.forEach(tag => {
  const count = (tagPosts[tag] || 0) + (tagPubs[tag] || 0);
  sigmaNodes.push({
    id: tag,
    label: tag,
    x: Math.random(),
    y: Math.random(),
    size: Math.log(count) + 1,
    color: "#3b82f6"
  });
});
posts.forEach(post => {
  const path = `/posts/${post.id}`;
  sigmaNodes.push({
    id: path,
    label: post.data.title,
    x: Math.random(),
    y: Math.random(),
    size: 1,
    color: "#10b981"
  });
  post.data.tags.forEach(tag => {
    sigmaEdges.push({
      id: `${path}--${tag}`,
      source: path,
      target: tag,
      size: 1,
      color: "rgba(255,255,255,0.07)"
    });
  });
});
publications.forEach(pub => {
  const path = `/publications/${pub.id}`;
  sigmaNodes.push({
    id: path,
    label: pub.data.title,
    x: Math.random(),
    y: Math.random(),
    size: 1,
    color: "#f59e0b"
  });
  pub.data.tags.forEach(tag => {
    sigmaEdges.push({
      id: `${path}--${tag}`,
      source: path,
      target: tag,
      size: 1,
      color: "rgba(255,255,255,0.07)"
    });
  });
});

const payload = {
  cytoscape: { elements: cytoscapeElements },
  d3: { nodes: d3Nodes, connections: d3Connections },
  sigma: { nodes: sigmaNodes, edges: sigmaEdges },
  "3d-force": { nodes: d3Nodes, connections: d3Connections },
  "vis-network": { nodes: d3Nodes, connections: d3Connections }
};

---

<Layout 
  title={`${title} Graph Visualization | Dr. Georg Hackenberg`} 
  description={`An interactive network diagram mapping the connections between blog posts, academic publications, and tags on Dr. Georg Hackenberg's website using ${title}.`}
  image={optimizedScreenshot?.src}
>
  <Navbar />

  <main class="flex-grow max-w-6xl mx-auto px-4 md:px-8 py-12 md:py-16 w-full relative z-10 flex flex-col h-[calc(100vh-80px)]">
    <!-- Back Button -->
    <a 
      href="/visualizations" 
      class="inline-flex items-center space-x-2 text-xs font-semibold px-4 py-2 rounded-xl bg-brand-green/10 border border-brand-green/20 hover:border-brand-green/30 text-brand-green transition-all mb-8 cursor-pointer self-start"
    >
      <span>&larr;</span>
      <span>Back to Visualizations</span>
    </a>

    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6 shrink-0">
      <div>
        <h1 class="text-2xl md:text-3xl font-extrabold text-white tracking-tight flex items-center gap-3">
          {title}
          <span class="text-xs px-2.5 py-0.5 rounded-full bg-white/5 border border-white/10 text-gray-400 font-semibold tracking-wide uppercase">
            Interactive
          </span>
        </h1>
      </div>

      <!-- Engine Selector Tabs -->
      <div class="flex flex-wrap gap-1 bg-white/5 border border-white/5 p-1 rounded-xl self-start sm:self-auto">
        <a 
          href="/visualizations/cytoscape" 
          class={`px-4 py-2 rounded-lg text-xs font-bold transition-all ${type === 'cytoscape' ? 'bg-brand-green text-gray-950 shadow-md' : 'text-gray-400 hover:text-white'}`}
        >
          Cytoscape
        </a>
        <a 
          href="/visualizations/d3" 
          class={`px-4 py-2 rounded-lg text-xs font-bold transition-all ${type === 'd3' ? 'bg-brand-green text-gray-950 shadow-md' : 'text-gray-400 hover:text-white'}`}
        >
          D3
        </a>
        <a 
          href="/visualizations/sigma" 
          class={`px-4 py-2 rounded-lg text-xs font-bold transition-all ${type === 'sigma' ? 'bg-brand-green text-gray-950 shadow-md' : 'text-gray-400 hover:text-white'}`}
        >
          Sigma
        </a>
        <a 
          href="/visualizations/3d-force" 
          class={`px-4 py-2 rounded-lg text-xs font-bold transition-all ${type === '3d-force' ? 'bg-brand-green text-gray-950 shadow-md' : 'text-gray-400 hover:text-white'}`}
        >
          3D Force
        </a>
        <a 
          href="/visualizations/vis-network" 
          class={`px-4 py-2 rounded-lg text-xs font-bold transition-all ${type === 'vis-network' ? 'bg-brand-green text-gray-950 shadow-md' : 'text-gray-400 hover:text-white'}`}
        >
          Vis.js
        </a>
      </div>
    </div>

    <!-- Graph Panel Area -->
    <div class="flex-grow w-full relative min-h-[450px] rounded-3xl border border-white/5 bg-gray-950/60 backdrop-blur-md overflow-hidden flex flex-col md:flex-row shadow-2xl">
      <!-- Sidebar Legend & Control -->
      <div class="w-full md:w-64 border-b md:border-b-0 md:border-r border-white/5 p-5 shrink-0 bg-gray-950/40 relative z-20 flex flex-col justify-between">
        <div class="space-y-6">
          <div>
            <h2 class="text-xs font-bold text-gray-500 uppercase tracking-widest mb-3">Graph Legend</h2>
            <div class="space-y-2.5">
              <div class="flex items-center space-x-3 text-xs">
                <span class="w-3.5 h-3.5 rounded-full bg-brand-blue border border-white/20 shadow-lg shadow-brand-blue/20"></span>
                <span class="text-gray-300 font-medium">Topic Tags (blue)</span>
              </div>
              <div class="flex items-center space-x-3 text-xs">
                <span class="w-3.5 h-3.5 rounded-full bg-brand-green border border-white/20 shadow-lg shadow-brand-green/20"></span>
                <span class="text-gray-300 font-medium">Blog Posts (green)</span>
              </div>
              <div class="flex items-center space-x-3 text-xs">
                <span class="w-3.5 h-3.5 rounded-full bg-brand-yellow border border-white/20 shadow-lg shadow-brand-yellow/20"></span>
                <span class="text-gray-300 font-medium">Publications (yellow)</span>
              </div>
            </div>
          </div>

          <!-- Layout Selector Section -->
          <div class="border-t border-white/5 pt-4">
            <h2 class="text-xs font-bold text-gray-500 uppercase tracking-widest mb-2.5">Layout Mode</h2>
            <div class="relative">
              <select 
                id="layout-selector"
                class="w-full px-3 py-2 text-xs rounded-xl bg-white/5 border border-white/10 hover:border-white/20 text-gray-200 light:bg-slate-900/5 light:border-slate-900/10 light:hover:border-slate-900/20 light:text-slate-800 focus:outline-none focus:ring-1 focus:ring-brand-green/50 light:focus:ring-brand-green/30 cursor-pointer appearance-none"
              >
                <!-- Options will be populated dynamically by the engine -->
              </select>
              <div class="absolute inset-y-0 right-3 flex items-center pointer-events-none text-gray-400 light:text-slate-500">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
                </svg>
              </div>
            </div>
          </div>

          <div class="border-t border-white/5 pt-4">
            <h2 class="text-xs font-bold text-gray-500 uppercase tracking-widest mb-2.5">Interaction</h2>
            <ul class="space-y-1.5 text-xs text-gray-400 list-disc pl-4 font-normal leading-relaxed">
              <li>Drag nodes to rearrange them</li>
              <li>Pinch/scroll wheel to zoom</li>
              <li>Click / Double-click a post or publication node to navigate directly to it</li>
            </ul>
          </div>
        </div>

        <div class="pt-6 text-[10px] text-gray-500 font-medium">
          Built with {title} &amp; Astro.
        </div>
      </div>

      <!-- Graph Rendering Canvas -->
      <div id="canvas" class="flex-grow w-full h-full relative z-10">
        <!-- Render Loading Placeholder -->
        <div id="canvas-loading" class="absolute inset-0 flex items-center justify-center bg-gray-950/80 z-30 transition-opacity duration-300">
          <div class="flex flex-col items-center space-y-4">
            <div class="w-8 h-8 rounded-full border-2 border-brand-green/20 border-t-brand-green animate-spin"></div>
            <span class="text-xs text-gray-400 font-semibold uppercase tracking-wider">Loading Network Graph...</span>
          </div>
        </div>
      </div>
    </div>
  </main>

  <!-- Expose Astro variables to global scope for client script -->
  <script is:inline define:vars={{ type, payload }}>
    window.GRAPH_TYPE = type;
    window.GRAPH_PAYLOAD = payload;
  </script>

  <!-- Inject Graph Boot Scripts -->
  <script>
    const type = window.GRAPH_TYPE;
    const payload = window.GRAPH_PAYLOAD;

    window.addEventListener('DOMContentLoaded', () => {
      const container = document.getElementById('canvas');
      const loading = document.getElementById('canvas-loading');
      const selector = document.getElementById('layout-selector');
      if (!container) return;

      let activeInstance = null;

      async function runInit() {
        if (activeInstance) {
          if (typeof activeInstance.destroy === 'function') {
            activeInstance.destroy();
          }
          activeInstance = null;
        }
        container.innerHTML = '';

        try {
          let engineModule;
          switch (type) {
            case 'cytoscape':
              engineModule = await import('../../content/visualizations/cytoscape/engine.js');
              break;
            case 'd3':
              engineModule = await import('../../content/visualizations/d3/engine.js');
              break;
            case 'sigma':
              engineModule = await import('../../content/visualizations/sigma/engine.js');
              break;
            case '3d-force':
              engineModule = await import('../../content/visualizations/3d-force/engine.js');
              break;
            case 'vis-network':
              engineModule = await import('../../content/visualizations/vis-network/engine.js');
              break;
            default:
              throw new Error(`Unknown visualization type: ${type}`);
          }

          const engine = engineModule.default;
          
          // Determine layout from query parameters
          const params = new URLSearchParams(window.location.search);
          let currentLayout = params.get('layout');
          
          // Verify layout is supported by the engine, else fallback to default
          const supportsLayout = engine.layouts.some(l => l.id === currentLayout);
          if (!currentLayout || !supportsLayout) {
            currentLayout = engine.layouts[0].id;
          }

          // Populate the layout dropdown
          if (selector) {
            const isLightMode = document.documentElement.classList.contains('light');
            selector.innerHTML = '';
            engine.layouts.forEach(l => {
              const option = document.createElement('option');
              option.value = l.id;
              option.textContent = l.label;
              option.style.backgroundColor = isLightMode ? '#ffffff' : '#030712';
              option.style.color = isLightMode ? '#0f172a' : '#ffffff';
              selector.appendChild(option);
            });
            selector.value = currentLayout;
          }

          // Initialize engine
          const isLight = document.documentElement.classList.contains('light');
          activeInstance = await engine.init(container, payload, currentLayout, isLight);
          window.activeInstance = activeInstance;

        } catch (e) {
          console.error("Failed to load visualization: ", e);
        }
      }

      // Initialize on load
      setTimeout(async () => {
        await runInit();
        if (loading) {
          loading.style.opacity = '0';
          setTimeout(() => loading.remove(), 300);
        }
      }, 100);

      // Handle layout change
      if (selector) {
        selector.addEventListener('change', (e) => {
          const newLayout = e.target.value;
          if (activeInstance) {
            const url = new URL(window.location.href);
            url.searchParams.set('layout', newLayout);
            window.history.pushState({}, '', url.toString());
            
            const isLight = document.documentElement.classList.contains('light');
            activeInstance.updateLayout(newLayout, isLight);
          }
        });
      }

      // Handle theme change dynamically without reloading canvas
      window.addEventListener('theme-changed', () => {
        const isLight = document.documentElement.classList.contains('light');
        if (selector) {
          Array.from(selector.options).forEach(option => {
            option.style.backgroundColor = isLight ? '#ffffff' : '#030712';
            option.style.color = isLight ? '#0f172a' : '#ffffff';
          });
        }
        if (activeInstance) {
          const params = new URLSearchParams(window.location.search);
          const currentLayout = params.get('layout') || activeInstance.layouts[0].id;
          activeInstance.updateLayout(currentLayout, isLight);
        }
      });
    });
  </script>
</Layout>

<style>
  /* Ensure canvas takes all available dimensions */
  #canvas {
    outline: none;
  }
</style>
