      </div>
    </section>

  </main>

</Layout>

<style>
  /* Tab Buttons Base Styling */
  .feed-tab-btn {
    position: relative;
    overflow: hidden;
    background: rgba(31, 41, 55, 0.4);
    border-color: rgba(255, 255, 255, 0.05);
    color: #9ca3af; /* text-gray-400 */
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Tab Progress Bar Indicator */
  .tab-progress {
    position: absolute;
    bottom: 0;
    left: 0;
    height: 3px;
    width: 0;
    background-color: currentColor;
    opacity: 0.7;
    transition: none;
  }

  .feed-tab-btn.active.animating .tab-progress {
    animation: tab-progress-grow 8s linear forwards;
  }

  /* Pause progress bar animation on hover of the widget */
  .social-feed-widget:hover .feed-tab-btn.active.animating .tab-progress {
    animation-play-state: paused;
  }

  @keyframes tab-progress-grow {
    from {
      width: 0%;
    }
    to {
      width: 100%;
    }
  }

  /* GitHub Active */
  .feed-tab-btn[data-tab="github"].active {
    background: rgba(59, 130, 246, 0.1);
    border-color: rgba(59, 130, 246, 0.3);
    color: #3b82f6;
    box-shadow: 0 0 15px -3px rgba(59, 130, 246, 0.25);
  }
  .feed-tab-btn[data-tab="github"]:hover:not(.active) {
    border-color: rgba(59, 130, 246, 0.2);
    color: #60a5fa;
  }

  /* LinkedIn Active */
  .feed-tab-btn[data-tab="linkedin"].active {
    background: rgba(168, 85, 247, 0.1);
    border-color: rgba(168, 85, 247, 0.3);
    color: #a855f7;
    box-shadow: 0 0 15px -3px rgba(168, 85, 247, 0.25);
  }
  .feed-tab-btn[data-tab="linkedin"]:hover:not(.active) {
    border-color: rgba(168, 85, 247, 0.2);
    color: #c084fc;
  }

  /* YouTube Active */
  .feed-tab-btn[data-tab="youtube"].active {
    background: rgba(16, 185, 129, 0.1);
    border-color: rgba(16, 185, 129, 0.3);
    color: #10b981;
    box-shadow: 0 0 15px -3px rgba(16, 185, 129, 0.25);
  }
  .feed-tab-btn[data-tab="youtube"]:hover:not(.active) {
    border-color: rgba(16, 185, 129, 0.2);
    color: #34d399;
  }

  /* Feed Panels Slide Animations */
  .feed-panel {
    will-change: opacity, transform, translate, scale;
  }

  @keyframes slideInRight {
    from {
      opacity: 0;
      translate: 4rem 0;
      scale: 0.98;
    }
    to {
      opacity: 1;
      translate: 0 0;
      scale: 1;
    }
  }

  @keyframes slideOutLeft {
    from {
      opacity: 1;
      translate: 0 0;
      scale: 1;
    }
    to {
      opacity: 0;
      translate: -4rem 0;
      scale: 0.98;
    }
  }

  @keyframes slideInLeft {
    from {
      opacity: 0;
      translate: -4rem 0;
      scale: 0.98;
    }
    to {
      opacity: 1;
      translate: 0 0;
      scale: 1;
    }
  }

  @keyframes slideOutRight {
    from {
      opacity: 1;
      translate: 0 0;
      scale: 1;
    }
    to {
      opacity: 0;
      translate: 4rem 0;
      scale: 0.98;
    }
  }

  .panel-slide-in-right {
    animation: slideInRight 3.0s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .panel-slide-out-left {
    animation: slideOutLeft 3.0s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .panel-slide-in-left {
    animation: slideInLeft 3.0s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .panel-slide-out-right {
    animation: slideOutRight 3.0s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  /* Profile Photo SVG Image Styling */
  .profile-svg-image {
    transform-origin: 50px 45px;
    transition: transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .group:hover .profile-svg-image {
    transform: scale(1.04) translateY(-2px);
  }

  /* Fix WebKit/Safari rendering glitch for the blurred glow element on load */
  .hero-glow-fix {
    will-change: filter, transform, opacity;
    -webkit-backface-visibility: hidden;
    backface-visibility: hidden;
    transform: translate3d(0, 0, 0);
  }
</style>

<script>
  // Copy to Clipboard logic for contact button
  const copyBtn = document.getElementById('copy-email-btn');
  const emailText = document.getElementById('email-text');
  const copyBtnText = document.getElementById('copy-btn-text');
  const copyIcon = document.getElementById('copy-icon');

  if (copyBtn && emailText && copyBtnText && copyIcon) {
    copyBtn.addEventListener('click', () => {
      const email = emailText.textContent?.trim() || 'georg.hackenberg@fh-wels.at';
      
      navigator.clipboard.writeText(email).then(() => {
        // Visual feedback
        copyBtnText.textContent = 'Copied!';
        copyBtn.classList.remove('bg-white/5', 'text-gray-300', 'border-white/10');
        copyBtn.classList.add('bg-brand-green/20', 'text-brand-green', 'border-brand-green/30');
        
        // Reset after 2.5 seconds
        setTimeout(() => {
          copyBtnText.textContent = 'Copy Email';
          copyBtn.classList.remove('bg-brand-green/20', 'text-brand-green', 'border-brand-green/30');
          copyBtn.classList.add('bg-white/5', 'text-gray-300', 'border-white/10');
        }, 2500);
      }).catch(err => {
        console.error('Failed to copy text: ', err);
      });
    });
  }

  // Tab switching and auto-rotation logic for activity feeds
  const tabs = document.querySelectorAll('.feed-tab-btn');
  const panels = document.querySelectorAll('.feed-panel');

  const ROTATE_INTERVAL = 8000; // 8 seconds per tab
  const PAUSE_DURATION = 15000; // 15 seconds pause on manual select

  let resumeTimeout = null;
  let activeTabId = 'github'; // default active tab ID
  let rotationInitialized = false;
  let observerInstance = null;

  // Map of tab ID to tab button
  const tabMap = {};
  tabs.forEach(tab => {
    const tabId = tab.getAttribute('data-tab');
    if (tabId) tabMap[tabId] = tab;
  });

  // Ordered list of tab IDs for cycling
  const tabSequence = ['github', 'linkedin', 'youtube'];

  function switchTab(targetTabId, isManual = false) {
    if (activeTabId === targetTabId && !isManual) return;

    if (!rotationInitialized) {
      rotationInitialized = true;
      if (observerInstance) {
        observerInstance.disconnect();
        observerInstance = null;
      }
    }

    // 1. Clear any active progress animation
    tabs.forEach(t => t.classList.remove('active', 'animating'));

    // Get target tab element
    const targetTabEl = tabMap[targetTabId];
    if (!targetTabEl) return;

    // Add active class to target tab
    targetTabEl.classList.add('active');

    // Calculate transition direction (forward or backward)
    const currentIndex = tabSequence.indexOf(activeTabId);
    const targetIndex = tabSequence.indexOf(targetTabId);
    
    let isForward = true;
    if (currentIndex === 2 && targetIndex === 0) {
      isForward = true; // Wrap-around from last to first is forward
    } else if (currentIndex === 0 && targetIndex === 2) {
      isForward = false; // Wrap-around from first to last is backward
    } else {
      isForward = targetIndex > currentIndex;
    }

    const previousTabId = activeTabId;
    activeTabId = targetTabId;

    // Update panels using keyed slide animations (directional slide & cross-fade)
    panels.forEach(panel => {
      const panelId = panel.getAttribute('id');
      
      // Reset animation and interaction baseline classes
      panel.className = 'feed-panel col-start-1 row-start-1 transform-gpu';
      
      if (panelId === `panel-${targetTabId}`) {
        // Target active panel: animate in
        panel.classList.add(isForward ? 'panel-slide-in-right' : 'panel-slide-in-left');
        panel.classList.add('pointer-events-auto', 'z-10');
      } else if (panelId === `panel-${previousTabId}`) {
        // Previous active panel: animate out
        panel.classList.add(isForward ? 'panel-slide-out-left' : 'panel-slide-out-right');
        panel.classList.add('pointer-events-none', 'z-0');
      } else {
        // All other non-active panels: hide instantly
        panel.classList.add('opacity-0', 'pointer-events-none', 'z-0');
      }
    });

    if (isManual) {
      // User clicked manually -> pause auto rotation
      if (resumeTimeout) clearTimeout(resumeTimeout);

      // Start a timeout to resume auto rotation after 15 seconds
      resumeTimeout = setTimeout(() => {
        startProgress(targetTabEl);
      }, PAUSE_DURATION);
    } else {
      // Auto transition -> start progress bar animation immediately on the new tab
      startProgress(targetTabEl);
    }
  }

  function startProgress(tabEl) {
    // Stop any existing progress animations first
    tabs.forEach(t => {
      t.classList.remove('animating');
    });

    // Force layout reflow to ensure animation restarts
    void tabEl.offsetWidth;

    // Start progress bar animation on the current tab
    tabEl.classList.add('animating');
  }

  // Set up event listeners for manual clicks
  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const targetTabId = tab.getAttribute('data-tab');
      if (targetTabId) {
        switchTab(targetTabId, true);
      }
    });
  });

  // Set up progress bar animationend listeners to cycle to next tab
  tabs.forEach(tab => {
    const progressIndicator = tab.querySelector('.tab-progress');
    if (progressIndicator) {
      progressIndicator.addEventListener('animationend', () => {
        // Find next tab in sequence
        const currentIndex = tabSequence.indexOf(activeTabId);
        const nextIndex = (currentIndex + 1) % tabSequence.length;
        const nextTabId = tabSequence[nextIndex];

        switchTab(nextTabId, false);
      });
    }
  });

  // Initialize auto-rotation when the widget becomes visible on screen
  const widget = document.querySelector('.social-feed-widget');
  if (widget && 'IntersectionObserver' in window) {
    observerInstance = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting && !rotationInitialized) {
          rotationInitialized = true;
          const initialActiveTab = tabMap[activeTabId];
          if (initialActiveTab) {
            startProgress(initialActiveTab);
          }
          if (observerInstance) {
            observerInstance.disconnect();
            observerInstance = null;
          }
        }
      });
    }, { threshold: 0.15 });
    observerInstance.observe(widget);
  } else {
    // Fallback if IntersectionObserver is not supported or widget not found
    rotationInitialized = true;
    const initialActiveTab = tabMap[activeTabId];
    if (initialActiveTab) {
      startProgress(initialActiveTab);
    }
  }
</script>
