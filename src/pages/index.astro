  </section>

    <!-- Professional Interests Section -->
    <section id="about" class="py-16 md:py-24 border-t border-white/5 scroll-mt-20">
      <div class="mb-12">
        <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight text-gray-100 mb-4">
          Professional Interests
        </h2>
        <p class="text-gray-400 text-sm md:text-base max-w-2xl font-normal">
          Key scientific and technical domains defining my software developments, academic teaching, and current research interests.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {professionalInterests.map(interest => {
          const mapping = colorMappings[interest.color];
          return (
            <div class={`glass-card p-6 rounded-2xl border ${mapping.border} group flex flex-col h-full`}>
              <div class={`w-10 h-10 rounded-xl flex items-center justify-center mb-6 font-bold text-lg border ${mapping.bg}`}>
                {interest.icon}
              </div>
              <h3 class={`text-lg font-bold text-gray-100 mb-2 group-hover:text-brand-${interest.color} transition-colors`}>
