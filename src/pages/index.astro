---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import ProjectCard from "../components/ProjectCard.astro";
import Timeline from "../components/Timeline.astro";
import GitHubWidget from "../components/GitHubWidget.astro";
import LinkedInWidget from "../components/LinkedInWidget.astro";
import YouTubeWidget from "../components/YouTubeWidget.astro";
import { getImage } from "astro:assets";
import profileImage from "../assets/images/comic-profile.png";
import { getCollection } from "astro:content";

const optimizedProfile = await getImage({
  src: profileImage,
  format: "webp",
  width: 600,
  quality: 80
});

const projects = await getCollection("projects");
const sortedProjects = projects.sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));

const services = await getCollection("services");
const sortedServices = services.sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));

const colorMappings = {
  blue: {
    border: 'border-brand-blue/10 hover:border-brand-blue/30',
    backBorder: 'border-brand-blue/20 bg-brand-blue/5',
    text: 'text-brand-blue',
    bg: 'bg-brand-blue/10 text-brand-blue border-brand-blue/20',
    button: 'bg-brand-blue hover:bg-brand-blue/90 shadow-brand-blue/20 text-white',
    bullet: 'text-brand-blue',
  },
  yellow: {
    border: 'border-brand-yellow/10 hover:border-brand-yellow/30',
    backBorder: 'border-brand-yellow/20 bg-brand-yellow/5',
    text: 'text-brand-yellow',
    bg: 'bg-brand-yellow/10 text-brand-yellow border-brand-yellow/20',
    button: 'bg-brand-yellow hover:bg-brand-yellow/90 shadow-brand-yellow/20 text-gray-950 light:text-gray-50',
    bullet: 'text-brand-yellow',
  },
  purple: {
    border: 'border-brand-purple/10 hover:border-brand-purple/30',
    backBorder: 'border-brand-purple/20 bg-brand-purple/5',
    text: 'text-brand-purple',
    bg: 'bg-brand-purple/10 text-brand-purple border-brand-purple/20',
    button: 'bg-brand-purple hover:bg-brand-purple/90 shadow-brand-purple/20 text-white',
    bullet: 'text-brand-purple',
  },
  green: {
    border: 'border-brand-green/10 hover:border-brand-green/30',
    backBorder: 'border-brand-green/20 bg-brand-green/5',
    text: 'text-brand-green',
    bg: 'bg-brand-green/10 text-brand-green border-brand-green/20',
    button: 'bg-brand-green hover:bg-brand-green/90 shadow-brand-green/20 text-white',
    bullet: 'text-brand-green',
  }
};

const professionalInterests = [
  {
    icon: "💻",
    color: "blue" as const,
    title: "Software Engineering",
    tagline: "Architectures & Web Platforms",
    description: "Architecting high-performance web systems using Astro and TypeScript. Designing modular, type-safe, and highly scalable enterprise platforms."
  },
  {
    icon: "🎓",
    color: "yellow" as const,
    title: "Computer Simulation",
    tagline: "Systems & Layout Modeling",
    description: "Modeling manufacturing layouts, logistics workflows, and natural systems. Running discrete-event simulations and optimization algorithms."
  },
  {
    icon: "🎯",
    color: "purple" as const,
    title: "Artificial Intelligence",
    tagline: "Generative AI & Agent Systems",
    description: "Integrating Large Language Models locally in web applications. Developing autonomous AI agents, semantic search, and reasoning engines."
  },
  {
    icon: "🌐",
    color: "green" as const,
    title: "User Experience",
    tagline: "Visualizations & UI Designs",
    description: "Crafting premium, responsive user interfaces with smooth animations, custom layout dynamics, and interactive graph network visualizations."
  }
];
---

<Layout 
  title="Dr. Georg Hackenberg | Professor & Software Engineer" 
  description="Explore the portfolio, academic lectures, research publications, and computer science insights of Dr. Georg Hackenberg, Professor for Industrial Informatics."
  preloadImage={optimizedProfile.src}
>
  <!-- Navbar -->
  <Navbar />

  <!-- Main Content -->
  <main class="flex-grow max-w-6xl mx-auto px-4 md:px-8 py-12 md:py-20 w-full relative z-10">
    
    <!-- Hero Section -->
    <section id="home" class="flex flex-col justify-center pb-12 md:pb-20 pt-0 relative">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8 items-center w-full">
        
        <!-- Text Content -->
        <div class="lg:col-span-7 flex flex-col justify-center order-2 lg:order-1">
          <span class="inline-flex items-center text-xs font-semibold px-3 py-1 rounded-full bg-brand-blue/10 text-brand-blue border border-brand-blue/20 mb-6 tracking-wider uppercase self-start">
            Welcome to my profile
          </span>
          
          <h1 class="text-4xl sm:text-6xl md:text-7xl font-extrabold tracking-tight text-gray-100 mb-6 leading-tight">
            Hi, I am <br class="sm:hidden" />
            <span class="bg-clip-text text-transparent bg-gradient-to-r from-brand-blue via-brand-purple to-brand-yellow">
              Georg Hackenberg
            </span>
          </h1>
          
          <p class="text-xl sm:text-2xl font-bold text-gray-300 mb-8 leading-normal tracking-wide">
            Professor for Industrial Informatics &bull; Entrepreneur &bull; Software Engineer
          </p>
          
          <p class="text-gray-400 text-base sm:text-lg leading-relaxed mb-10 font-normal">
            I am a computer science professor, software engineer, and entrepreneur from Bavaria, Germany living in Upper Austria. On this page you can find details about my software projects, academic teaching, and core focuses. I am passionate about engineering modern software platforms, building rich knowledge graph architectures, and training the next generation of engineers.
          </p>
          
          <div class="flex flex-wrap gap-4">
            <a 
              href="#projects" 
              class="px-6 py-3.5 rounded-xl bg-brand-blue hover:bg-brand-blue/90 text-slate-950 font-bold shadow-lg shadow-brand-blue/20 hover:shadow-brand-blue/30 transition-all duration-300 hover:scale-105"
            >
              Explore Projects
            </a>
            <a 
              href="#contact" 
              class="px-6 py-3.5 rounded-xl bg-element-bg border border-element-border-medium hover:border-element-border-hover text-gray-300 hover:text-gray-100 font-semibold transition-all duration-300 hover:bg-element-bg-hover hover:scale-105"
            >
              Get in Touch
            </a>
          </div>
        </div>
        
        <!-- Profile Photo -->
        <div class="lg:col-span-5 flex justify-center lg:justify-end order-1 lg:order-2">
          <div class="relative w-64 h-64 min-[360px]:w-72 min-[360px]:h-72 sm:w-96 sm:h-96 lg:w-[440px] lg:h-[440px] xl:w-[480px] xl:h-[480px] group shrink-0">
            <!-- Large floating headshot inside SVG to avoid WebKit subpixel clipping artifacts -->
            <svg 
              viewBox="0 0 100 100" 
              class="w-full h-full select-none pointer-events-none relative z-10"
              role="img"
              aria-label="Dr. Georg Hackenberg - Profile Headshot"
            >
              <defs>
                <!-- SVG RadialGradient for soft bottom fadeout, keeping top head sharp -->
                <radialGradient id="fadeGradient" cx="50%" cy="30%" r="70%">
                  <stop offset="55%" stop-color="#fff" stop-opacity="1" />
                  <stop offset="95%" stop-color="#fff" stop-opacity="0" />
                </radialGradient>
                <!-- SVG Mask applying the gradient -->
                <mask id="fadeMask">
                  <rect x="0" y="0" width="100%" height="100%" fill="url(#fadeGradient)" />
                </mask>
              </defs>
              <!-- Group using mask for vignette blend without clipping boundaries -->
              <g>
                <!-- Image inside using mask for vignette blend -->
                <image
                  href={optimizedProfile.src}
                  x="0"
                  y="0"
                  width="100"
                  height="100"
                  preserveAspectRatio="xMidYMid slice"
                  mask="url(#fadeMask)"
                  class="profile-svg-image"
                />
              </g>
            </svg>
          </div>
        </div>
        
      </div>
    </section>

  <!-- Tech Stack Showcase Section -->
  <section class="py-12 border-t border-white/5 relative z-20">
    <div class="glass-panel rounded-3xl p-6 md:p-10 border border-white/5 relative overflow-hidden flex flex-col lg:flex-row items-center justify-between gap-8 bg-gradient-to-r from-white/[0.01] via-brand-blue/[0.02] to-brand-purple/[0.02]">
      <!-- Left Content -->
      <div class="flex-grow max-w-2xl text-center lg:text-left">
        <span class="inline-flex items-center text-[10px] font-bold tracking-widest text-brand-blue bg-brand-blue/10 border border-brand-blue/20 px-2.5 py-1 rounded-full uppercase mb-3">
          Site Architecture
        </span>
        <h2 class="text-2xl md:text-3xl font-extrabold text-gray-100 mb-3 tracking-tight">
          Built with Cutting-Edge Technologies
        </h2>
        <p class="text-gray-400 text-sm md:text-base leading-relaxed font-normal">
          This personal portfolio is engineered as a modern, high-performance web platform. Built using framework-agnostic compiler design, componentized styling systems, and agentic AI tooling to deliver optimized delivery speeds and visual quality.
        </p>
      </div>

      <!-- Right Content: Interactive Grayscale-to-Color Logos -->
      <div class="flex flex-wrap items-center justify-center gap-4 md:gap-6 shrink-0 w-full lg:w-auto">
        <!-- Astro Card -->
        <a 
          href="https://astro.build" 
          target="_blank" 
          rel="noopener noreferrer" 
          class="group flex flex-col items-center gap-3 px-5 py-4 w-32 rounded-2xl glass-card border border-white/5 hover:border-brand-blue/30 transition-all duration-300 hover:scale-105"
        >
