---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import { getCollection } from "astro:content";

const publications = (await getCollection("publications")).sort(
  (a, b) => b.id.localeCompare(a.id)
);

// Collect all unique tags for a tag cloud
const tags = Array.from(
  new Set(publications.flatMap((pub) => pub.data.tags || []))
).sort();

// Group by year
const groupedByYear: Record<string, typeof publications> = {};
publications.forEach((pub) => {
  const year = pub.id.substring(0, 4);
  if (!groupedByYear[year]) {
    groupedByYear[year] = [];
  }
  groupedByYear[year].push(pub);
});

const years = Object.keys(groupedByYear).sort((a, b) => b.localeCompare(a));

function getPublisherDomain(url: string | undefined): string {
  if (!url) return "";
  try {
    const parsed = new URL(url);
    let hostname = parsed.hostname;
    if (hostname.startsWith("www.")) {
      hostname = hostname.substring(4);
    }
    if (hostname === "doi.org") {
      const path = parsed.pathname;
      if (path.includes("10.1109")) return "ieeexplore.ieee.org";
      if (path.includes("10.1145") || path.includes("10.5555")) return "dl.acm.org";
      if (path.includes("10.1007")) return "link.springer.com";
      if (path.includes("10.1016")) return "sciencedirect.com";
      if (path.includes("10.1117")) return "spiedigitallibrary.org";
      if (path.includes("10.3139")) return "hanser-elibrary.com";
      if (path.includes("10.1515")) return "degruyter.com";
      if (path.includes("10.5220")) return "scitepress.org";
      if (path.includes("10.1017")) return "cambridge.org";
    }
    return hostname;
  } catch (e) {
    return "Publisher Page";
  }
}
---

<Layout title="Publications | Dr. Georg Hackenberg" description="Academic publications, conference papers, and research presentations by Dr. Georg Hackenberg.">
  <Navbar />

  <main class="flex-grow max-w-6xl mx-auto px-4 md:px-8 py-12 md:py-20 w-full relative z-10">
    <div class="mb-12">
      <span class="inline-flex items-center text-xs font-semibold px-3 py-1 rounded-full bg-brand-yellow/10 text-brand-yellow border border-brand-yellow/20 mb-6 tracking-wider uppercase">
        Academic Research
      </span>
      <h1 class="text-4xl md:text-6xl font-extrabold tracking-tight text-white mb-6">
        Peer-Reviewed <span class="bg-clip-text text-transparent bg-gradient-to-r from-brand-yellow via-brand-purple to-brand-blue">Publications</span>
      </h1>
      <p class="text-gray-400 text-base md:text-lg max-w-2xl font-normal leading-relaxed">
        A list of international conference papers, workshop reports, journals, and presentations focusing on gesture control, software engineering, and smart grids.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
      <!-- Tag Cloud -->
      <div class="lg:col-span-3 order-1 lg:order-2 lg:sticky lg:top-24">
        <div class="glass-card p-6 rounded-2xl border border-white/5 flex flex-col max-h-[300px] lg:max-h-[calc(100vh-10rem)]">
          <h3 class="text-lg font-bold text-white mb-4 flex items-center space-x-2 shrink-0">
            <span>🏷️</span>
            <span>Research Tags</span>
          </h3>
          <div class="mb-3 relative shrink-0">
            <input 
              type="text" 
              id="tag-search" 
              placeholder="Search tags..." 
              class="w-full bg-white/5 border border-white/10 rounded-lg px-3 py-1.5 pl-8 text-xs text-white placeholder-gray-500 focus:outline-none focus:border-brand-yellow/50 focus:ring-1 focus:ring-brand-yellow/50 transition-all duration-200"
            />
            <span class="absolute left-2.5 top-2 text-[10px] text-gray-500">🔍</span>
          </div>
          <div class="flex flex-wrap gap-2 overflow-y-auto pr-1 custom-scrollbar-thin flex-grow">
            {tags.map(tag => (
              <a 
                href={`/publications/tags/${tag}`}
                data-tag={tag}
                class="px-2.5 py-1 rounded-lg text-xs font-medium bg-white/5 border border-white/10 text-gray-400 hover:text-white hover:border-brand-yellow/30 transition-all duration-200"
              >
                #{tag}
              </a>
            ))}
            <p id="no-tags-message" class="text-xs text-gray-500 italic py-2 hidden w-full text-center">No matching tags</p>
          </div>
        </div>
      </div>

      <!-- Grouped Publications list -->
      <div class="lg:col-span-9 order-2 lg:order-1 space-y-12">
        {years.length === 0 ? (
          <p class="text-gray-500 font-medium py-12 text-center glass-card rounded-2xl">No publications found.</p>
        ) : (
          years.map(year => (
            <section class="space-y-4">
              <h2 class="text-2xl font-extrabold text-white border-b border-white/5 pb-2 tracking-tight">
                {year}
              </h2>
              <div class="space-y-4">
                {groupedByYear[year].map(pub => (
                  <div class="glass-card p-6 rounded-2xl border border-white/5 group flex flex-col md:flex-row gap-6 items-start relative cursor-pointer hover:border-brand-yellow/30">
                    <!-- Icon -->
                    <div class="w-12 h-12 md:w-16 md:h-16 rounded-xl overflow-hidden shrink-0 border border-white/10 bg-gray-900/50 flex items-center justify-center text-white/30 group-hover:text-brand-yellow/80 group-hover:border-brand-yellow/30 transition-all duration-300">
                      {pub.data.icon ? (
                        <img 
                          src={pub.data.icon} 
                          alt="" 
                          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                          loading="lazy"
                        />
                      ) : (
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 md:w-8 md:h-8">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
                        </svg>
                      )}
                    </div>

                    <!-- Details -->
                    <div class="flex-grow">
                      <h3 class="text-lg font-bold text-white mb-2 group-hover:text-brand-yellow transition-colors leading-snug">
                        <a href={`/publications/${pub.id}`} class="after:absolute after:inset-0 after:z-10">
                          {pub.data.title}
                        </a>
                      </h3>
                      
                      <p class="text-gray-300 text-sm mb-2 font-normal">
                        <span set:html={pub.data.author} />
                      </p>

                      <p class="text-gray-400 text-xs mb-4 font-normal italic">
                        {pub.data.book && <span>{pub.data.book}, </span>}
                        <span>{pub.data.pubDate}</span>
                      </p>

                      <div class="flex flex-wrap gap-2 items-center w-full">
                        {pub.data.tags.map(tag => (
                          <a 
                            href={`/publications/tags/${tag}`}
                            class="text-xs font-medium text-gray-500 hover:text-white transition-colors relative z-20"
                          >
                            #{tag}
                          </a>
                        ))}
                        <div class="ml-auto flex items-center space-x-4 relative z-20">
                          {pub.data.publisherUrl && (
                            <a 
                              href={pub.data.publisherUrl}
                              target="_blank"
                              rel="noopener noreferrer"
                              class="text-xs font-semibold text-brand-blue hover:text-brand-blue/85 flex items-center space-x-1"
                            >
                              <span>{getPublisherDomain(pub.data.publisherUrl)}</span>
                              <span>↗</span>
                            </a>
                          )}
                          <a 
                            href={`/publications/${pub.id}`} 
                            class="text-xs font-semibold text-brand-yellow hover:text-brand-yellow/85 flex items-center space-x-1"
                          >
                            <span>Abstract &amp; BibTeX</span>
                            <span>&rarr;</span>
                          </a>
                        </div>
                      </div>
                    </div>
                  </div>
                ))}
              </div>
            </section>
          ))
        )}
      </div>
    </div>
  </main>

  <script>
    const searchInput = document.getElementById('tag-search') as HTMLInputElement | null;
    const tagLinks = document.querySelectorAll('[data-tag]');
    const noTagsMessage = document.getElementById('no-tags-message');

    searchInput?.addEventListener('input', (e) => {
      const query = (e.target as HTMLInputElement).value.toLowerCase().trim();
      let visibleCount = 0;

      tagLinks.forEach(link => {
        const tag = link.getAttribute('data-tag')?.toLowerCase() || '';
        if (tag.includes(query)) {
          link.classList.remove('hidden');
          visibleCount++;
        } else {
          link.classList.add('hidden');
        }
      });

      if (noTagsMessage) {
        if (visibleCount === 0 && query !== '') {
          noTagsMessage.classList.remove('hidden');
        } else {
          noTagsMessage.classList.add('hidden');
        }
      }
    });
  </script>
</Layout>
