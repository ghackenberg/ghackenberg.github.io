---
import Layout from "../../../layouts/Layout.astro";
import Navbar from "../../../components/Navbar.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const pubs = await getCollection("publications");
  const uniqueTags = Array.from(
    new Set(pubs.flatMap((pub) => pub.data.tags || []))
  );
  
  return uniqueTags.map((tag) => {
    const filteredPubs = pubs
      .filter((pub) => pub.data.tags.includes(tag))
      .sort((a, b) => b.id.localeCompare(a.id));
    return {
      params: { tag },
      props: { pubs: filteredPubs, tag },
    };
  });
}

const { pubs, tag } = Astro.props;
---

<Layout title={`Publications tagged #${tag} | Dr. Georg Hackenberg`} description={`List of publications tagged with #${tag}`}>
  <Navbar />

  <main class="flex-grow max-w-4xl mx-auto px-4 md:px-8 py-12 md:py-20 w-full relative z-10">
    <a 
      href="/publications" 
      class="inline-flex items-center space-x-2 text-xs font-semibold px-4 py-2 rounded-xl bg-white/5 border border-white/10 hover:border-white/20 text-gray-300 hover:text-white transition-all mb-8"
    >
      <span>&larr;</span>
      <span>All Publications</span>
    </a>

    <div class="mb-12">
      <span class="inline-flex items-center text-xs font-semibold px-3 py-1 rounded-full bg-brand-yellow/10 text-brand-yellow border border-brand-yellow/20 mb-6 tracking-wider uppercase">
        Tag Filter
      </span>
      <h1 class="text-3xl md:text-5xl font-extrabold tracking-tight text-white mb-6">
        Publications tagged <span class="bg-clip-text text-transparent bg-gradient-to-r from-brand-yellow to-brand-purple">#{tag}</span>
      </h1>
    </div>

    <!-- Publications List -->
    <div class="space-y-6">
      {pubs.map(pub => (
        <div class="glass-card p-6 rounded-2xl border border-white/5 group flex flex-col md:flex-row gap-6 items-start">
          <div class="w-12 h-12 md:w-16 md:h-16 rounded-xl overflow-hidden shrink-0 border border-white/10 bg-gray-900/50 flex items-center justify-center text-white/30 group-hover:text-brand-yellow/80 group-hover:border-brand-yellow/30 transition-all duration-300">
            {pub.data.icon ? (
              <img 
                src={pub.data.icon} 
                alt="" 
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                loading="lazy"
              />
            ) : (
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 md:w-8 md:h-8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
              </svg>
            )}
          </div>
          
          <div class="flex-grow">
            <span class="text-[10px] font-semibold text-brand-yellow/80 block mb-2">
              {pub.id.substring(0, 4)}
            </span>
            
            <h2 class="text-lg font-bold text-white mb-2 group-hover:text-brand-yellow transition-colors leading-snug">
              <a href={`/publications/${pub.id}`}>
                {pub.data.title}
              </a>
            </h2>
            
            <p class="text-gray-300 text-sm mb-2 font-normal">
              <span set:html={pub.data.author} />
            </p>

            <p class="text-gray-400 text-xs mb-4 font-normal italic">
              {pub.data.book && <span>{pub.data.book}, </span>}
              <span>{pub.data.pubDate}</span>
            </p>

            <div class="flex flex-wrap gap-2 items-center">
              {pub.data.tags.map(t => (
                <a 
                  href={`/publications/tags/${t}`}
                  class={`text-xs font-medium ${t === tag ? 'text-brand-yellow' : 'text-gray-500 hover:text-white'} transition-colors`}
                >
                  #{t}
                </a>
              ))}
              <a 
                href={`/publications/${pub.id}`} 
                class="text-xs font-semibold text-brand-yellow hover:text-brand-yellow/85 ml-auto flex items-center space-x-1"
              >
                <span>Abstract &amp; Citation</span>
                <span>&rarr;</span>
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </main>
</Layout>
