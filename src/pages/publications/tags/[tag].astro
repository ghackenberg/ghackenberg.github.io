---
import Layout from "../../../layouts/Layout.astro";
import Navbar from "../../../components/Navbar.astro";
import { getCollection } from "astro:content";
import PublicationCard from "../../../components/PublicationCard.astro";

export async function getStaticPaths() {
  const pubs = await getCollection("publications");
  const uniqueTags = Array.from(
    new Set(pubs.flatMap((pub) => pub.data.tags || []))
  );
  
  return uniqueTags.map((tag) => {
    const filteredPubs = pubs
      .filter((pub) => pub.data.tags.includes(tag))
      .sort((a, b) => b.id.localeCompare(a.id));
    return {
      params: { tag },
      props: { pubs: filteredPubs },
    };
  });
}

const { pubs } = Astro.props;
const { tag } = Astro.params;


---

<Layout 
  title={`Research Publications on #${tag} | Dr. Georg Hackenberg`} 
  description={`Explore peer-reviewed research papers and presentations by Dr. Georg Hackenberg tagged with the topic #${tag}.`}
>
  <Navbar />

  <main class="flex-grow max-w-4xl mx-auto px-4 md:px-8 py-12 md:py-20 w-full relative z-10">
    <a 
      href="/publications" 
      class="inline-flex items-center space-x-2 text-xs font-semibold px-4 py-2 rounded-xl bg-white/5 border border-white/10 hover:border-white/20 text-gray-300 hover:text-white transition-all mb-8"
    >
      <span>&larr;</span>
      <span>All Publications</span>
    </a>

    <div class="mb-12">
      <span class="inline-flex items-center text-xs font-semibold px-3 py-1 rounded-full bg-brand-purple/10 text-brand-purple border border-brand-purple/20 mb-6 tracking-wider uppercase">
        Tag Filter
      </span>
      <h1 class="text-3xl md:text-5xl font-extrabold tracking-tight text-white mb-6">
        Publications tagged <span class="bg-clip-text text-transparent bg-gradient-to-r from-brand-purple to-purple-400 light:to-purple-700">#{tag}</span>
      </h1>
    </div>

    <div class="space-y-6">
      {pubs.map(pub => (
        <PublicationCard
          id={pub.id}
          title={pub.data.title}
          author={pub.data.author}
          pubDate={pub.data.pubDate}
          book={pub.data.book}
          tags={pub.data.tags}
          icon={pub.data.icon}
          publisherUrl={pub.data.publisherUrl}
          activeTag={tag}
          linkLabel="Abstract & Citation"
        />
      ))}
    </div>
  </main>
</Layout>
