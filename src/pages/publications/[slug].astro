---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const pubs = await getCollection("publications");
  return pubs.map((pub) => ({
    params: { slug: pub.id },
    props: { pub },
  }));
}

const { pub } = Astro.props;
const { Content } = await render(pub);

// Get related publications
const allPubs = await getCollection("publications");
const relatedPubs = allPubs
  .filter((p) => p.id !== pub.id)
  .map((p) => {
    const commonTags = p.data.tags.filter((t) => pub.data.tags.includes(t)).length;
    return { pub: p, commonTags };
  })
  .sort((a, b) => b.commonTags - a.commonTags || b.pub.id.localeCompare(a.pub.id))
  .slice(0, 3)
  .map((x) => x.pub);

// Format slides URL
let slidesUrl = pub.data.slides;
if (slidesUrl && slidesUrl.startsWith("//")) {
  slidesUrl = "https:" + slidesUrl;
}

function getPublisherDomain(url: string | undefined): string {
  if (!url) return "";
  try {
    const parsed = new URL(url);
    let hostname = parsed.hostname;
    if (hostname.startsWith("www.")) {
      hostname = hostname.substring(4);
    }
    if (hostname === "doi.org") {
      const path = parsed.pathname;
      if (path.includes("10.1109")) return "ieeexplore.ieee.org";
      if (path.includes("10.1145") || path.includes("10.5555")) return "dl.acm.org";
      if (path.includes("10.1007")) return "link.springer.com";
      if (path.includes("10.1016")) return "sciencedirect.com";
      if (path.includes("10.1117")) return "spiedigitallibrary.org";
      if (path.includes("10.3139")) return "hanser-elibrary.com";
      if (path.includes("10.1515")) return "degruyter.com";
      if (path.includes("10.5220")) return "scitepress.org";
      if (path.includes("10.1017")) return "cambridge.org";
    }
    return hostname;
  } catch (e) {
    return "Publisher Page";
  }
}

const cleanAbstract = pub.data.abstract 
  ? pub.data.abstract.replace(/\s+/g, " ").trim()
  : "";
const seoDescription = cleanAbstract.length > 156 
  ? `${cleanAbstract.substring(0, 153)}...` 
  : cleanAbstract || `Academic research publication by Dr. Georg Hackenberg: "${pub.data.title}"`;
---

<Layout 
  title={`${pub.data.title} | Research Publications | Dr. Georg Hackenberg`} 
  description={seoDescription}
  type="article"
  pubDate={pub.data.pubDate}
  tags={pub.data.tags}
>
  <Navbar />

  <main class="flex-grow max-w-4xl mx-auto px-4 md:px-8 py-12 md:py-20 w-full relative z-10">
    <!-- Back Button -->
    <a 
      href="/publications" 
      class="inline-flex items-center space-x-2 text-xs font-semibold px-4 py-2 rounded-xl bg-brand-purple/10 border border-brand-purple/20 hover:border-brand-purple/30 text-brand-purple transition-all mb-8 cursor-pointer"
    >
      <span>&larr;</span>
      <span>Back to Publications</span>
    </a>

    <!-- Publication Header -->
    <header class="mb-10 pb-8 border-b border-element-border">
      <h1 class="text-3xl sm:text-4xl md:text-5xl font-extrabold tracking-tight text-gray-100 mb-6 leading-tight">
        {pub.data.title}
      </h1>

      <p class="text-gray-300 text-base md:text-lg mb-4 font-normal">
        <span set:html={pub.data.author} />
      </p>

      <p class="text-gray-400 text-sm mb-6 font-normal italic">
        {pub.data.book && <span>{pub.data.book}, </span>}
        <span>{pub.data.pubDate}</span>
      </p>

      <div class="flex flex-wrap gap-2 items-center">
        {pub.data.tags.map(tag => (
          <a 
            href={`/publications/tags/${tag}`}
            class="px-2.5 py-1 rounded-lg text-xs font-medium bg-element-bg border border-element-border-medium text-gray-400 hover:text-gray-100 hover:border-brand-purple/30 transition-all duration-200"
          >
            #{tag}
          </a>
        ))}
        {pub.data.publisherUrl && (
          <a 
            href={pub.data.publisherUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="ml-auto px-3 py-1.5 rounded-xl text-xs font-semibold bg-brand-purple/10 border border-brand-purple/20 text-brand-purple hover:bg-brand-purple/20 transition-all duration-200 flex items-center space-x-1"
          >
            <span>{getPublisherDomain(pub.data.publisherUrl)}</span>
            <span>↗</span>
          </a>
        )}
      </div>
    </header>

    <!-- Content Sections -->
    <div class="space-y-12 mb-16">
      
      <!-- Abstract -->
      {pub.data.abstract && (
        <section class="glass-card p-6 md:p-10 rounded-3xl border border-element-border relative overflow-hidden">
          <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-brand-purple to-pink-500 light:to-pink-600"></div>
          
          <h2 class="text-2xl font-bold text-gray-100 mb-6 tracking-tight">
            Abstract
          </h2>
          <p class="text-gray-300 text-base leading-relaxed font-normal">
            {pub.data.abstract}
          </p>
        </section>
      )}

      <!-- Embedded Slides -->
      {slidesUrl && (
        <section class="glass-card p-6 md:p-8 rounded-3xl border border-element-border">
          <h2 class="text-2xl font-bold text-gray-100 mb-6 tracking-tight">
            Presentation Slides
          </h2>
          <div class="relative w-full aspect-video rounded-xl overflow-hidden border border-element-border-medium bg-black">
            <iframe 
              src={slidesUrl} 
              frameborder="0" 
              marginwidth="0" 
              marginheight="0" 
              scrolling="no" 
              allowfullscreen="yes" 
              class="absolute top-0 left-0 w-full h-full"
            >
              Loading presentation...
            </iframe>
          </div>
        </section>
      )}

      <!-- BibTeX Citation -->
      {pub.data.bibtex && (
        <section class="glass-card p-6 md:p-8 rounded-3xl border border-element-border relative">
          <div class="flex items-center justify-between mb-6">
            <h2 class="text-2xl font-bold text-gray-100 tracking-tight">
              BibTeX Citation
            </h2>
            
            <button 
              id="copy-bibtex-btn"
              class="px-4 py-2 text-xs font-semibold rounded-lg bg-element-bg hover:bg-element-bg-hover text-gray-300 hover:text-gray-100 border border-element-border-medium hover:border-element-border-hover transition-all duration-200 flex items-center space-x-2"
            >
              <svg id="copy-icon" class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"></path>
              </svg>
              <span id="copy-btn-text">Copy Citation</span>
            </button>
          </div>
          
          <pre id="bibtex-content" class="bg-gray-950/80 p-5 rounded-xl border border-element-border text-gray-300 font-mono text-xs overflow-x-auto leading-relaxed select-all">{pub.data.bibtex}</pre>
        </section>
      )}

    </div>

    <!-- Related Publications -->
    {relatedPubs.length > 0 && (
      <section class="border-t border-element-border pt-16">
        <h2 class="text-2xl font-bold text-gray-100 mb-8 tracking-tight">
          You might also be interested in
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {relatedPubs.map(p => (
            <a href={`/publications/${p.id}`} class="glass-card p-5 rounded-2xl border border-element-border group flex flex-col h-full justify-between">
              <div>
                <span class="text-[10px] font-semibold text-brand-purple/80 block mb-2">
                  {p.id.substring(0, 4)}
                </span>
                <h3 class="text-sm font-bold text-gray-100 group-hover:text-brand-purple transition-colors line-clamp-3 mb-2 leading-snug">
                  {p.data.title}
                </h3>
              </div>
              <span class="text-xs font-semibold text-brand-purple/80 mt-4 flex items-center space-x-1 group-hover:translate-x-1 transition-transform">
                <span>View publication</span>
                <span>&rarr;</span>
              </span>
            </a>
          ))}
        </div>
      </section>
    )}
  </main>
</Layout>

<script>
  // Copy Bibtex logic
  const copyBtn = document.getElementById('copy-bibtex-btn');
  const bibtexContent = document.getElementById('bibtex-content');
  const copyBtnText = document.getElementById('copy-btn-text');

  if (copyBtn && bibtexContent && copyBtnText) {
    copyBtn.addEventListener('click', () => {
      const text = bibtexContent.textContent?.trim() || '';
      navigator.clipboard.writeText(text).then(() => {
        // Visual feedback
        copyBtnText.textContent = 'Copied!';
        copyBtn.classList.remove('bg-element-bg', 'text-gray-300', 'border-element-border-medium');
        copyBtn.classList.add('bg-brand-green/20', 'text-brand-green', 'border-brand-green/30');
        
        // Reset after 2.5 seconds
        setTimeout(() => {
          copyBtnText.textContent = 'Copy Citation';
          copyBtn.classList.remove('bg-brand-green/20', 'text-brand-green', 'border-brand-green/30');
          copyBtn.classList.add('bg-element-bg', 'text-gray-300', 'border-element-border-medium');
        }, 2500);
      }).catch(err => {
        console.error('Failed to copy citation: ', err);
      });
    });
  }
</script>
