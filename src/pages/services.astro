---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import { getCollection } from "astro:content";
import { Image, getImage } from "astro:assets";

const services = await getCollection("services");
const sortedServices = services.sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));
const modules = await getCollection("modules");

const optimizedServices = await Promise.all(
  sortedServices.map(async (service) => {
    let optimizedImageSrc = undefined;

    if (service.data.previewImage) {
      const optimized = await getImage({
        src: service.data.previewImage,
        format: "webp",
        width: 800,
        quality: 80
      });
      optimizedImageSrc = optimized.src;
    }

    return {
      ...service,
      optimizedImageSrc
    };
  })
);

const colorClasses = {
  blue: {
    text: 'text-brand-blue light:text-blue-700',
    border: 'border-brand-blue/20 light:border-blue-200',
    hoverBorder: 'hover:border-brand-blue/40 light:hover:border-blue-300',
    bg: 'bg-brand-blue/10 text-brand-blue border-brand-blue/20 light:bg-blue-50/50 light:text-blue-700 light:border-blue-200',
    btnBg: 'bg-brand-blue hover:bg-brand-blue/90 shadow-brand-blue/20 hover:shadow-brand-blue/30 text-gray-950 font-bold light:bg-blue-600 light:hover:bg-blue-700 light:text-white',
    glow: 'from-brand-blue to-indigo-500 light:to-indigo-600',
    hoverText: 'group-hover:text-brand-blue light:group-hover:text-blue-600',
    dot: 'bg-brand-blue shadow-[0_0_8px_rgba(59,130,246,0.8)] light:shadow-[0_0_4px_rgba(29,78,216,0.4)]'
  },
  yellow: {
    text: 'text-brand-yellow light:text-amber-800',
    border: 'border-brand-yellow/20 light:border-amber-200',
    hoverBorder: 'hover:border-brand-yellow/40 light:hover:border-amber-300',
    bg: 'bg-brand-yellow/10 text-brand-yellow border-brand-yellow/20 light:bg-amber-50/50 light:text-amber-800 light:border-amber-200',
    btnBg: 'bg-brand-yellow hover:bg-brand-yellow/90 shadow-brand-yellow/20 hover:shadow-brand-yellow/30 text-gray-950 font-bold light:bg-amber-600 light:hover:bg-amber-700 light:text-white',
    glow: 'from-brand-yellow to-orange-500 light:to-orange-600',
    hoverText: 'group-hover:text-brand-yellow light:group-hover:text-amber-700',
    dot: 'bg-brand-yellow shadow-[0_0_8px_rgba(245,158,11,0.8)] light:shadow-[0_0_4px_rgba(180,83,9,0.4)]'
  },
  purple: {
    text: 'text-brand-purple light:text-purple-700',
    border: 'border-brand-purple/20 light:border-purple-200',
    hoverBorder: 'hover:border-brand-purple/40 light:hover:border-purple-300',
    bg: 'bg-brand-purple/10 text-brand-purple border-brand-purple/20 light:bg-purple-50/50 light:text-purple-700 light:border-purple-200',
    btnBg: 'bg-brand-purple hover:bg-brand-purple/90 shadow-brand-purple/20 hover:shadow-brand-purple/30 text-gray-950 font-bold light:bg-purple-600 light:hover:bg-purple-700 light:text-white',
    glow: 'from-brand-purple to-pink-500 light:to-pink-600',
    hoverText: 'group-hover:text-brand-purple light:group-hover:text-purple-600',
    dot: 'bg-brand-purple shadow-[0_0_8px_rgba(168,85,247,0.8)] light:shadow-[0_0_4px_rgba(126,34,206,0.4)]'
  },
  green: {
    text: 'text-brand-green light:text-emerald-700',
    border: 'border-brand-green/20 light:border-emerald-200',
    hoverBorder: 'hover:border-brand-green/40 light:hover:border-emerald-300',
    bg: 'bg-brand-green/10 text-brand-green border-brand-green/20 light:bg-emerald-50/50 light:text-emerald-700 light:border-emerald-200',
    btnBg: 'bg-brand-green hover:bg-brand-green/90 shadow-brand-green/20 hover:shadow-brand-green/30 text-gray-950 font-bold light:bg-emerald-600 light:hover:bg-emerald-700 light:text-white',
    glow: 'from-brand-green to-cyan-500 light:to-cyan-600',
    hoverText: 'group-hover:text-brand-green light:group-hover:text-emerald-700',
    dot: 'bg-brand-green shadow-[0_0_8px_rgba(16,185,129,0.8)] light:shadow-[0_0_4px_rgba(4,120,87,0.4)]'
  }
};
---

<Layout 
  title="Professional Services | Dr. Georg Hackenberg" 
  description="Explore custom R&D prototyping, corporate training bootcamps, scientific advisory, and media publishing services offered by Dr. Georg Hackenberg."
>
  <Navbar />

  <main class="flex-grow max-w-6xl mx-auto px-4 md:px-8 py-12 md:py-20 w-full relative z-10">
    <!-- Header -->
    <div class="mb-16">
      <span class="inline-flex items-center text-xs font-semibold px-3 py-1 rounded-full bg-brand-purple/10 text-brand-purple border border-brand-purple/20 mb-6 tracking-wider uppercase">
        Professional Collaboration
      </span>
      <h1 class="text-4xl md:text-6xl font-extrabold tracking-tight text-white mb-6">
        Professional <span class="bg-clip-text text-transparent bg-gradient-to-r from-brand-purple to-pink-500 light:to-pink-600">Services</span>
      </h1>
      <p class="text-gray-400 text-base md:text-lg max-w-2xl font-normal leading-relaxed">
        Bridging the gap between academic research, software engineering, and corporate strategy. Discover tailorable workshops, R&D prototyping, and advisory setups.
      </p>
    </div>


    <!-- Services Detailed List -->
    <div class="space-y-16">
      {optimizedServices.map((service) => {
        const classes = colorClasses[service.data.color];
        const serviceModules = modules
          .filter((m) => m.data.serviceId === service.id)
          .sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));
        return (
          <section id={service.id} class="scroll-mt-24 relative group">
            <div class="glass-card rounded-3xl border border-white/5 relative overflow-hidden flex flex-col lg:grid lg:grid-cols-12 items-stretch p-0">
              <!-- Top accent color line -->
              <div class={`absolute top-0 left-0 right-0 h-1.5 bg-gradient-to-r ${classes.glow} z-20`}></div>

              <!-- Card Clickable Overlay Link -->
              <a 
                href={`/services/${service.id}`} 
                class="absolute inset-0 z-10 cursor-pointer" 
                aria-label={`View details for ${service.data.title}`}
              ></a>

              <!-- Info Column (Left) -->
              <div class="p-8 md:p-10 lg:col-span-7 flex flex-col justify-center space-y-6 relative">
                <!-- Header -->
                <div class="flex items-center gap-4">
                  <div class={`w-12 h-12 rounded-xl flex items-center justify-center font-bold text-xl border ${classes.bg}`}>
                    {service.data.icon}
                  </div>
                  <div>
                    <h2 class={`text-2xl md:text-3xl font-extrabold text-white tracking-tight leading-none flex items-center gap-2 relative transition-colors ${classes.hoverText}`}>
                      <span>{service.data.title}</span>
                      <span 
                        class={`unread-dot hidden w-2.5 h-2.5 rounded-full ${classes.dot}`}
                        data-item-url={`/services/${service.id}`}
                        title="Unread service"
                      ></span>
                    </h2>
                    <p class={`${classes.text} font-bold text-xs uppercase tracking-wider mt-1.5`}>
                      {service.data.tagline}
                    </p>
                  </div>
                </div>

                <!-- Description -->
                <div class="space-y-3">
                  <p class="text-gray-300 text-sm leading-relaxed font-normal">
                    {service.data.description}
                  </p>
                </div>

                {serviceModules.length > 0 && (
                  <div class="space-y-3 relative z-20">
                    <p class="text-[10px] text-gray-500 font-extrabold uppercase tracking-widest">
                      Service Modules
                    </p>
                    <div class="flex flex-wrap gap-2">
                      {serviceModules.map((module) => {
                        const moduleSlug = module.id.split('/').pop();
                        const moduleUrl = `/services/${service.id}/${moduleSlug}`;
                        return (
                          <a 
                            href={moduleUrl}
                            class="inline-flex items-center gap-2 px-3 py-1 rounded-full text-[10px] font-bold tracking-wide uppercase border border-white/10 bg-white/5 text-gray-400 hover:bg-white/10 hover:text-white hover:border-white/20 transition-all cursor-pointer min-h-[28px]"
                          >
                            <span>{module.data.title}</span>
                            <span 
                              class={`unread-dot hidden w-1.5 h-1.5 rounded-full ${classes.dot}`}
                              data-item-url={moduleUrl}
                              title="Unread module"
                            ></span>
                          </a>
                        );
                      })}
                    </div>
                  </div>
                )}

                <div class="flex flex-col sm:flex-row gap-4 pt-2 relative z-20">
                  <a
                    href={`/services/${service.id}`}
                    class={`px-5 py-3 rounded-xl text-center text-xs font-bold shadow-md transition-all duration-300 hover:scale-[1.02] flex items-center justify-center space-x-1.5 cursor-pointer min-h-[44px] ${classes.btnBg}`}
                  >
                    <span>View Details & Methodology</span>
                    <span>&rarr;</span>
                  </a>
                </div>
              </div>

              <!-- Preview Image Column (Right) -->
              <div class="lg:col-span-5 relative min-h-[240px] sm:min-h-[320px] lg:min-h-full w-full overflow-hidden bg-gray-950/40">
                {service.data.previewImage && (
                  <svg 
                    class="absolute inset-0 w-full h-full group-hover:scale-105 transition-transform duration-500 z-0 will-change-transform pointer-events-none" 
                    viewBox={`0 0 ${service.data.previewImage.width} ${service.data.previewImage.height}`} 
                    preserveAspectRatio="xMidYMid slice"
                    role="img"
                    aria-label={`Service preview: ${service.data.title}`}
                  >
                    <defs>
                      <linearGradient id={`grad-service-dark-${service.id}`} x1="0" y1="0" x2="0" y2="1">
                        <stop offset="0%" stop-color="#000000" stop-opacity="0" />
                        <stop offset="50%" stop-color="#000000" stop-opacity="0.15" />
                        <stop offset="100%" stop-color="#000000" stop-opacity="0.75" />
                      </linearGradient>
                      <linearGradient id={`grad-service-light-${service.id}`} x1="0" y1="0" x2="0" y2="1">
                        <stop offset="0%" stop-color="#000000" stop-opacity="0" />
                        <stop offset="50%" stop-color="#000000" stop-opacity="0.10" />
                        <stop offset="100%" stop-color="#000000" stop-opacity="0.40" />
                      </linearGradient>
                    </defs>
                    <image 
                      href={service.optimizedImageSrc || service.data.previewImage.src} 
                      x="0" 
                      y="0" 
                      width={service.data.previewImage.width} 
                      height={service.data.previewImage.height} 
                      preserveAspectRatio="xMidYMid slice" 
                    />
                    <rect 
                      x="0" 
                      y="0" 
                      width={service.data.previewImage.width} 
                      height={service.data.previewImage.height + 0.5} 
                      class="block light:hidden"
                      fill={`url(#grad-service-dark-${service.id})`} 
                    />
                    <rect 
                      x="0" 
                      y="0" 
                      width={service.data.previewImage.width} 
                      height={service.data.previewImage.height + 0.5} 
                      class="hidden light:block"
                      fill={`url(#grad-service-light-${service.id})`} 
                    />
                  </svg>
                )}
                <div class="absolute inset-0 bg-gradient-to-t lg:bg-gradient-to-l from-gray-950/40 via-transparent to-transparent pointer-events-none z-10"></div>
              </div>

            </div>
          </section>
        );
      })}
    </div>

    <!-- Contact & Booking Section -->
    <section id="contact-services" class="py-16 mt-16 border-t border-white/5 scroll-mt-24">
      <div class="max-w-3xl mx-auto text-center mb-12">
        <span class="inline-flex items-center text-xs font-semibold px-3 py-1 rounded-full bg-brand-purple/10 text-brand-purple border border-brand-purple/20 mb-4 uppercase tracking-wider">
          Let's Collaborate
        </span>
        <h2 class="text-3xl md:text-4xl font-extrabold text-white mb-4">
          Start a Conversation
        </h2>
        <p class="text-gray-400 text-sm md:text-base leading-relaxed">
          Select a service above or write directly to discuss educational partnerships, strategic advisory, or prototype developments.
        </p>
      </div>

      <div class="max-w-2xl mx-auto">
        <div class="glass-card p-8 md:p-10 rounded-3xl border border-white/5 relative overflow-hidden">
          <div class="absolute top-0 left-0 right-0 h-1.5 bg-gradient-to-r from-brand-purple to-pink-500 light:to-pink-600"></div>
          
          <h3 class="text-lg font-bold text-white mb-6">Contact & Booking Inquiry</h3>
          
          <div class="space-y-6">
            <div class="flex items-start space-x-4">
              <div class="text-brand-purple mt-1.5 shrink-0">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"></path>
                </svg>
              </div>
              <div class="flex-grow flex flex-col sm:flex-row sm:items-center justify-between gap-4">
                <div>
                  <p class="text-gray-500 text-xs font-semibold uppercase tracking-wider">Send an email request to</p>
                  <p id="services-email-text" class="text-white font-mono font-medium mt-0.5 select-all text-sm sm:text-base">georg.hackenberg@fh-wels.at</p>
                </div>
                <button 
                  id="services-copy-email-btn"
                  class="px-4 py-2 text-xs font-semibold rounded-lg bg-white/5 hover:bg-white/10 text-gray-300 hover:text-white border border-white/10 hover:border-white/20 transition-all duration-200 self-start sm:self-auto flex items-center space-x-2"
                >
                  <span id="services-copy-btn-text">Copy Email</span>
                </button>
              </div>
            </div>
            
            <div class="pt-6 border-t border-white/5 flex flex-col sm:flex-row gap-4 justify-between items-center text-xs text-gray-400">
              <p>Typically responding within 2 business days.</p>
              <a 
                id="direct-mail-link"
                href="mailto:georg.hackenberg@fh-wels.at?subject=Services%20Inquiry"
                class="px-5 py-2.5 rounded-xl bg-brand-purple hover:bg-brand-purple/90 text-gray-950 font-bold transition-all duration-300 hover:scale-105 shadow-md shadow-brand-purple/20"
              >
                Open Email Client &rarr;
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

  </main>
</Layout>

<style>
  /* Markdown content styling for service layouts */
  .service-content :global(h3) {
    font-size: 1.25rem;
    font-weight: 800;
    color: white;
    margin-top: 1.5rem;
    margin-bottom: 0.85rem;
    letter-spacing: -0.015em;
  }
  .service-content :global(h3:first-child) {
    margin-top: 0;
  }
  .service-content :global(h4) {
    font-size: 1.05rem;
    font-weight: 700;
    color: white;
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }
  .service-content :global(p) {
    font-size: 0.875rem;
    line-height: 1.7;
    color: #9ca3af; /* text-gray-400 */
    margin-bottom: 1.25rem;
  }
  .service-content :global(ul) {
    list-style-type: disc;
    padding-left: 1.25rem;
    margin-bottom: 1.25rem;
    color: #9ca3af;
  }
  .service-content :global(li) {
    margin-bottom: 0.5rem;
    font-size: 0.875rem;
    line-height: 1.6;
  }
  .service-content :global(li strong) {
    color: white;
  }
</style>

<script>
  // Add listeners to inquiry triggers to pre-fill email client link subject
  const triggers = document.querySelectorAll('.inquiry-trigger');
  const directMailLink = document.getElementById('direct-mail-link') as HTMLAnchorElement | null;
  
  triggers.forEach(trigger => {
    trigger.addEventListener('click', () => {
      const subject = trigger.getAttribute('data-subject');
      if (directMailLink && subject) {
        directMailLink.href = `mailto:georg.hackenberg@fh-wels.at?subject=${encodeURIComponent(subject)}`;
      }
    });
  });

  // Copy Email Logic
  const copyBtn = document.getElementById('services-copy-email-btn');
  const emailText = document.getElementById('services-email-text');
  const copyBtnText = document.getElementById('services-copy-btn-text');

  if (copyBtn && emailText && copyBtnText) {
    copyBtn.addEventListener('click', () => {
      const email = emailText.textContent?.trim() || 'georg.hackenberg@fh-wels.at';
      
      navigator.clipboard.writeText(email).then(() => {
        copyBtnText.textContent = 'Copied!';
        copyBtn.classList.remove('bg-white/5', 'text-gray-300', 'border-white/10');
        copyBtn.classList.add('bg-brand-green/20', 'text-brand-green', 'border-brand-green/30');
        
        setTimeout(() => {
          copyBtnText.textContent = 'Copy Email';
          copyBtn.classList.remove('bg-brand-green/20', 'text-brand-green', 'border-brand-green/30');
          copyBtn.classList.add('bg-white/5', 'text-gray-300', 'border-white/10');
        }, 2500);
      }).catch(err => {
        console.error('Failed to copy: ', err);
      });
    });
  }
</script>
