---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import { getCollection } from "astro:content";
import PostCard from "../../components/PostCard.astro";

export async function getStaticPaths({ paginate }) {
  const posts = (await getCollection("posts")).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
  );
  return paginate(posts, { pageSize: 10 });
}

const { page } = Astro.props;
const posts = page.data;

// Collect all unique tags for a tag cloud across all posts
const allPosts = await getCollection("posts");
const tags = Array.from(
  new Set(allPosts.flatMap((post) => post.data.tags || []))
).sort();

const getPageNumbers = (current: number, total: number) => {
  if (total <= 7) {
    return Array.from({ length: total }, (_, i) => i + 1);
  }
  if (current <= 4) {
    return [1, 2, 3, 4, 5, '...', total];
  }
  if (current >= total - 3) {
    return [1, '...', total - 4, total - 3, total - 2, total - 1, total];
  }
  return [1, '...', current - 1, current, current + 1, '...', total];
};

const pageList = getPageNumbers(page.currentPage, page.lastPage);

const getPageUrl = (pageNum: number | string) => {
  if (typeof pageNum === 'string') return '#';
  return pageNum === 1 ? "/posts" : `/posts/${pageNum}`;
};
---

<Layout 
  title={page.currentPage > 1 ? `Computer Science Blog - Page ${page.currentPage} | Dr. Georg Hackenberg` : "Computer Science Blog | Dr. Georg Hackenberg"} 
  description={page.currentPage > 1 ? `Read computer science insights, software tutorials, and dev logs by Dr. Georg Hackenberg (Page ${page.currentPage}).` : "Read computer science insights, software tutorials, and dev logs by Dr. Georg Hackenberg covering systems development, styling, and graphics."}
>
  <Navbar />

  <main class="flex-grow max-w-6xl mx-auto px-4 md:px-8 py-12 md:py-20 w-full relative z-10">
    <div class="mb-12">
      <span class="inline-flex items-center text-xs font-semibold px-3 py-1 rounded-full bg-brand-blue/10 text-brand-blue border border-brand-blue/20 mb-6 tracking-wider uppercase">
        Digital Log
      </span>
      <h1 class="text-4xl md:text-6xl font-extrabold tracking-tight mb-6">
        Computer Science <span class="bg-clip-text text-transparent bg-gradient-to-r from-brand-blue to-indigo-500 light:to-indigo-600">Blog</span>
      </h1>
      <p class="text-gray-400 text-base md:text-lg max-w-2xl font-normal leading-relaxed">
        Insights, development logs, sketches, and tutorials covering ultimate usability design, graphics engine development, software systems, and mechatronics workbench engineering.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
      <!-- Tag Filter Cloud -->
      <div class="lg:col-span-3 order-1 lg:order-2 lg:sticky lg:top-24">
        <div class="glass-card p-6 rounded-2xl border border-white/5 flex flex-col max-h-[300px] lg:max-h-[calc(100vh-10rem)]">
          <h2 class="text-lg font-bold mb-4 flex items-center space-x-2 shrink-0">
            <span>🏷️</span>
            <span>Tags</span>
          </h2>
          <div class="mb-3 relative shrink-0">
            <input 
              type="text" 
              id="tag-search" 
              placeholder="Search tags..." 
              class="w-full bg-white/5 border border-white/10 rounded-lg px-3 py-1.5 pl-8 text-xs placeholder-gray-500 focus:outline-none focus:border-brand-blue/50 focus:ring-1 focus:ring-brand-blue/50 transition-all duration-200"
            />
            <span class="absolute left-2.5 top-2 text-[10px] text-gray-500">🔍</span>
          </div>
          <div class="flex flex-wrap gap-2 overflow-y-auto pr-1 custom-scrollbar-thin flex-grow">
            {tags.map(tag => (
              <a 
                href={`/posts/tags/${tag}`}
                data-tag={tag}
                class="tag-link px-2.5 py-1 rounded-lg text-xs font-medium border transition-all duration-200"
              >
                #{tag}
              </a>
            ))}
            <p id="no-tags-message" class="text-xs text-gray-500 italic py-2 hidden w-full text-center">No matching tags</p>
          </div>
        </div>
      </div>

      <!-- Posts List -->
      <div class="lg:col-span-9 order-2 lg:order-1 space-y-6">
        {posts.length === 0 ? (
          <p class="text-gray-500 font-medium py-12 text-center glass-card rounded-2xl">No blog posts found.</p>
        ) : (
          posts.map(post => (
            <PostCard
              id={post.id}
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              icon={post.data.icon}
              tags={post.data.tags}
            />
          ))
        )}

        <!-- Pagination Controls -->
        {page.lastPage > 1 && (
          <nav class="flex flex-col sm:flex-row items-center justify-between gap-4 pt-8 border-t border-white/5 mt-10" aria-label="Pagination">
            {/* Previous Button */}
            <div class="flex-1 w-full sm:w-auto text-left">
              {page.url.prev ? (
                <a 
                  href={page.url.prev} 
                  class="inline-flex items-center justify-center px-4 py-2.5 rounded-xl bg-white/5 border border-white/10 text-gray-300 hover:text-white hover:border-brand-blue/30 hover:bg-white/10 transition-all duration-200 text-sm font-semibold group w-full sm:w-auto"
                >
                  <span class="group-hover:-translate-x-0.5 transition-transform mr-1.5">&larr;</span>
                  <span>Previous</span>
                </a>
              ) : (
                <span class="inline-flex items-center justify-center px-4 py-2.5 rounded-xl bg-white/5 border border-white/5 text-gray-600 text-sm font-semibold cursor-not-allowed opacity-40 w-full sm:w-auto">
                  <span class="mr-1.5">&larr;</span>
                  <span>Previous</span>
                </span>
              )}
            </div>

            {/* Page Numbers */}
            <div class="flex items-center justify-center gap-1.5 order-3 sm:order-2">
              {pageList.map((num) => {
                if (typeof num === 'string') {
                  return (
                    <span class="px-3.5 py-2 text-gray-500 text-sm font-medium">
                      {num}
                    </span>
                  );
                }
                const isCurrent = num === page.currentPage;
                return isCurrent ? (
                  <span 
                    class="px-3.5 py-2 rounded-xl text-sm font-bold text-gray-950 bg-gradient-to-r from-brand-blue to-brand-purple shadow-lg shadow-brand-blue/20 cursor-default select-none min-w-[38px] text-center"
                    aria-current="page"
                  >
                    {num}
                  </span>
                ) : (
                  <a 
                    href={getPageUrl(num)} 
                    class="px-3.5 py-2 rounded-xl text-sm font-medium bg-white/5 border border-white/10 text-gray-400 hover:text-white hover:border-brand-blue/30 hover:bg-white/10 transition-all duration-200 min-w-[38px] text-center"
                  >
                    {num}
                  </a>
                );
              })}
            </div>

            {/* Next Button */}
            <div class="flex-1 w-full sm:w-auto text-right order-2 sm:order-3">
              {page.url.next ? (
                <a 
                  href={page.url.next} 
                  class="inline-flex items-center justify-center px-4 py-2.5 rounded-xl bg-white/5 border border-white/10 text-gray-300 hover:text-white hover:border-brand-blue/30 hover:bg-white/10 transition-all duration-200 text-sm font-semibold group w-full sm:w-auto"
                >
                  <span>Next</span>
                  <span class="group-hover:translate-x-0.5 transition-transform ml-1.5">&rarr;</span>
                </a>
              ) : (
                <span class="inline-flex items-center justify-center px-4 py-2.5 rounded-xl bg-white/5 border border-white/5 text-gray-600 text-sm font-semibold cursor-not-allowed opacity-40 w-full sm:w-auto">
                  <span>Next</span>
                  <span class="ml-1.5">&rarr;</span>
                </span>
              )}
            </div>
          </nav>
        )}
      </div>
    </div>
  </main>

  <script>
    const searchInput = document.getElementById('tag-search') as HTMLInputElement | null;
    const tagLinks = document.querySelectorAll('[data-tag]');
    const noTagsMessage = document.getElementById('no-tags-message');

    searchInput?.addEventListener('input', (e) => {
      const query = (e.target as HTMLInputElement).value.toLowerCase().trim();
      let visibleCount = 0;

      tagLinks.forEach(link => {
        const tag = link.getAttribute('data-tag')?.toLowerCase() || '';
        if (tag.includes(query)) {
          link.classList.remove('hidden');
          visibleCount++;
        } else {
          link.classList.add('hidden');
        }
      });

      if (noTagsMessage) {
        if (visibleCount === 0 && query !== '') {
          noTagsMessage.classList.remove('hidden');
        } else {
          noTagsMessage.classList.add('hidden');
        }
      }
    });
  </script>
</Layout>

<style>
  .tag-link {
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(255, 255, 255, 0.1);
    color: #9ca3af;
  }
  .tag-link:hover {
    border-color: rgba(59, 130, 246, 0.4);
    color: #60a5fa;
    background: rgba(59, 130, 246, 0.08);
  }
  :global(.light) .tag-link {
    background: rgba(15, 23, 42, 0.04);
    border-color: rgba(15, 23, 42, 0.08);
    color: #475569;
  }
  :global(.light) .tag-link:hover {
    background: rgba(59, 130, 246, 0.06);
    border-color: rgba(59, 130, 246, 0.3);
    color: #1d4ed8;
  }
</style>
