---
import Layout from "../../../../layouts/Layout.astro";
import Navbar from "../../../../components/Navbar.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths({ paginate }) {
  const posts = await getCollection("posts");
  const uniqueTags = Array.from(
    new Set(posts.flatMap((post) => post.data.tags || []))
  );
  
  return uniqueTags.flatMap((tag) => {
    const filteredPosts = posts
      .filter((post) => post.data.tags.includes(tag))
      .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
      
    return paginate(filteredPosts, {
      params: { tag },
      pageSize: 10,
    });
  });
}

const { page } = Astro.props;
const { tag } = Astro.params;
const posts = page.data;

const getPageNumbers = (current: number, total: number) => {
  if (total <= 7) {
    return Array.from({ length: total }, (_, i) => i + 1);
  }
  if (current <= 4) {
    return [1, 2, 3, 4, 5, '...', total];
  }
  if (current >= total - 3) {
    return [1, '...', total - 4, total - 3, total - 2, total - 1, total];
  }
  return [1, '...', current - 1, current, current + 1, '...', total];
};

const pageList = getPageNumbers(page.currentPage, page.lastPage);

const getPageUrl = (pageNum: number | string) => {
  if (typeof pageNum === 'string') return '#';
  return pageNum === 1 ? `/posts/tags/${tag}` : `/posts/tags/${tag}/${pageNum}`;
};
---

<Layout title={page.currentPage > 1 ? `Posts tagged #${tag} - Page ${page.currentPage} | Dr. Georg Hackenberg` : `Posts tagged #${tag} | Dr. Georg Hackenberg`} description={`List of blog posts tagged with #${tag}`}>
  <Navbar />

  <main class="flex-grow max-w-4xl mx-auto px-4 md:px-8 py-12 md:py-20 w-full relative z-10">
    <a 
      href="/posts" 
      class="inline-flex items-center space-x-2 text-xs font-semibold px-4 py-2 rounded-xl bg-white/5 border border-white/10 hover:border-white/20 text-gray-300 hover:text-white transition-all mb-8"
    >
      <span>&larr;</span>
      <span>All Posts</span>
    </a>

    <div class="mb-12">
      <span class="inline-flex items-center text-xs font-semibold px-3 py-1 rounded-full bg-brand-blue/10 text-brand-blue border border-brand-blue/20 mb-6 tracking-wider uppercase">
        Tag Filter
      </span>
      <h1 class="text-3xl md:text-5xl font-extrabold tracking-tight text-white mb-6">
        Posts tagged <span class="bg-clip-text text-transparent bg-gradient-to-r from-brand-blue to-brand-purple">#{tag}</span>
      </h1>
    </div>

    <!-- Posts List -->
    <div class="space-y-6">
      {posts.map(post => (
        <article class="glass-card p-6 rounded-2xl border border-white/5 flex flex-col md:flex-row gap-6 items-start group">
          {post.data.icon && (
            <div class="w-16 h-16 md:w-20 md:h-20 rounded-xl overflow-hidden shrink-0 border border-white/10 bg-gray-900/50 flex items-center justify-center">
              <img 
                src={post.data.icon} 
                alt="" 
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                loading="lazy"
              />
            </div>
          )}
          
          <div class="flex-grow">
            <time class="text-xs font-semibold text-brand-blue/80 block mb-2">
              {post.data.pubDate.toLocaleDateString("en-US", {
                year: "numeric",
                month: "short",
                day: "numeric"
              })}
            </time>
            
            <h2 class="text-lg font-bold text-white mb-2 group-hover:text-brand-blue transition-colors">
              <a href={`/posts/${post.id}`}>
                {post.data.title}
              </a>
            </h2>
            
            {post.data.description && (
              <p class="text-gray-400 text-sm leading-relaxed mb-4 font-normal">
                {post.data.description}
              </p>
            )}

            <div class="flex flex-wrap gap-2 items-center">
              {post.data.tags.map(t => (
                <a 
                  href={`/posts/tags/${t}`}
                  class={`text-xs font-medium ${t === tag ? 'text-brand-blue' : 'text-gray-500 hover:text-white'} transition-colors`}
                >
                  #{t}
                </a>
              ))}
              <a 
                href={`/posts/${post.id}`} 
                class="text-xs font-semibold text-brand-blue hover:text-brand-blue/85 ml-auto flex items-center space-x-1"
              >
                <span>Read More</span>
                <span>&rarr;</span>
              </a>
            </div>
          </div>
        </article>
      ))}

      <!-- Pagination Controls -->
      {page.lastPage > 1 && (
        <nav class="flex flex-col sm:flex-row items-center justify-between gap-4 pt-8 border-t border-white/5 mt-10" aria-label="Pagination">
          {/* Previous Button */}
          <div class="flex-1 w-full sm:w-auto text-left">
            {page.url.prev ? (
              <a 
                href={page.url.prev} 
                class="inline-flex items-center justify-center px-4 py-2.5 rounded-xl bg-white/5 border border-white/10 text-gray-300 hover:text-white hover:border-brand-blue/30 hover:bg-white/10 transition-all duration-200 text-sm font-semibold group w-full sm:w-auto"
              >
                <span class="group-hover:-translate-x-0.5 transition-transform mr-1.5">&larr;</span>
                <span>Previous</span>
              </a>
            ) : (
              <span class="inline-flex items-center justify-center px-4 py-2.5 rounded-xl bg-white/5 border border-white/5 text-gray-600 text-sm font-semibold cursor-not-allowed opacity-40 w-full sm:w-auto">
                <span class="mr-1.5">&larr;</span>
                <span>Previous</span>
              </span>
            )}
          </div>

          {/* Page Numbers */}
          <div class="flex items-center justify-center gap-1.5 order-3 sm:order-2">
            {pageList.map((num) => {
              if (typeof num === 'string') {
                return (
                  <span class="px-3.5 py-2 text-gray-500 text-sm font-medium">
                    {num}
                  </span>
                );
              }
              const isCurrent = num === page.currentPage;
              return isCurrent ? (
                <span 
                  class="px-3.5 py-2 rounded-xl text-sm font-bold text-white bg-gradient-to-r from-brand-blue to-brand-purple shadow-lg shadow-brand-blue/20 cursor-default select-none min-w-[38px] text-center"
                  aria-current="page"
                >
                  {num}
                </span>
              ) : (
                <a 
                  href={getPageUrl(num)} 
                  class="px-3.5 py-2 rounded-xl text-sm font-medium bg-white/5 border border-white/10 text-gray-400 hover:text-white hover:border-brand-blue/30 hover:bg-white/10 transition-all duration-200 min-w-[38px] text-center"
                >
                  {num}
                </a>
              );
            })}
          </div>

          {/* Next Button */}
          <div class="flex-1 w-full sm:w-auto text-right order-2 sm:order-3">
            {page.url.next ? (
              <a 
                href={page.url.next} 
                class="inline-flex items-center justify-center px-4 py-2.5 rounded-xl bg-white/5 border border-white/10 text-gray-300 hover:text-white hover:border-brand-blue/30 hover:bg-white/10 transition-all duration-200 text-sm font-semibold group w-full sm:w-auto"
              >
                <span>Next</span>
                <span class="group-hover:translate-x-0.5 transition-transform ml-1.5">&rarr;</span>
              </a>
            ) : (
              <span class="inline-flex items-center justify-center px-4 py-2.5 rounded-xl bg-white/5 border border-white/5 text-gray-600 text-sm font-semibold cursor-not-allowed opacity-40 w-full sm:w-auto">
                <span>Next</span>
                <span class="ml-1.5">&rarr;</span>
              </span>
            )}
          </div>
        </nav>
      )}
    </div>
  </main>
</Layout>
