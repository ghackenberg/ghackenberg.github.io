---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("posts")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

// Collect all unique tags for a tag cloud
const tags = Array.from(
  new Set(posts.flatMap((post) => post.data.tags || []))
).sort();
---

<Layout title="Blog | Dr. Georg Hackenberg" description="Georg Hackenberg's personal computer science blog sharing updates on software, academic research, and informatics.">
  <Navbar />

  <main class="flex-grow max-w-6xl mx-auto px-4 md:px-8 py-12 md:py-20 w-full relative z-10">
    <div class="mb-12">
      <span class="inline-flex items-center text-xs font-semibold px-3 py-1 rounded-full bg-brand-blue/10 text-brand-blue border border-brand-blue/20 mb-6 tracking-wider uppercase">
        Digital Log
      </span>
      <h1 class="text-4xl md:text-6xl font-extrabold tracking-tight text-white mb-6">
        Computer Science <span class="bg-clip-text text-transparent bg-gradient-to-r from-brand-blue via-brand-purple to-brand-yellow">Blog</span>
      </h1>
      <p class="text-gray-400 text-base md:text-lg max-w-2xl font-normal leading-relaxed">
        Insights, development logs, sketches, and tutorials covering ultimate usability design, graphics engine development, software systems, and mechatronics workbench engineering.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
      <!-- Tag Filter Cloud -->
      <div class="lg:col-span-3 order-1 lg:order-2 lg:sticky lg:top-24">
        <div class="glass-card p-6 rounded-2xl border border-white/5">
          <h3 class="text-lg font-bold text-white mb-4 flex items-center space-x-2">
            <span>🏷️</span>
            <span>Tags</span>
          </h3>
          <div class="flex flex-wrap gap-2">
            {tags.map(tag => (
              <a 
                href={`/posts/tags/${tag}`}
                class="px-2.5 py-1 rounded-lg text-xs font-medium bg-white/5 border border-white/10 text-gray-400 hover:text-white hover:border-brand-blue/30 transition-all duration-200"
              >
                #{tag}
              </a>
            ))}
          </div>
        </div>
      </div>

      <!-- Posts List -->
      <div class="lg:col-span-9 order-2 lg:order-1 space-y-6">
        {posts.length === 0 ? (
          <p class="text-gray-500 font-medium py-12 text-center glass-card rounded-2xl">No blog posts found.</p>
        ) : (
          posts.map(post => (
            <article class="glass-card p-6 rounded-2xl border border-white/5 flex flex-col md:flex-row gap-6 items-start group">
              <!-- Post Icon -->
              {post.data.icon && (
                <div class="w-16 h-16 md:w-24 md:h-24 rounded-xl overflow-hidden shrink-0 border border-white/10 bg-gray-900/50 flex items-center justify-center">
                  <img 
                    src={post.data.icon} 
                    alt="" 
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                    loading="lazy"
                  />
                </div>
              )}
              
              <!-- Content -->
              <div class="flex-grow">
                <div class="flex items-center space-x-3 mb-2.5">
                  <time class="text-xs font-semibold text-brand-blue/80">
                    {post.data.pubDate.toLocaleDateString("en-US", {
                      year: "numeric",
                      month: "short",
                      day: "numeric"
                    })}
                  </time>
                </div>
                
                <h2 class="text-xl font-bold text-white mb-3 group-hover:text-brand-blue transition-colors">
                  <a href={`/posts/${post.id}`}>
                    {post.data.title}
                  </a>
                </h2>
                
                {post.data.description && (
                  <p class="text-gray-400 text-sm leading-relaxed mb-4 font-normal">
                    {post.data.description}
                  </p>
                )}

                <div class="flex flex-wrap gap-2 items-center">
                  {post.data.tags.map(tag => (
                    <a 
                      href={`/posts/tags/${tag}`}
                      class="text-xs font-medium text-gray-500 hover:text-white transition-colors"
                    >
                      #{tag}
                    </a>
                  ))}
                  <a 
                    href={`/posts/${post.id}`} 
                    class="text-xs font-semibold text-brand-blue hover:text-brand-blue/85 ml-auto flex items-center space-x-1"
                  >
                    <span>Read More</span>
                    <span>&rarr;</span>
                  </a>
                </div>
              </div>
            </article>
          ))
        )}
      </div>
    </div>
  </main>
</Layout>
