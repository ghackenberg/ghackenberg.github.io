---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// Get related posts
const allPosts = await getCollection("posts");
const relatedPosts = allPosts
  .filter((p) => p.id !== post.id)
  .map((p) => {
    const commonTags = p.data.tags.filter((t) => post.data.tags.includes(t)).length;
    return { post: p, commonTags };
  })
  .sort((a, b) => b.commonTags - a.commonTags || b.post.data.pubDate.valueOf() - a.post.data.pubDate.valueOf())
  .slice(0, 3)
  .map((x) => x.post);
---

<Layout 
  title={`${post.data.title} | Dr. Georg Hackenberg`} 
  description={post.data.description}
  type="article"
  pubDate={post.data.pubDate}
  tags={post.data.tags}
>
  <Navbar />

  <main class="flex-grow max-w-4xl mx-auto px-4 md:px-8 py-12 md:py-20 w-full relative z-10">
    <!-- Back button -->
    <a 
      href="/posts" 
      class="inline-flex items-center space-x-2 text-xs font-semibold px-4 py-2 rounded-xl bg-white/5 border border-white/10 hover:border-white/20 text-gray-300 hover:text-white transition-all mb-8"
    >
      <span>&larr;</span>
      <span>Back to Blog</span>
    </a>

    <!-- Post Header -->
    <header class="mb-10 pb-8 border-b border-white/5">
      <div class="flex items-center space-x-3 mb-4">
        <time class="text-sm font-semibold text-brand-blue/80">
          {post.data.pubDate.toLocaleDateString("en-US", {
            year: "numeric",
            month: "long",
            day: "numeric"
          })}
        </time>
      </div>

      <h1 class="text-3xl sm:text-4xl md:text-5xl font-extrabold tracking-tight text-white mb-6 leading-tight">
        {post.data.title}
      </h1>

      <div class="flex flex-wrap gap-2">
        {post.data.tags.map(tag => (
          <a 
            href={`/posts/tags/${tag}`}
            class="px-2.5 py-1 rounded-lg text-xs font-medium bg-white/5 border border-white/10 text-gray-400 hover:text-white hover:border-brand-blue/30 transition-all duration-200"
          >
            #{tag}
          </a>
        ))}
      </div>
    </header>

    <!-- Post Body -->
    <div class="post-body glass-card p-6 md:p-10 rounded-3xl border border-white/5 mb-16 relative overflow-hidden">
      <!-- Top accent line -->
      <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-brand-blue via-brand-purple to-brand-yellow"></div>
      
      <Content />
    </div>

    <!-- Related Posts -->
    {relatedPosts.length > 0 && (
      <section class="border-t border-white/5 pt-16">
        <h2 class="text-2xl font-bold text-white mb-8 tracking-tight">
          You might also be interested in
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {relatedPosts.map(p => (
            <a href={`/posts/${p.id}`} class="glass-card p-5 rounded-2xl border border-white/5 group flex flex-col h-full justify-between">
              <div>
                <time class="text-[10px] font-semibold text-brand-blue/80 block mb-2">
                  {p.data.pubDate.toLocaleDateString("en-US", {
                    year: "numeric",
                    month: "short",
                    day: "numeric"
                  })}
                </time>
                <h3 class="text-sm font-bold text-white group-hover:text-brand-blue transition-colors line-clamp-2 mb-2">
                  {p.data.title}
                </h3>
              </div>
              <span class="text-xs font-semibold text-brand-blue/80 mt-4 flex items-center space-x-1 group-hover:translate-x-1 transition-transform">
                <span>Read article</span>
                <span>&rarr;</span>
              </span>
            </a>
          ))}
        </div>
      </section>
    )}
  </main>
</Layout>

<style>
  /* Local styling rules for post html contents rendering */
  .post-body :global(p) {
    margin-bottom: 1.5rem;
    line-height: 1.8;
    color: #d1d5db; /* gray-300 */
    font-size: 1.0625rem;
  }
  .post-body :global(p:last-child) {
    margin-bottom: 0;
  }
  .post-body :global(a) {
    color: #3b82f6; /* brand-blue */
    text-decoration: underline;
    transition: color 0.2s;
  }
  .post-body :global(a:hover) {
    color: #60a5fa;
  }
  .post-body :global(strong) {
    color: #ffffff;
    font-weight: 700;
  }
  .post-body :global(img) {
    border-radius: 0.75rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    margin: 2rem auto;
    max-width: 100%;
    height: auto;
    display: block;
    box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.4);
  }
  .post-body :global(pre) {
    background: rgba(3, 7, 18, 0.6);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 0.75rem;
    padding: 1.25rem;
    overflow-x: auto;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.875rem;
    margin-bottom: 1.5rem;
    color: #e5e7eb;
  }
  .post-body :global(ul) {
    list-style-type: disc;
    padding-left: 1.5rem;
    margin-bottom: 1.5rem;
    color: #d1d5db;
  }
  .post-body :global(ol) {
    list-style-type: decimal;
    padding-left: 1.5rem;
    margin-bottom: 1.5rem;
    color: #d1d5db;
  }
  .post-body :global(li) {
    margin-bottom: 0.5rem;
    line-height: 1.7;
  }
</style>
