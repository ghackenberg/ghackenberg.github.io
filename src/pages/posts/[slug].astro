---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// Get related posts
const allPosts = await getCollection("posts");
const relatedPosts = allPosts
  .filter((p) => p.id !== post.id)
  .map((p) => {
    const commonTags = p.data.tags.filter((t) => post.data.tags.includes(t)).length;
    return { post: p, commonTags };
  })
  .sort((a, b) => b.commonTags - a.commonTags || b.post.data.pubDate.valueOf() - a.post.data.pubDate.valueOf())
  .slice(0, 3)
  .map((x) => x.post);

const seoDescription = post.data.description 
  ? post.data.description.replace(/\s+/g, " ").trim().substring(0, 156)
  : `${post.data.title} - A blog post by Dr. Georg Hackenberg on topics like ${post.data.tags.join(", ")}.`;
---

<Layout 
  title={`${post.data.title} | Blog | Dr. Georg Hackenberg`} 
  description={seoDescription}
  type="article"
  pubDate={post.data.pubDate}
  tags={post.data.tags}
  hasMath={post.body ? (post.body.includes('$$') || /\$[^\$\s][^\$]*\$/.test(post.body)) : false}
>
  <Navbar />

  <main class="flex-grow max-w-4xl mx-auto px-4 md:px-8 py-12 md:py-20 w-full relative z-10">
    <!-- Back button -->
    <a 
      href="/posts" 
      class="inline-flex items-center space-x-2 text-xs font-semibold px-4 py-2 rounded-xl bg-brand-blue/10 border border-brand-blue/20 hover:border-brand-blue/30 text-brand-blue transition-all mb-8 cursor-pointer"
    >
      <span>&larr;</span>
      <span>Back to Blog</span>
    </a>

    <!-- Post Header -->
    <header class="mb-10 pb-8 border-b border-element-border">
      <div class="flex items-center space-x-3 mb-4">
        <time class="text-sm font-semibold text-brand-blue/80">
          {post.data.pubDate.toLocaleDateString("en-US", {
            year: "numeric",
            month: "long",
            day: "numeric"
          })}
        </time>
      </div>

      <h1 class="text-3xl sm:text-4xl md:text-5xl font-extrabold tracking-tight mb-6 leading-tight">
        {post.data.title}
      </h1>

      <div class="flex flex-wrap gap-2">
        {post.data.tags.map(tag => (
          <a 
            href={`/posts/tags/${tag}`}
            class="px-2.5 py-1 rounded-lg text-xs font-medium bg-element-bg border border-element-border-medium text-gray-400 hover:text-gray-100 hover:border-brand-blue/30 transition-all duration-200"
          >
            #{tag}
          </a>
        ))}
      </div>
    </header>

    <!-- Post Body -->
    <div class="post-body glass-card p-6 md:p-10 rounded-3xl border border-element-border mb-16 relative overflow-hidden prose-custom">
      <!-- Top accent line -->
      <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-brand-blue to-indigo-500 light:to-indigo-600"></div>
      
      <Content />
    </div>

    <!-- Related Posts -->
    {relatedPosts.length > 0 && (
      <section class="border-t border-element-border pt-16">
        <h2 class="text-2xl font-bold mb-8 tracking-tight">
          You might also be interested in
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {relatedPosts.map(p => (
            <a href={`/posts/${p.id}`} class="glass-card p-5 rounded-2xl border border-element-border group flex flex-col h-full justify-between">
              <div>
                <time class="text-[10px] font-semibold text-brand-blue/80 block mb-2">
                  {p.data.pubDate.toLocaleDateString("en-US", {
                    year: "numeric",
                    month: "short",
                    day: "numeric"
                  })}
                </time>
                <h3 class="text-sm font-bold group-hover:text-brand-blue transition-colors line-clamp-2 mb-2">
                  {p.data.title}
                </h3>
              </div>
              <span class="text-xs font-semibold text-brand-blue/80 mt-4 flex items-center space-x-1 group-hover:translate-x-1 transition-transform">
                <span>Read article</span>
                <span>&rarr;</span>
              </span>
            </a>
          ))}
        </div>
      </section>
    )}
  </main>
</Layout>

<style>
  /* Local styling rules for post html contents rendering */
  .post-body :global(h2) {
    font-size: 1.75rem;
    font-weight: 800;
    color: var(--color-text-heading);
    margin-top: 3rem;
    margin-bottom: 1.25rem;
    letter-spacing: -0.02em;
    line-height: 1.3;
    border-bottom: 1px solid var(--color-border-subtle);
    padding-bottom: 0.5rem;
    transition: color 0.5s ease, border-color 0.5s ease;
  }
  .post-body :global(h2:first-child) {
    margin-top: 0;
  }
  .post-body :global(h3) {
    font-size: 1.375rem;
    font-weight: 700;
    color: var(--color-text-heading);
    margin-top: 2.25rem;
    margin-bottom: 1rem;
    letter-spacing: -0.01em;
    line-height: 1.4;
    transition: color 0.5s ease;
  }
  .post-body :global(p) {
    margin-bottom: 1.5rem;
    line-height: 1.8;
    color: var(--color-text-main);
    font-size: 1.0625rem;
    transition: color 0.5s ease;
  }
  .post-body :global(p:last-child) {
    margin-bottom: 0;
  }
  .post-body :global(a) {
    color: #3b82f6; /* brand-blue */
    text-decoration: underline;
    transition: color 0.2s;
  }
  .post-body :global(a:hover) {
    color: #60a5fa;
  }
  .post-body :global(strong) {
    color: var(--color-text-heading);
    font-weight: 700;
    transition: color 0.5s ease;
  }
  .post-body :global(img) {
    border-radius: 1rem;
    border: 1px solid var(--color-border-medium);
    max-width: 100%;
    height: auto;
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.5), 0 8px 10px -6px rgba(0, 0, 0, 0.5);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    display: inline-block;
    vertical-align: middle;
  }
  .post-body :global(img:hover) {
    border-color: rgba(255, 255, 255, 0.2);
    transform: scale(1.01);
  }
  :global(.light) .post-body :global(img:hover) {
    border-color: rgba(15, 23, 42, 0.2);
  }
  /* Center block images */
  .post-body :global(p > img:only-child),
  .post-body :global(p > a:only-child > img) {
    display: block;
    margin: 2.5rem auto;
  }
  /* Responsive, styled iframes (YouTube, Slideshare) */
  .post-body :global(iframe) {
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 1rem;
    border: 1px solid var(--color-border-medium);
    margin: 2.5rem auto;
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.5), 0 8px 10px -6px rgba(0, 0, 0, 0.5);
    background: rgba(17, 24, 39, 0.4);
    display: block;
  }
  :global(.light) .post-body :global(iframe) {
    background: rgba(255, 255, 255, 0.4);
  }
  .post-body :global(pre) {
    background: rgba(3, 7, 18, 0.6);
    border: 1px solid var(--color-border-subtle);
    border-radius: 0.75rem;
    padding: 1.25rem;
    overflow-x: auto;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.875rem;
    margin-bottom: 1.5rem;
    color: #e5e7eb;
  }
  :global(.light) .post-body :global(pre) {
    background: rgba(255, 255, 255, 0.6);
    color: #1e293b;
  }
  .post-body :global(ul) {
    list-style-type: disc;
    padding-left: 1.5rem;
    margin-bottom: 1.5rem;
    color: var(--color-text-main);
    transition: color 0.5s ease;
  }
  .post-body :global(ol) {
    list-style-type: decimal;
    padding-left: 1.5rem;
    margin-bottom: 1.5rem;
    color: var(--color-text-main);
    transition: color 0.5s ease;
  }
  .post-body :global(li) {
    margin-bottom: 0.5rem;
    line-height: 1.7;
  }
  /* Markdown Tables Styling */
  .post-body :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 2rem 0;
    background: rgba(37, 49, 78, 0.25);
    border-radius: 1rem;
    overflow: hidden;
    border: 1px solid var(--color-border-subtle);
  }
  :global(.light) .post-body :global(table) {
    background: rgba(15, 23, 42, 0.03);
  }
  .post-body :global(th) {
    background: rgba(255, 255, 255, 0.05);
    padding: 0.875rem 1.25rem;
    text-align: left;
    font-weight: 700;
    color: var(--color-text-heading);
    border-bottom: 1px solid var(--color-border-medium);
    transition: color 0.5s ease, border-color 0.5s ease;
  }
  :global(.light) .post-body :global(th) {
    background: rgba(15, 23, 42, 0.05);
  }
  .post-body :global(td) {
    padding: 0.875rem 1.25rem;
    color: var(--color-text-main);
    border-bottom: 1px solid var(--color-border-subtle);
    transition: color 0.5s ease, border-color 0.5s ease;
  }
  .post-body :global(tr:last-child td) {
    border-bottom: none;
  }
</style>
