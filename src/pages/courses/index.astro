---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import { getCollection } from "astro:content";
import { getImage } from "astro:assets";
import CourseCard from "../../components/CourseCard.astro";

const courses = await getCollection("courses");
const repos = await getCollection("github-repos");

// Map repoName to repo data for quick access
const repoMap = new Map();
for (const repo of repos) {
  repoMap.set(repo.id, repo.data);
}

// Extract unique technologies/languages from course repos
const techLanguagesSet = new Set<string>();
for (const course of courses) {
  const repo = repoMap.get(course.data.repoName);
  if (repo && repo.language) {
    techLanguagesSet.add(repo.language);
  }
}
const techLanguages = Array.from(techLanguagesSet).sort();

// Find the first course's screenshot to preload for LCP
const firstCourse = courses[0];
const firstCourseScreenshot = firstCourse?.data.screenshot;
const optimizedFirstScreenshot = firstCourseScreenshot ? await getImage({
  src: firstCourseScreenshot,
  format: 'webp',
  width: 480,
  quality: 80
}) : null;

// Language badge colors
const languageColors: Record<string, string> = {
  TypeScript: "bg-blue-400",
  JavaScript: "bg-yellow-400",
  HTML: "bg-orange-500",
  CSS: "bg-purple-400",
  Astro: "bg-rose-500",
  Python: "bg-blue-500",
  Vue: "bg-emerald-500",
  React: "bg-sky-400",
  C: "bg-gray-400",
  "C++": "bg-pink-500",
  Java: "bg-red-400",
  "C#": "bg-violet-500",
  TeX: "bg-emerald-600",
  Mermaid: "bg-teal-400",
  "Jupyter Notebook": "bg-amber-600"
};
---

<Layout 
  title="Academic Courses & Teaching | Dr. Georg Hackenberg" 
  description="Explore syllabus materials, repositories, and teaching resources for Computer Science & Industrial Informatics courses taught by Dr. Georg Hackenberg."
  preloadImage={optimizedFirstScreenshot?.src}
>
  <Navbar />

  <main class="flex-grow max-w-6xl mx-auto px-4 md:px-8 py-12 md:py-20 w-full relative z-10">
    <!-- Header -->
    <div class="mb-12">
      <span class="inline-flex items-center text-xs font-semibold px-3 py-1 rounded-full bg-brand-yellow/10 text-brand-yellow border border-brand-yellow/20 mb-6 tracking-wider uppercase">
        Academic & Teaching
      </span>
      <h1 class="text-4xl md:text-6xl font-extrabold tracking-tight mb-6">
        University <span class="bg-clip-text text-transparent bg-gradient-to-r from-brand-yellow to-orange-500 light:to-orange-600">Lectures</span>
      </h1>
      <p class="text-gray-400 text-base md:text-lg max-w-2xl font-normal leading-relaxed">
        Explore materials, code repositories, and syllabus details for the courses I teach at the University of Applied Sciences Upper Austria (Fakultät für Technik und angewandte Naturwissenschaften, Wels).
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
      <!-- Filters Sidebar (Column 1) -->
      <div class="lg:col-span-3 order-1 lg:order-2 lg:sticky lg:top-24">
        <div class="glass-card p-6 rounded-2xl border border-white/5 flex flex-col">
          <h2 class="text-lg font-bold mb-4 flex items-center space-x-2 shrink-0">
            <span>⚙️</span>
            <span>Filter Catalog</span>
          </h2>

          <!-- Text Search -->
          <div class="mb-4">
            <label for="course-search" class="text-[10px] font-extrabold text-gray-500 uppercase tracking-widest block mb-2">Search</label>
            <div class="relative">
              <input 
                type="text" 
                id="course-search" 
                placeholder="Search lectures..." 
                class="w-full bg-white/5 border border-white/10 rounded-lg px-3 py-2 pl-8 text-xs placeholder-gray-500 focus:outline-none focus:border-brand-yellow/50 focus:ring-1 focus:ring-brand-yellow/50 transition-all duration-200"
              />
              <span class="absolute left-2.5 top-2.5 text-xs text-gray-500">🔍</span>
            </div>
          </div>

          <!-- Instruction Language -->
          <div class="mb-4">
            <span class="text-[10px] font-extrabold text-gray-500 uppercase tracking-widest block mb-2">Instruction Language</span>
            <div class="flex flex-wrap gap-2">
              <button 
                id="lang-btn-all" 
                class="lang-filter-btn active px-3 py-1.5 rounded-lg text-xs font-semibold border cursor-pointer transition-all duration-200"
                data-lang="all"
              >
                All
              </button>
              <button 
                id="lang-btn-de" 
                class="lang-filter-btn px-3 py-1.5 rounded-lg text-xs font-semibold border cursor-pointer transition-all duration-200"
                data-lang="de"
              >
                Deutsch (DE)
              </button>
              <button 
                id="lang-btn-en" 
                class="lang-filter-btn px-3 py-1.5 rounded-lg text-xs font-semibold border cursor-pointer transition-all duration-200"
                data-lang="en"
              >
                English (EN)
              </button>
            </div>
          </div>

          <!-- Programming Language / Tech -->
          <div class="mb-2">
            <label for="tech-filter" class="text-[10px] font-extrabold text-gray-500 uppercase tracking-widest block mb-2">Primary Technology</label>
            <select 
              id="tech-filter" 
              class="w-full bg-gray-900 border border-white/10 rounded-lg px-3 py-2 text-xs focus:outline-none focus:border-brand-yellow/50 transition-all duration-200 cursor-pointer"
            >
              <option value="all" class="bg-gray-900">All Technologies</option>
              {techLanguages.map(tech => (
                <option value={tech} class="bg-gray-900">{tech}</option>
              ))}
            </select>
          </div>
        </div>
      </div>

      <!-- Courses Grid (Column 2) -->
      <div class="lg:col-span-9 order-2 lg:order-1">
        {courses.length === 0 ? (
          <p class="text-gray-500 font-medium py-12 text-center glass-card rounded-2xl">No courses defined.</p>
        ) : (
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6" id="courses-grid">
            {courses.map(course => {
              const repo = repoMap.get(course.data.repoName);
              const starCount = repo?.stars ?? 0;
              const tech = repo?.language ?? "Web";
              const socialPreview = repo?.image;
              const goalsJoined = (course.data.learningGoals || []).join(" ").toLowerCase();

              return (
                <div 
                  class="course-card h-full"
                  data-title={course.data.title.toLowerCase()}
                  data-desc={(course.data.description || "").toLowerCase()}
                  data-goals={goalsJoined}
                  data-lang={course.data.language}
                  data-tech={tech}
                >
                  <CourseCard
                    title={course.data.title}
                    description={course.data.description}
                    href={`/courses/${course.id}`}
                    language={course.data.language}
                    screenshot={course.data.screenshot}
                    tech={tech}
                    starCount={starCount}
                  />
                </div>
              );
            })}
          </div>
        )}
        <p id="no-courses-message" class="text-gray-500 font-medium py-12 text-center glass-card rounded-2xl hidden">
          No courses match your selected filter criteria.
        </p>
      </div>
    </div>
  </main>
</Layout>

<style>
  /* Custom filter active states matching design guidelines */
  .lang-filter-btn {
    position: relative;
    background: rgba(31, 41, 55, 0.4);
    border-color: rgba(255, 255, 255, 0.05);
    color: #9ca3af; /* text-gray-400 */
  }

  .lang-filter-btn.active {
    background: rgba(245, 158, 11, 0.1);
    border-color: rgba(245, 158, 11, 0.3);
    color: #f59e0b; /* brand-yellow */
    box-shadow: 0 0 15px -3px rgba(245, 158, 11, 0.25);
  }

  .lang-filter-btn:hover:not(.active) {
    border-color: rgba(245, 158, 11, 0.2);
    color: #fbbf24;
  }

  /* Light mode overrides */
  :global(.light) .lang-filter-btn {
    background: rgba(15, 23, 42, 0.04);
    border-color: rgba(15, 23, 42, 0.08);
    color: #475569; /* slate-600 */
  }

  :global(.light) .lang-filter-btn.active {
    background: rgba(245, 158, 11, 0.15);
    border-color: rgba(245, 158, 11, 0.4);
    color: #b45309; /* amber-700 */
    box-shadow: 0 0 15px -3px rgba(245, 158, 11, 0.2);
  }

  :global(.light) .lang-filter-btn:hover:not(.active) {
    background: rgba(245, 158, 11, 0.06);
    border-color: rgba(245, 158, 11, 0.3);
    color: #d97706; /* amber-600 */
  }

  :global(.light) #tech-filter {
    background-color: #ffffff;
    border-color: rgba(15, 23, 42, 0.12);
    color: #0f172a;
  }

  :global(.light) #tech-filter option {
    background-color: #ffffff;
    color: #0f172a;
  }

  :global(.light) #tech-filter:focus {
    border-color: rgba(245, 158, 11, 0.6);
  }
</style>

<script>
  import { ClientListFilter } from "../../scripts/filter";

  new ClientListFilter({
    itemSelector: ".course-card",
    searchFieldSelector: "#course-search",
    searchDataAttributes: ["data-title", "data-desc", "data-goals"],
    dropdownFilters: [
      {
        selectSelector: "#tech-filter",
        dataAttribute: "data-tech",
        matchType: "exact"
      }
    ],
    buttonFilters: [
      {
        buttonSelector: ".lang-filter-btn",
        dataAttribute: "data-lang",
        defaultValue: "all",
        activeClass: "active"
      }
    ],
    noResultsSelector: "#no-courses-message"
  });
</script>
