---
import Layout from "../../../layouts/Layout.astro";
import Navbar from "../../../components/Navbar.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const modules = await getCollection("modules");
  const services = await getCollection("services");
  
  return modules.map((module) => {
    const [serviceSlug, moduleSlug] = module.id.split('/');
    const parentService = services.find((s) => s.id === serviceSlug);
    
    return {
      params: { slug: serviceSlug, moduleSlug: moduleSlug },
      props: { module, parentService },
    };
  });
}

const { module, parentService } = Astro.props;
const { Content } = await render(module);

const colorClasses = {
  blue: {
    text: 'text-brand-blue',
    border: 'border-brand-blue/20',
    bg: 'bg-brand-blue/10',
    btnBg: 'bg-brand-blue hover:bg-brand-blue/90 shadow-brand-blue/20 hover:shadow-brand-blue/30 text-gray-950 font-bold',
    glow: 'from-brand-blue to-brand-purple',
    leftBorder: 'border-brand-blue',
    glowBorder: 'rgba(59, 130, 246, 0.3)',
    glowText: '#60a5fa',
    glowShadow: 'rgba(59, 130, 246, 0.25)',
  },
  yellow: {
    text: 'text-brand-yellow',
    border: 'border-brand-yellow/20',
    bg: 'bg-brand-yellow/10',
    btnBg: 'bg-brand-yellow hover:bg-brand-yellow/90 shadow-brand-yellow/20 hover:shadow-brand-yellow/30 text-gray-950 font-bold',
    glow: 'from-brand-yellow to-brand-purple',
    leftBorder: 'border-brand-yellow',
    glowBorder: 'rgba(245, 158, 11, 0.3)',
    glowText: '#fbbf24',
    glowShadow: 'rgba(245, 158, 11, 0.25)',
  },
  purple: {
    text: 'text-brand-purple',
    border: 'border-brand-purple/20',
    bg: 'bg-brand-purple/10',
    btnBg: 'bg-brand-purple hover:bg-brand-purple/90 shadow-brand-purple/20 hover:shadow-brand-purple/30 text-gray-950 font-bold',
    glow: 'from-brand-purple to-brand-blue',
    leftBorder: 'border-brand-purple',
    glowBorder: 'rgba(168, 85, 247, 0.3)',
    glowText: '#c084fc',
    glowShadow: 'rgba(168, 85, 247, 0.25)',
  },
  green: {
    text: 'text-brand-green',
    border: 'border-brand-green/20',
    bg: 'bg-brand-green/10',
    btnBg: 'bg-brand-green hover:bg-brand-green/90 shadow-brand-green/20 hover:shadow-brand-green/30 text-gray-950 font-bold',
    glow: 'from-brand-green to-brand-blue',
    leftBorder: 'border-brand-green',
    glowBorder: 'rgba(16, 185, 129, 0.3)',
    glowText: '#34d399',
    glowShadow: 'rgba(16, 185, 129, 0.25)',
  }
}[parentService.data.color];
---

<Layout 
  title={`${module.data.title} | ${parentService.data.title} | Dr. Georg Hackenberg`} 
  description={module.data.description}
  image={module.data.previewImage?.src}
>
  <Navbar />

  <main class="flex-grow max-w-5xl mx-auto px-4 md:px-8 py-12 md:py-20 w-full relative z-10">
    <!-- Back Button -->
    <a 
      href={`/services/${parentService.id}`} 
      class="inline-flex items-center space-x-2 text-xs font-semibold px-4 py-2 rounded-xl bg-white/5 border border-white/10 hover:border-white/20 text-gray-300 hover:text-white transition-all mb-8 cursor-pointer"
    >
      <span>&larr;</span>
      <span>Back to {parentService.data.title}</span>
    </a>

    <!-- Header -->
    <header class="mb-12 pb-10 border-b border-white/5 relative">
      <div class="flex items-center gap-3 mb-4">
        <span class={`inline-flex items-center text-[10px] font-bold px-2.5 py-1 rounded border ${colorClasses.bg} ${colorClasses.text} ${colorClasses.border} uppercase tracking-wider`}>
          {parentService.data.icon} &nbsp; {module.data.badge || 'Module'} &bull; {parentService.data.category}
        </span>
      </div>
      <h1 class="text-3xl sm:text-4xl md:text-5xl font-extrabold tracking-tight text-white mb-4 leading-tight">
        {module.data.title}
      </h1>
      <p class="text-brand-yellow font-bold text-xs uppercase tracking-wider mb-2">
        {module.data.tagline}
      </p>
      <p class="text-gray-300 text-base sm:text-lg max-w-3xl leading-relaxed font-normal">
        {module.data.description}
      </p>
    </header>

    <!-- Main Content & Sidebar -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
      <!-- Left Column: Details & Methodology Flowchart -->
      <div class="lg:col-span-8 space-y-12">
        <!-- Module Text Content -->
        <section class="glass-card p-8 md:p-10 rounded-3xl border border-white/5 service-content">
          <Content />
        </section>

        <!-- HTML/CSS Methodology Timeline Section -->
        {module.data.methodologyPhases && (
          <section 
            class="glass-card p-8 md:p-10 rounded-3xl border border-white/5 space-y-8"
            style={`
              --glow-border: ${colorClasses.glowBorder};
              --glow-text: ${colorClasses.glowText};
              --glow-shadow: ${colorClasses.glowShadow};
            `}
          >
            <div class="flex items-center justify-between flex-wrap gap-4">
              <h2 class="text-xl font-extrabold text-white tracking-tight flex items-center space-x-2">
                <span>📊</span>
                <span>Our Collaboration Methodology</span>
              </h2>
              <span class={`inline-flex items-center text-[10px] font-bold px-2.5 py-1 rounded border ${colorClasses.bg} ${colorClasses.text} ${colorClasses.border} uppercase tracking-wider`}>
                4-Stage Workflow
              </span>
            </div>
            
            {module.data.methodologyDescription && (
              <p class="text-gray-400 text-xs leading-relaxed font-normal">
                {module.data.methodologyDescription}
              </p>
            )}

            {/* Timeline Diagram container */}
            <div class="relative pl-3 pr-3 sm:pl-0 sm:pr-0 sm:grid sm:grid-cols-4 gap-6 pt-4">
              {module.data.methodologyPhases.map((phase, idx) => {
                const isSignatureStep = idx === 1 || idx === 2;
                return (
                  <div class="relative flex flex-row sm:flex-col items-start sm:items-center text-left sm:text-center gap-4 sm:gap-0 sm:space-y-4 pb-8 sm:pb-0 z-10 group/phase">
                    
                    {/* Connecting line for desktop (from center of current node to center of next node) */}
                    {idx < 3 && (
                      <div class="hidden sm:block absolute sm:top-[20px] left-[50%] w-[calc(100%+1.5rem)] h-0.5 z-0 pointer-events-none">
                        <div class={`w-full h-full bg-gradient-to-r ${colorClasses.glow} opacity-30`}></div>
                      </div>
                    )}

                    {/* Connecting line for mobile (from center of current node to center of next node) */}
                    {idx < 3 && (
                      <div class="sm:hidden absolute top-[20px] left-[20px] w-0.5 h-full z-0 pointer-events-none">
                        <div class={`w-full h-full bg-gradient-to-b ${colorClasses.glow} opacity-30`}></div>
                      </div>
                    )}

                    {/* Number node */}
                    <div 
                      class={`w-10 h-10 rounded-full flex items-center justify-center font-mono font-bold text-xs border transition-all duration-300 bg-gray-950 z-10 ${
                        isSignatureStep 
                          ? 'border-transparent text-white' 
                          : 'border-white/10 text-gray-500 group-hover/phase:border-white/20 group-hover/phase:text-gray-300'
                      }`}
                      style={isSignatureStep ? 'border-color: var(--glow-border); color: var(--glow-text); box-shadow: 0 0 15px -3px var(--glow-shadow);' : ''}
                    >
                      {String(idx + 1).padStart(2, '0')}
                    </div>

                    {/* Text block */}
                    <div class="space-y-1.5 sm:px-2 flex-1">
                      <h3 class="text-xs font-bold text-white uppercase tracking-wider leading-tight">
                        {phase.title}
                      </h3>
                      <p class="text-[10px] text-gray-400 leading-relaxed font-normal">
                        {phase.description}
                      </p>
                    </div>

                  </div>
                );
              })}
            </div>

            {/* Phase specifications cards vertical stack */}
            <div class="border-t border-white/5 pt-8 mt-8 space-y-6">
              {module.data.methodologyPhases.map((phase, idx) => {
                const hasInputs = phase.inputs && phase.inputs.length > 0;
                const hasDeliverables = phase.deliverables && phase.deliverables.length > 0;
                
                return (
                  <>
                    <div class="glass-card p-6 md:p-8 rounded-2xl border border-white/5 bg-white/[0.01] relative overflow-hidden group hover:border-white/10 transition-all duration-300">
                      {/* Glow indicator at the left side */}
                      <div class={`absolute top-0 bottom-0 left-0 w-[3px] bg-gradient-to-b ${colorClasses.glow} opacity-40 group-hover:opacity-75 transition-opacity`}></div>
                      
                      <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-4 mb-4">
                        <div>
                          <p class={`text-[10px] font-bold uppercase tracking-widest ${colorClasses.text} mb-1`}>
                            Phase {String(idx + 1).padStart(2, '0')} specifications
                          </p>
                          <h3 class="text-base font-extrabold text-white tracking-tight">
                            {phase.title}
                          </h3>
                        </div>
                      </div>

                      <p class="text-xs text-gray-300 leading-relaxed mb-6 font-normal">
                         {phase.description}
                      </p>

                      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 pt-4 border-t border-white/5">
                        {/* Inputs Column */}
                        <div class="space-y-3">
                          <h4 class="text-xs font-bold text-white uppercase tracking-wider flex items-center gap-2">
                            <span class="text-sm">📥</span>
                            <span>What you provide / invest</span>
                          </h4>
                          {hasInputs ? (
                            <ul class="space-y-2">
                              {phase.inputs.map(input => (
                                <li class="text-[11px] text-gray-400 flex items-start gap-2.5 leading-relaxed font-normal">
                                  <span class="w-1.5 h-1.5 rounded-full mt-1.5 shrink-0" style="background-color: var(--glow-text)"></span>
                                  <span>{input}</span>
                                </li>
                              ))}
                            </ul>
                          ) : (
                            <p class="text-[11px] text-gray-500 italic">No specific inputs required.</p>
                          )}
                        </div>

                        {/* Deliverables Column */}
                        <div class="space-y-3">
                          <h4 class="text-xs font-bold text-white uppercase tracking-wider flex items-center gap-2">
                            <span class="text-sm">📤</span>
                            <span>What you receive / deliverables</span>
                          </h4>
                          {hasDeliverables ? (
                            <ul class="space-y-2">
                              {phase.deliverables.map(deliv => (
                                <li class="text-[11px] text-gray-300 flex items-start gap-2.5 leading-relaxed font-normal">
                                  <svg class={`w-3.5 h-3.5 mt-0.5 shrink-0 ${colorClasses.text}`} fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"></path>
                                  </svg>
                                  <span>{deliv}</span>
                                </li>
                              ))}
                            </ul>
                          ) : (
                            <p class="text-[11px] text-gray-500 italic">No direct deliverables for this stage.</p>
                          )}
                        </div>
                      </div>

                    </div>

                    {/* Sequential transition arrow */}
                    {idx < 3 && (
                      <div class="flex justify-center py-2 relative z-10">
                        <div class="w-8 h-8 rounded-full border border-white/5 bg-white/[0.02] flex items-center justify-center text-gray-500 shadow-inner">
                          <svg class={`w-4 h-4 ${colorClasses.text}`} fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m0 0l6.75-6.75M12 19.5l-6.75-6.75"></path>
                          </svg>
                        </div>
                      </div>
                    )}
                  </>
                );
              })}
            </div>
          </section>
        )}
      </div>

      {/* Right Column: Sidebar highlights & booking */}
      <div class="lg:col-span-4 space-y-8 lg:sticky lg:top-24">
        <!-- Highlights list card -->
        <div class="glass-card p-6 rounded-2xl border border-white/5 flex flex-col relative overflow-hidden">
          <div class={`absolute top-0 left-0 right-0 h-1 bg-gradient-to-r ${colorClasses.glow}`}></div>
          
          <h2 class="text-sm font-extrabold uppercase tracking-widest text-white mb-4 flex items-center space-x-2">
            <span>ℹ️</span>
            <span>Focus Areas</span>
          </h2>

          <ul class="space-y-3.5 mb-8">
            {module.data.highlights.map(item => (
              <li class="text-[11px] text-gray-300 flex items-start gap-2 leading-relaxed">
                <span class={`font-bold select-none ${colorClasses.text}`}>&bull;</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>

          <a 
            href="#contact-services"
            data-subject={`Inquiry: ${parentService.data.title} - ${module.data.title}`}
            class={`w-full py-3.5 px-4 rounded-xl text-center text-xs font-semibold shadow-lg transition-all duration-300 hover:scale-[1.02] flex items-center justify-center space-x-1.5 cursor-pointer inquiry-trigger ${colorClasses.btnBg}`}
          >
            <span>{module.data.ctaText}</span>
            <span>&rarr;</span>
          </a>
        </div>

        {/* Bundle Notice Card */}
        <div class="glass-card p-6 rounded-2xl border border-white/5 flex flex-col relative overflow-hidden bg-brand-yellow/5">
          <div class="absolute top-0 left-0 right-0 h-1 bg-brand-yellow/30"></div>
          <h2 class="text-sm font-extrabold uppercase tracking-widest text-brand-yellow mb-3 flex items-center space-x-2">
            <span>💡</span>
            <span>Bundle rate</span>
          </h2>
          <p class="text-[11px] text-gray-400 leading-relaxed mb-0">
            Combine this module with any other modules (e.g. Websites & Hosting + corporate simulations) for a custom bundle rate. Reach out below to request a tailored quote.
          </p>
        </div>
      </div>
    </div>

    <!-- Contact Section -->
    <section id="contact-services" class="py-16 mt-16 border-t border-white/5 scroll-mt-24">
      <div class="max-w-3xl mx-auto text-center mb-12">
        <span class="inline-flex items-center text-xs font-semibold px-3 py-1 rounded-full bg-brand-yellow/10 text-brand-yellow border border-brand-yellow/20 mb-4 uppercase tracking-wider">
          Let's Collaborate
        </span>
        <h2 class="text-3xl md:text-4xl font-extrabold text-white mb-4">
          Start a Conversation
        </h2>
        <p class="text-gray-400 text-sm md:text-base leading-relaxed">
          Write directly to request an inquiry about the {module.data.title} module or custom bundle options.
        </p>
      </div>

      <div class="max-w-2xl mx-auto">
        <div class="glass-card p-8 md:p-10 rounded-3xl border border-white/5 relative overflow-hidden">
          <div class="absolute top-0 left-0 right-0 h-1.5 bg-gradient-to-r from-brand-blue via-brand-purple to-brand-yellow"></div>
          
          <h2 class="text-lg font-bold text-white mb-6">Contact & Booking Inquiry</h2>
          
          <div class="space-y-6">
            <div class="flex items-start space-x-4">
              <div class="text-brand-blue mt-1.5 shrink-0">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"></path>
                </svg>
              </div>
              <div class="flex-grow flex flex-col sm:flex-row sm:items-center justify-between gap-4">
                <div>
                  <p class="text-gray-500 text-xs font-semibold uppercase tracking-wider">Send an email request to</p>
                  <p id="services-email-text" class="text-white font-mono font-medium mt-0.5 select-all text-sm sm:text-base">georg.hackenberg@fh-wels.at</p>
                </div>
                <button 
                  id="services-copy-email-btn"
                  class="px-4 py-2 text-xs font-semibold rounded-lg bg-white/5 hover:bg-white/10 text-gray-300 hover:text-white border border-white/10 hover:border-white/20 transition-all duration-200 self-start sm:self-auto flex items-center space-x-2"
                >
                  <span id="services-copy-btn-text">Copy Email</span>
                </button>
              </div>
            </div>
            
            <div class="pt-6 border-t border-white/5 flex flex-col sm:flex-row gap-4 justify-between items-center text-xs text-gray-400">
              <p>Typically responding within 2 business days.</p>
              <a 
                id="direct-mail-link"
                href={`mailto:georg.hackenberg@fh-wels.at?subject=Services%20Inquiry:%20${encodeURIComponent(parentService.data.title)}%20-%20${encodeURIComponent(module.data.title)}`}
                class="px-5 py-2.5 rounded-xl bg-brand-blue hover:bg-brand-blue/90 text-gray-950 font-bold transition-all duration-300 hover:scale-105 shadow-md shadow-brand-blue/20"
              >
                Open Email Client &rarr;
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  /* Markdown content styling for service layouts */
  .service-content :global(h2) {
    font-size: 1.25rem;
    font-weight: 800;
    color: white;
    margin-top: 1.85rem;
    margin-bottom: 0.85rem;
    letter-spacing: -0.015em;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    padding-bottom: 0.35rem;
  }
  .service-content :global(h2:first-child) {
    margin-top: 0;
  }
  .service-content :global(h3) {
    font-size: 1.05rem;
    font-weight: 700;
    color: white;
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }
  .service-content :global(p) {
    font-size: 0.875rem;
    line-height: 1.7;
    color: #cbd5e1;
    margin-bottom: 1.25rem;
  }
  .service-content :global(ul) {
    list-style-type: disc;
    padding-left: 1.25rem;
    margin-bottom: 1.25rem;
    color: #cbd5e1;
  }
  .service-content :global(li) {
    margin-bottom: 0.5rem;
    font-size: 0.875rem;
    line-height: 1.6;
  }
  .service-content :global(li strong) {
    color: white;
  }
  .service-content :global(> *:last-child) {
    margin-bottom: 0;
  }
</style>

<script>
  // Add listeners to inquiry triggers to pre-fill email client link subject
  const triggers = document.querySelectorAll('.inquiry-trigger');
  const directMailLink = document.getElementById('direct-mail-link') as HTMLAnchorElement | null;
  
  triggers.forEach(trigger => {
    trigger.addEventListener('click', () => {
      const subject = trigger.getAttribute('data-subject');
      if (directMailLink && subject) {
        directMailLink.href = `mailto:georg.hackenberg@fh-wels.at?subject=${encodeURIComponent(subject)}`;
      }
    });
  });

  // Copy Email Logic
  const copyBtn = document.getElementById('services-copy-email-btn');
  const emailText = document.getElementById('services-email-text');
  const copyBtnText = document.getElementById('services-copy-btn-text');

  if (copyBtn && emailText && copyBtnText) {
    copyBtn.addEventListener('click', () => {
      const email = emailText.textContent?.trim() || 'georg.hackenberg@fh-wels.at';
      
      navigator.clipboard.writeText(email).then(() => {
        copyBtnText.textContent = 'Copied!';
        copyBtn.classList.remove('bg-white/5', 'text-gray-300', 'border-white/10');
        copyBtn.classList.add('bg-brand-green/20', 'text-brand-green', 'border-brand-green/30');
        
        setTimeout(() => {
          copyBtnText.textContent = 'Copy Email';
          copyBtn.classList.remove('bg-brand-green/20', 'text-brand-green', 'border-brand-green/30');
          copyBtn.classList.add('bg-white/5', 'text-gray-300', 'border-white/10');
        }, 2500);
      }).catch(err => {
        console.error('Failed to copy: ', err);
      });
    });
  }
</script>
