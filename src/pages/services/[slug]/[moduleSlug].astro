---
import Layout from "../../../layouts/Layout.astro";
import Navbar from "../../../components/Navbar.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const modules = await getCollection("modules");
  const services = await getCollection("services");
  
  return modules.map((module) => {
    const [serviceSlug, moduleSlug] = module.id.split('/');
    const parentService = services.find((s) => s.id === serviceSlug);
    
    return {
      params: { slug: serviceSlug, moduleSlug: moduleSlug },
      props: { module, parentService },
    };
  });
}

const { module, parentService } = Astro.props;
const { Content } = await render(module);

const colorClasses = {
  blue: {
    text: 'text-brand-blue light:text-blue-700',
    border: 'border-brand-blue/20 light:border-blue-200',
    bg: 'bg-brand-blue/10 light:bg-blue-50/50',
    btnBg: 'bg-brand-blue hover:bg-brand-blue/90 shadow-brand-blue/20 hover:shadow-brand-blue/30 text-slate-950 font-bold light:bg-blue-600 light:hover:bg-blue-700 light:text-white',
    glow: 'from-brand-blue to-indigo-500 light:to-indigo-600',
    leftBorder: 'border-brand-blue light:border-blue-600',
    glowBorder: 'rgba(59, 130, 246, 0.3)',
    glowText: '#60a5fa',
    glowShadow: 'rgba(59, 130, 246, 0.25)',
    dot: 'bg-brand-blue shadow-[0_0_8px_rgba(59,130,246,0.8)] light:shadow-[0_0_4px_rgba(29,78,216,0.4)]',
    phaseHover: 'group-hover/phase:text-brand-blue light:group-hover/phase:text-blue-700',
  },
  yellow: {
    text: 'text-brand-yellow light:text-amber-800',
    border: 'border-brand-yellow/20 light:border-amber-200',
    bg: 'bg-brand-yellow/10 light:bg-amber-50/50',
    btnBg: 'bg-brand-yellow hover:bg-brand-yellow/90 shadow-brand-yellow/20 hover:shadow-brand-yellow/30 text-slate-950 font-bold light:bg-amber-800 light:hover:bg-amber-900 light:text-white',
    glow: 'from-brand-yellow to-orange-500 light:to-orange-600',
    leftBorder: 'border-brand-yellow light:border-amber-600',
    glowBorder: 'rgba(245, 158, 11, 0.3)',
    glowText: '#fbbf24',
    glowShadow: 'rgba(245, 158, 11, 0.25)',
    dot: 'bg-brand-yellow shadow-[0_0_8px_rgba(245,158,11,0.8)] light:shadow-[0_0_4px_rgba(180,83,9,0.4)]',
    phaseHover: 'group-hover/phase:text-brand-yellow light:group-hover/phase:text-amber-800',
  },
  purple: {
    text: 'text-brand-purple light:text-purple-700',
    border: 'border-brand-purple/20 light:border-purple-200',
    bg: 'bg-brand-purple/10 light:bg-purple-50/50',
    btnBg: 'bg-brand-purple hover:bg-brand-purple/90 shadow-brand-purple/20 hover:shadow-brand-purple/30 text-slate-950 font-bold light:bg-purple-600 light:hover:bg-purple-700 light:text-white',
    glow: 'from-brand-purple to-pink-500 light:to-pink-600',
    leftBorder: 'border-brand-purple light:border-purple-600',
    glowBorder: 'rgba(168, 85, 247, 0.3)',
    glowText: '#c084fc',
    glowShadow: 'rgba(168, 85, 247, 0.25)',
    dot: 'bg-brand-purple shadow-[0_0_8px_rgba(168,85,247,0.8)] light:shadow-[0_0_4px_rgba(126,34,206,0.4)]',
    phaseHover: 'group-hover/phase:text-brand-purple light:group-hover/phase:text-purple-700',
  },
  green: {
    text: 'text-brand-green light:text-emerald-700',
    border: 'border-brand-green/20 light:border-emerald-200',
    bg: 'bg-brand-green/10 light:bg-emerald-50/50',
    btnBg: 'bg-brand-green hover:bg-brand-green/90 shadow-brand-green/20 hover:shadow-brand-green/30 text-slate-950 font-bold light:bg-emerald-800 light:hover:bg-emerald-900 light:text-white',
    glow: 'from-brand-green to-cyan-500 light:to-cyan-600',
    leftBorder: 'border-brand-green light:border-emerald-600',
    glowBorder: 'rgba(16, 185, 129, 0.3)',
    glowText: '#34d399',
    glowShadow: 'rgba(16, 185, 129, 0.25)',
    dot: 'bg-brand-green shadow-[0_0_8px_rgba(16,185,129,0.8)] light:shadow-[0_0_4px_rgba(4,120,87,0.4)]',
    phaseHover: 'group-hover/phase:text-brand-green light:group-hover/phase:text-emerald-700',
  }
}[parentService.data.color];

---

<Layout 
  title={`${module.data.title} | ${parentService.data.title} | Dr. Georg Hackenberg`} 
  description={module.data.description}
  image={module.data.previewImage?.src}
>
  <Navbar />

  <main class="flex-grow max-w-4xl mx-auto px-4 md:px-8 py-12 md:py-20 w-full relative z-10">
    <!-- Back Button -->
    <a 
      href={`/services/${parentService.id}`} 
      class={`inline-flex items-center space-x-2 text-xs font-semibold px-4 py-2 rounded-xl bg-brand-${parentService.data.color}/10 border border-brand-${parentService.data.color}/20 hover:border-brand-${parentService.data.color}/30 text-brand-${parentService.data.color} transition-all mb-8 cursor-pointer`}
    >
      <span>&larr;</span>
      <span>Back to {parentService.data.title}</span>
    </a>

    <!-- Header -->
    <header class="mb-12 pb-10 border-b border-element-border relative">
      <h1 class="text-3xl sm:text-4xl md:text-5xl font-extrabold tracking-tight mb-4 leading-tight">
        {module.data.title}
      </h1>
      <p class={`${colorClasses.text} font-bold text-xs uppercase tracking-wider mb-2`}>
        {module.data.tagline}
      </p>
      <p class="text-gray-300 text-base sm:text-lg max-w-3xl leading-relaxed font-normal">
        {module.data.description}
      </p>
      
      <div class="flex flex-col sm:flex-row sm:items-stretch gap-6 mt-8 pt-8 border-t border-element-border">
        <a
          href="#contact-services"
          data-subject={`Inquiry: ${parentService.data.title} - ${module.data.title}`}
          class={`px-6 py-3 rounded-xl text-center text-xs font-bold shadow-md transition-all duration-300 hover:scale-[1.02] flex items-center justify-center space-x-1.5 cursor-pointer inquiry-trigger min-h-[48px] shrink-0 ${colorClasses.btnBg}`}
        >
          <span>{module.data.ctaText}</span>
          <span>&rarr;</span>
        </a>
        
        {/* Quick Specs Grid */}
        <div class="flex-grow grid grid-cols-1 sm:grid-cols-2 gap-3">
          <div class="px-4 py-2.5 rounded-xl bg-element-bg border border-element-border flex flex-col justify-center min-h-[50px] light:bg-slate-50 light:border-slate-200">
            <span class="text-[9px] font-bold text-gray-500 uppercase tracking-wider">Est. Duration</span>
            <span class="text-xs font-bold mt-0.5">
              {module.data.duration || 'Flexible Plan'}
            </span>
          </div>
          <div class="px-4 py-2.5 rounded-xl bg-element-bg border border-element-border flex flex-col justify-center min-h-[50px] light:bg-slate-50 light:border-slate-200">
            <span class="text-[9px] font-bold text-gray-500 uppercase tracking-wider">Delivery Mode</span>
            <span class="text-xs font-bold mt-0.5">
              {module.data.delivery || 'Collaborative'}
            </span>
          </div>
        </div>
      </div>
    </header>

    <!-- Main Content -->
    <div class="space-y-16">
        <!-- Module Text Content -->
        <section class={`glass-card p-8 md:p-10 rounded-3xl border border-element-border service-content theme-${parentService.data.color} prose-custom`}>
          <Content />
        </section>

        <!-- Service Scope & Key Capabilities Section -->
        <section class="space-y-4">
          <h2 class="text-xl font-extrabold tracking-tight flex items-center space-x-2">
            <span>🎯</span>
            <span>Service Scope & Key Capabilities</span>
          </h2>
          <p class="text-gray-400 text-sm leading-relaxed font-normal max-w-2xl light:text-slate-600">
            This module covers the following targeted topics and key expert competencies:
          </p>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            {module.data.highlights.map(item => (
              <div class="p-5 rounded-2xl border border-element-border bg-element-bg hover:border-element-border-medium hover:bg-element-bg-hover transition-all duration-300 flex items-start gap-3.5 group light:bg-slate-50/50 light:border-slate-200 light:hover:bg-slate-50 light:hover:border-slate-300">
                <div class="mt-[7px] shrink-0">
                  <span class={`flex w-2 h-2 rounded-full ${colorClasses.dot} transition-transform group-hover:scale-125`}></span>
                </div>
                <span class="text-xs sm:text-sm font-semibold text-gray-300 light:text-slate-800 leading-relaxed">
                  {item}
                </span>
              </div>
            ))}
          </div>
        </section>

        <!-- Engagement Requirements & Deliverables Dashboard -->
        <section class="space-y-6">
          <div class="space-y-2">
            <h2 class="text-xl font-extrabold tracking-tight flex items-center space-x-2">
              <span>📦</span>
              <span>Specifications: Inputs & Deliverables</span>
            </h2>
            <p class="text-gray-400 text-sm leading-relaxed font-normal max-w-2xl light:text-slate-600">
              A clear breakdown of the resource inputs required from your side and the concrete deliverables you will receive as the output of this service module:
            </p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            {/* Inputs Card - Required Resources */}
            <div class="glass-card p-6 md:p-8 rounded-3xl border border-element-border bg-element-bg relative overflow-hidden flex flex-col justify-between group hover:border-element-border-medium transition-all duration-300 light:bg-slate-50/30 light:border-slate-200 light:hover:border-slate-300">
              {/* Highlight Left Accent Border */}
              <div class="absolute top-0 bottom-0 left-0 w-[4px] bg-slate-500 opacity-40 group-hover:opacity-75 transition-opacity"></div>
              
              <div class="space-y-6">
                <div class="flex items-center gap-3">
                  <span class="flex items-center justify-center w-8 h-8 rounded-xl bg-element-bg border border-element-border-medium text-base light:bg-slate-100 light:border-slate-200">📥</span>
                  <div>
                    <h3 class="text-sm font-extrabold uppercase tracking-wider mt-0 mb-0.5">
                      Required Client Inputs
                    </h3>
                    <p class="text-[10px] text-gray-500 font-medium">To be provided to initiate development</p>
                  </div>
                </div>

                {module.data.inputs && module.data.inputs.length > 0 ? (
                  <ul class="space-y-3.5">
                    {module.data.inputs.map(item => (
                      <li class="text-xs text-gray-400 light:text-slate-600 flex items-start gap-3 leading-relaxed font-normal">
                        <span class="w-1.5 h-1.5 rounded-full mt-2 shrink-0 bg-gray-500 light:bg-slate-400"></span>
                        <span>{item}</span>
                      </li>
                    ))}
                  </ul>
                ) : (
                  <p class="text-xs text-gray-500 italic">No specific inputs required.</p>
                )}
              </div>
            </div>

            {/* Outputs Card - Guaranteed Deliverables */}
            <div class="glass-card p-6 md:p-8 rounded-3xl border border-element-border bg-element-bg relative overflow-hidden flex flex-col justify-between group hover:border-element-border-medium transition-all duration-300 light:bg-slate-50/50 light:border-slate-200 light:hover:border-slate-300 shadow-[0_4px_20px_rgba(0,0,0,0.2)]">
              {/* Glowing Gradient Left Accent Border */}
              <div class={`absolute top-0 bottom-0 left-0 w-[4px] bg-gradient-to-b ${colorClasses.glow} opacity-60 group-hover:opacity-100 transition-opacity`}></div>
              
              <div class="space-y-6">
                <div class="flex items-center gap-3">
                  <span class="flex items-center justify-center w-8 h-8 rounded-xl bg-element-bg border border-element-border-medium text-base light:bg-slate-100 light:border-slate-200">📤</span>
                  <div>
                    <h3 class="text-sm font-extrabold uppercase tracking-wider mt-0 mb-0.5">
                      Guaranteed Deliverables
                    </h3>
                    <p class="text-[10px] text-gray-400 light:text-slate-500 font-medium">Outcome packages included in the scope</p>
                  </div>
                </div>

                {module.data.outputs && module.data.outputs.length > 0 ? (
                  <ul class="space-y-3.5">
                    {module.data.outputs.map(item => (
                      <li class="text-xs text-gray-300 light:text-slate-800 flex items-start gap-3 leading-relaxed font-normal">
                        <svg class={`w-4 h-4 mt-0.5 shrink-0 ${colorClasses.text}`} fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"></path>
                        </svg>
                        <span class="font-medium">{item}</span>
                      </li>
                    ))}
                  </ul>
                ) : (
                  <p class="text-xs text-gray-500 italic">No direct deliverables.</p>
                )}
              </div>
            </div>
          </div>
        </section>

        <!-- Project Plan & Execution Phases Section -->
        {module.data.methodologyPhases && (
          <section 
            class="glass-card p-8 md:p-10 rounded-3xl border border-element-border space-y-8 light:bg-slate-50/20 light:border-slate-200"
            style={`
              --glow-border: ${colorClasses.glowBorder};
              --glow-text: ${colorClasses.glowText};
              --glow-shadow: ${colorClasses.glowShadow};
            `}
          >
            <div class="space-y-2">
              <h2 class="text-xl font-extrabold tracking-tight flex items-center space-x-2">
                <span>📋</span>
                <span>Project Plan & Execution Phases</span>
              </h2>
              {module.data.methodologyDescription && (
                <p class="text-gray-400 text-sm leading-relaxed font-normal light:text-slate-600">
                  {module.data.methodologyDescription}
                </p>
              )}
            </div>
            
            {/* Vertical Timeline container */}
            <div class="relative pl-8 sm:pl-10 pt-2">
              {module.data.methodologyPhases.map((phase, idx) => {
                const isFirst = idx === 0;
                const isLast = idx === module.data.methodologyPhases.length - 1;
                
                return (
                  <div class={`relative z-10 group/phase ${isLast ? '' : 'pb-8'}`}>
                    {/* Vertical Line Segment */}
                    <div 
                      class={`absolute -left-[21px] sm:-left-[25px] w-0.5 bg-gradient-to-b ${colorClasses.glow} opacity-20`}
                      style={`
                        top: ${isFirst ? '10px' : '0px'};
                        bottom: ${isLast ? 'calc(100% - 10px)' : '0px'};
                      `}
                    ></div>

                    {/* Circle Node on Timeline */}
                    <div 
                      class={`absolute -left-[32px] sm:-left-[36px] top-[-2px] w-6 h-6 rounded-full flex items-center justify-center font-mono font-bold text-[10px] border transition-all duration-300 methodology-step-node`}
                    >
                      {String(idx + 1).padStart(2, '0')}
                    </div>

                    <div class="space-y-1.5 flex-grow">
                      <h3 class={`text-xs sm:text-sm font-extrabold uppercase tracking-wider leading-tight ${colorClasses.phaseHover} transition-colors mt-0.5`}>
                        {phase.title}
                      </h3>
                      <p class="text-xs text-gray-400 leading-relaxed font-normal group-hover/phase:text-gray-300 transition-colors max-w-3xl light:text-slate-600 light:group-hover/phase:text-slate-800">
                        {phase.description}
                      </p>
                    </div>
                  </div>
                );
              })}
            </div>
          </section>
        )}
    </div>

    <!-- Contact Section -->
    <section id="contact-services" class="py-16 mt-16 border-t border-element-border scroll-mt-24">
      <div class="max-w-3xl mx-auto text-center mb-12">
        <span class={`inline-flex items-center text-xs font-semibold px-3 py-1 rounded-full ${colorClasses.bg} ${colorClasses.text} ${colorClasses.border} mb-4 uppercase tracking-wider`}>
          Let's Collaborate
        </span>
        <h2 class="text-3xl md:text-4xl font-extrabold mb-4">
          Start a Conversation
        </h2>
        <p class="text-gray-400 text-sm md:text-base leading-relaxed">
          Write directly to request an inquiry about the {module.data.title} module or custom bundle options.
        </p>
      </div>

      <div class="max-w-2xl mx-auto">
        <div class="glass-card p-8 md:p-10 rounded-3xl border border-element-border relative overflow-hidden">
          <div class={`absolute top-0 left-0 right-0 h-1.5 bg-gradient-to-r ${colorClasses.glow}`}></div>
          
          <h2 class="text-lg font-bold mb-6">Contact & Booking Inquiry</h2>
          
          <div class="space-y-6">
            <div class="flex items-start space-x-4">
              <div class={`${colorClasses.text} mt-1.5 shrink-0`}>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"></path>
                </svg>
              </div>
              <div class="flex-grow flex flex-col sm:flex-row sm:items-center justify-between gap-4">
                <div>
                  <p class="text-gray-500 text-xs font-semibold uppercase tracking-wider">Send an email request to</p>
                  <p id="services-email-text" class="font-mono font-medium mt-0.5 select-all text-sm sm:text-base">georg.hackenberg@fh-wels.at</p>
                </div>
                <button 
                  id="services-copy-email-btn"
                  class="px-4 py-2 text-xs font-semibold rounded-lg bg-element-bg hover:bg-element-bg-hover text-gray-300 hover:text-gray-100 border border-element-border-medium hover:border-element-border-hover transition-all duration-200 self-start sm:self-auto flex items-center space-x-2"
                >
                  <span id="services-copy-btn-text">Copy Email</span>
                </button>
              </div>
            </div>
            
            <div class="pt-6 border-t border-element-border flex flex-col sm:flex-row gap-4 justify-between items-center text-xs text-gray-400 mb-0">
text-gray-400">
              <p>Typically responding within 2 business days.</p>
              <a 
                id="direct-mail-link"
                href={`mailto:georg.hackenberg@fh-wels.at?subject=Services%20Inquiry:%20${encodeURIComponent(parentService.data.title)}%20-%20${encodeURIComponent(module.data.title)}`}
                class={`px-5 py-2.5 rounded-xl font-bold transition-all duration-300 hover:scale-105 shadow-md ${colorClasses.btnBg}`}
              >
                Open Email Client &rarr;
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  /* Markdown content styling for service layouts */
  .service-content :global(h2) {
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--color-text-heading);
    margin-top: 1.85rem;
    margin-bottom: 0.85rem;
    letter-spacing: -0.015em;
    border-bottom: 1px solid var(--color-border-subtle);
    padding-bottom: 0.35rem;
    transition: color 0.5s ease, border-color 0.5s ease;
  }
  .service-content :global(h2:first-child) {
    margin-top: 0;
  }
  .service-content :global(h3) {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-text-heading);
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
    transition: color 0.5s ease;
  }
  .service-content :global(p) {
    font-size: 0.875rem;
    line-height: 1.7;
    color: var(--color-text-main);
    margin-bottom: 1.25rem;
    transition: color 0.5s ease;
  }
  .service-content :global(p:first-of-type) {
    font-size: 1rem;
    font-weight: 500;
    line-height: 1.6;
    color: var(--color-text-heading);
    border-left: 3px solid var(--glow-text, #a855f7);
    padding-left: 1rem;
    margin-bottom: 1.5rem;
    transition: color 0.5s ease, border-color 0.5s ease;
  }
  .service-content :global(ul) {
    list-style-type: none;
    padding-left: 0;
    margin-bottom: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }
  .service-content :global(li) {
    margin-bottom: 0;
    font-size: 0.875rem;
    line-height: 1.6;
    background: rgba(255, 255, 255, 0.01);
    border: 1px solid rgba(255, 255, 255, 0.04);
    padding: 0.85rem 1rem;
    border-radius: 12px;
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    transition: border-color 0.2s ease, background-color 0.2s ease;
  }
  :global(.light) .service-content :global(li) {
    background: rgba(15, 23, 42, 0.02);
    border-color: rgba(15, 23, 42, 0.06);
  }
  .service-content :global(li:hover) {
    border-color: rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.03);
  }
  :global(.light) .service-content :global(li:hover) {
    background: rgba(15, 23, 42, 0.04);
    border-color: rgba(15, 23, 42, 0.1);
  }
  .service-content :global(li::before) {
    content: "→";
    color: var(--glow-text, #a855f7);
    font-weight: bold;
    flex-shrink: 0;
  }
  .service-content :global(li strong) {
    color: var(--color-text-heading);
    transition: color 0.5s ease;
  }
  .service-content :global(> *:last-child) {
    margin-bottom: 0;
  }

  .methodology-step-node {
    background-color: #020617;
    border-color: rgba(255, 255, 255, 0.1);
    color: #9ca3af;
  }

  .group\/phase:hover .methodology-step-node {
    border-color: var(--glow-text) !important;
    color: var(--glow-text) !important;
    box-shadow: 0 0 10px -3px var(--glow-shadow);
  }

  :global(.light) .methodology-step-node {
    background-color: #ffffff !important;
    border-color: rgba(15, 23, 42, 0.15) !important;
    color: #475569;
  }

  :global(.light) .group\/phase:hover .methodology-step-node {
    border-color: var(--glow-text) !important;
    color: var(--glow-text) !important;
  }

  .theme-blue {
    --glow-border: rgba(59, 130, 246, 0.3);
    --glow-text: #60a5fa;
    --glow-shadow: rgba(59, 130, 246, 0.25);
  }
  .theme-yellow {
    --glow-border: rgba(245, 158, 11, 0.3);
    --glow-text: #fbbf24;
    --glow-shadow: rgba(245, 158, 11, 0.25);
  }
  .theme-purple {
    --glow-border: rgba(168, 85, 247, 0.3);
    --glow-text: #c084fc;
    --glow-shadow: rgba(168, 85, 247, 0.25);
  }
  .theme-green {
    --glow-border: rgba(16, 185, 129, 0.3);
    --glow-text: #34d399;
