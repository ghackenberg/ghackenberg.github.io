---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";

export async function getStaticPaths() {
  const services = await getCollection("services");
  return services.map((service) => ({
    params: { slug: service.id },
    props: { service },
  }));
}

const { service } = Astro.props;
const { Content } = await render(service);

const allModules = await getCollection("modules");
const serviceModules = allModules
  .filter((m) => m.data.serviceId === service.id)
  .sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));

const colorClasses = {
  blue: {
    text: 'text-brand-blue',
    border: 'border-brand-blue/20',
    bg: 'bg-brand-blue/10',
    btnBg: 'bg-brand-blue hover:bg-brand-blue/90 shadow-brand-blue/20 hover:shadow-brand-blue/30 text-gray-950 font-bold',
    hoverText: 'hover:text-brand-blue',
    glow: 'from-brand-blue to-brand-purple',
    leftBorder: 'border-brand-blue',
    dot: 'bg-brand-blue shadow-[0_0_8px_rgba(59,130,246,0.8)]'
  },
  yellow: {
    text: 'text-brand-yellow',
    border: 'border-brand-yellow/20',
    bg: 'bg-brand-yellow/10',
    btnBg: 'bg-brand-yellow hover:bg-brand-yellow/90 shadow-brand-yellow/20 hover:shadow-brand-yellow/30 text-gray-950 font-bold',
    hoverText: 'hover:text-brand-yellow',
    glow: 'from-brand-yellow to-brand-purple',
    leftBorder: 'border-brand-yellow',
    dot: 'bg-brand-yellow shadow-[0_0_8px_rgba(245,158,11,0.8)]'
  },
  purple: {
    text: 'text-brand-purple',
    border: 'border-brand-purple/20',
    bg: 'bg-brand-purple/10',
    btnBg: 'bg-brand-purple hover:bg-brand-purple/90 shadow-brand-purple/20 hover:shadow-brand-purple/30 text-gray-950 font-bold',
    hoverText: 'hover:text-brand-purple',
    glow: 'from-brand-purple to-brand-blue',
    leftBorder: 'border-brand-purple',
    dot: 'bg-brand-purple shadow-[0_0_8px_rgba(168,85,247,0.8)]'
  },
  green: {
    text: 'text-brand-green',
    border: 'border-brand-green/20',
    bg: 'bg-brand-green/10',
    btnBg: 'bg-brand-green hover:bg-brand-green/90 shadow-brand-green/20 hover:shadow-brand-green/30 text-gray-950 font-bold',
    hoverText: 'hover:text-brand-green',
    glow: 'from-brand-green to-brand-blue',
    leftBorder: 'border-brand-green',
    dot: 'bg-brand-green shadow-[0_0_8px_rgba(16,185,129,0.8)]'
  }
}[service.data.color];
---

<Layout 
  title={`${service.data.title} | Professional Services | Dr. Georg Hackenberg`} 
  description={service.data.description}
  image={service.data.previewImage?.src}
>
  <Navbar />

  <main class="flex-grow max-w-5xl mx-auto px-4 md:px-8 py-12 md:py-20 w-full relative z-10">
    <!-- Back Button -->
    <a 
      href="/services" 
      class="inline-flex items-center space-x-2 text-xs font-semibold px-4 py-2 rounded-xl bg-white/5 border border-white/10 hover:border-white/20 text-gray-300 hover:text-white transition-all mb-8 cursor-pointer"
    >
      <span>&larr;</span>
      <span>Back to Services</span>
    </a>

    <!-- Header -->
    <header class="mb-12 pb-10 border-b border-white/5 relative">
      <div class="flex items-center gap-3 mb-4">
        <span class={`inline-flex items-center text-[10px] font-bold px-2.5 py-1 rounded border ${colorClasses.bg} ${colorClasses.text} ${colorClasses.border} uppercase tracking-wider`}>
          {service.data.icon} &nbsp; {service.data.category}
        </span>
      </div>
      <h1 class="text-3xl sm:text-4xl md:text-5xl font-extrabold tracking-tight text-white mb-4 leading-tight">
        {service.data.title}
      </h1>
      <p class="text-brand-yellow font-bold text-xs uppercase tracking-wider mb-2">
        {service.data.tagline}
      </p>
      <p class="text-gray-300 text-base sm:text-lg max-w-3xl leading-relaxed font-normal">
        {service.data.description}
      </p>
    </header>

    <!-- Main Content & Sidebar -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
      <!-- Left Column: Service details and Modules List -->
      <div class="lg:col-span-8 space-y-12">
        <!-- Service Text -->
        <section class="glass-card p-8 md:p-10 rounded-3xl border border-white/5 service-content">
          <Content />
        </section>

        <!-- Service Modules Section -->
        <section class="space-y-6">
          <div class="flex items-center justify-between flex-wrap gap-4">
            <h2 class="text-2xl font-extrabold text-white tracking-tight flex items-center space-x-2">
              <span>📦</span>
              <span>Available Service Modules</span>
            </h2>
            <span class={`inline-flex items-center text-[10px] font-bold px-2.5 py-1 rounded border ${colorClasses.bg} ${colorClasses.text} ${colorClasses.border} uppercase tracking-wider`}>
              Modular Selection
            </span>
          </div>
          
          <p class="text-gray-400 text-sm leading-relaxed font-normal">
            Each service module represents a concrete building block that can be booked individually or combined into a comprehensive custom package.
          </p>

          <div class="space-y-6">
            {serviceModules.map((module) => {
              const moduleSlug = module.id.split('/').pop();
              return (
                <a 
                  href={`/services/${service.id}/${moduleSlug}`}
                  class="glass-card rounded-2xl border border-white/5 relative overflow-hidden flex flex-col sm:grid sm:grid-cols-12 items-stretch p-0 hover:border-white/10 transition-colors group cursor-pointer block no-underline"
                >
                  {/* Accent bar */}
                  <div class={`absolute top-0 left-0 right-0 h-1 bg-gradient-to-r ${colorClasses.glow} z-20`}></div>
                  
                  <!-- Info Column -->
                  <div class="p-6 sm:p-8 sm:col-span-8 flex flex-col justify-center space-y-4 relative z-10 text-left">
                    <div class="flex items-center justify-between gap-3">
                      <h3 class="text-lg font-bold text-white uppercase tracking-wider leading-none mt-0 flex items-center gap-2">
                        <span>{module.data.title}</span>
                        <span 
                          class={`unread-dot hidden w-2 h-2 rounded-full ${colorClasses.dot}`}
                          data-item-url={`/services/${service.id}/${moduleSlug}`}
                          title="Unread module"
                        ></span>
                      </h3>
                      {module.data.badge && (
                        <span class={`text-[9px] px-2 py-0.5 rounded-full font-mono font-medium ${colorClasses.bg} ${colorClasses.text} border ${colorClasses.border}`}>
                          {module.data.badge}
                        </span>
                      )}
                    </div>
                    <p class="text-brand-yellow font-bold text-[10px] uppercase tracking-wider leading-none">
                      {module.data.tagline}
                    </p>
                    <p class="text-gray-400 text-xs leading-relaxed font-normal">
                      {module.data.description}
                    </p>
                    <div>
                      <span 
                        class={`inline-flex items-center space-x-1.5 text-xs font-semibold px-4 py-2 rounded-lg bg-white/5 border border-white/10 text-white group-hover:bg-white/10 group-hover:border-white/20 transition-all`}
                      >
                        <span>Explore Module & Methodology</span>
                        <span>&rarr;</span>
                      </span>
                    </div>
                  </div>

                  {/* Preview Image Column */}
                  <div class="sm:col-span-4 relative min-h-[160px] sm:min-h-full w-full overflow-hidden bg-gray-950/40">
                    {module.data.previewImage && (
                      <Image 
                        src={module.data.previewImage} 
                        alt={`${module.data.title} preview`}
                        width={480}
                        height={320}
                        class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 will-change-transform"
                      />
                    )}
                    <div class="absolute inset-0 bg-gradient-to-t sm:bg-gradient-to-l from-gray-950/40 via-transparent to-transparent pointer-events-none"></div>
                  </div>
                </a>
              );
            })}
          </div>
        </section>
      </div>

      <!-- Right Column: Sidebar modules quick links & Bundle CTA -->
      <div class="lg:col-span-4 space-y-8 lg:sticky lg:top-24">
        <!-- Service Modules Quick Links -->
        <div class="glass-card p-6 rounded-2xl border border-white/5 flex flex-col relative overflow-hidden">
          <div class={`absolute top-0 left-0 right-0 h-1 bg-gradient-to-r ${colorClasses.glow}`}></div>
          
          <h3 class="text-sm font-extrabold uppercase tracking-widest text-white mb-4 flex items-center space-x-2">
            <span>📦</span>
            <span>Modules</span>
          </h3>

          <ul class="space-y-3.5 mb-6">
            {serviceModules.map(module => {
              const moduleSlug = module.id.split('/').pop();
              return (
                <li class="text-[11px] text-gray-300 leading-relaxed">
                  <a 
                    href={`/services/${service.id}/${moduleSlug}`}
                    class={`flex items-center space-x-2 hover:text-white transition-colors`}
                  >
                    <span class={`font-bold select-none ${colorClasses.text}`}>&bull;</span>
                    <span>{module.data.title}</span>
                    <span 
                      class={`unread-dot hidden w-1.5 h-1.5 rounded-full ${colorClasses.dot}`}
                      data-item-url={`/services/${service.id}/${moduleSlug}`}
                      title="Unread module"
                    ></span>
                  </a>
                </li>
              );
            })}
          </ul>

          <a 
            href="#contact-services"
            data-subject={`Inquiry: ${service.data.title}`}
            class={`w-full py-3 px-4 rounded-xl text-center text-xs font-semibold shadow-lg transition-all duration-300 hover:scale-[1.02] flex items-center justify-center space-x-1.5 cursor-pointer inquiry-trigger ${colorClasses.btnBg}`}
          >
            <span>{service.data.ctaText}</span>
            <span>&rarr;</span>
          </a>
        </div>

        {/* Bundle Notice Card */}
        <div class="glass-card p-6 rounded-2xl border border-white/5 flex flex-col relative overflow-hidden bg-brand-yellow/5">
          <div class="absolute top-0 left-0 right-0 h-1 bg-brand-yellow/30"></div>
          <h3 class="text-sm font-extrabold uppercase tracking-widest text-brand-yellow mb-3 flex items-center space-x-2">
            <span>💡</span>
            <span>Bundle rate</span>
          </h3>
          <p class="text-[11px] text-gray-400 leading-relaxed mb-0">
            Combine two or more modules across any services for a unified project delivery and a bundle discount rate. Reach out in the contact form to discuss a custom arrangement.
          </p>
        </div>
      </div>
    </div>

    <!-- Contact & Booking Section -->
    <section id="contact-services" class="py-16 mt-16 border-t border-white/5 scroll-mt-24">
      <div class="max-w-3xl mx-auto text-center mb-12">
        <span class="inline-flex items-center text-xs font-semibold px-3 py-1 rounded-full bg-brand-yellow/10 text-brand-yellow border border-brand-yellow/20 mb-4 uppercase tracking-wider">
          Let's Collaborate
        </span>
        <h2 class="text-3xl md:text-4xl font-extrabold text-white mb-4">
          Start a Conversation
        </h2>
        <p class="text-gray-400 text-sm md:text-base leading-relaxed">
          Write directly to discuss custom setups, corporate workshops, strategic advisory, or media publishing.
        </p>
      </div>

      <div class="max-w-2xl mx-auto">
        <div class="glass-card p-8 md:p-10 rounded-3xl border border-white/5 relative overflow-hidden">
          <div class="absolute top-0 left-0 right-0 h-1.5 bg-gradient-to-r from-brand-blue via-brand-purple to-brand-yellow"></div>
          
          <h3 class="text-lg font-bold text-white mb-6">Contact & Booking Inquiry</h3>
          
          <div class="space-y-6">
            <div class="flex items-start space-x-4">
              <div class="text-brand-blue mt-1.5 shrink-0">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"></path>
                </svg>
              </div>
              <div class="flex-grow flex flex-col sm:flex-row sm:items-center justify-between gap-4">
                <div>
                  <p class="text-gray-500 text-xs font-semibold uppercase tracking-wider">Send an email request to</p>
                  <p id="services-email-text" class="text-white font-mono font-medium mt-0.5 select-all text-sm sm:text-base">georg.hackenberg@fh-wels.at</p>
                </div>
                <button 
                  id="services-copy-email-btn"
                  class="px-4 py-2 text-xs font-semibold rounded-lg bg-white/5 hover:bg-white/10 text-gray-300 hover:text-white border border-white/10 hover:border-white/20 transition-all duration-200 self-start sm:self-auto flex items-center space-x-2"
                >
                  <span id="services-copy-btn-text">Copy Email</span>
                </button>
              </div>
            </div>
            
            <div class="pt-6 border-t border-white/5 flex flex-col sm:flex-row gap-4 justify-between items-center text-xs text-gray-400">
              <p>Typically responding within 2 business days.</p>
              <a 
                id="direct-mail-link"
                href={`mailto:georg.hackenberg@fh-wels.at?subject=Services%20Inquiry:%20${encodeURIComponent(service.data.title)}`}
                class="px-5 py-2.5 rounded-xl bg-brand-blue hover:bg-brand-blue/90 text-gray-950 font-bold transition-all duration-300 hover:scale-105 shadow-md shadow-brand-blue/20"
              >
                Open Email Client &rarr;
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  /* Markdown content styling for service layouts */
  .service-content :global(h2) {
    font-size: 1.25rem;
    font-weight: 800;
    color: white;
    margin-top: 1.85rem;
    margin-bottom: 0.85rem;
    letter-spacing: -0.015em;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    padding-bottom: 0.35rem;
  }
  .service-content :global(h2:first-child) {
    margin-top: 0;
  }
  .service-content :global(h3) {
    font-size: 1.05rem;
    font-weight: 700;
    color: white;
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }
  .service-content :global(p) {
    font-size: 0.875rem;
    line-height: 1.7;
    color: #cbd5e1; /* slate-300 for premium contrast */
    margin-bottom: 1.25rem;
  }
  .service-content :global(ul) {
    list-style-type: disc;
    padding-left: 1.25rem;
    margin-bottom: 1.25rem;
    color: #cbd5e1;
  }
  .service-content :global(li) {
    margin-bottom: 0.5rem;
    font-size: 0.875rem;
    line-height: 1.6;
  }
  .service-content :global(li strong) {
    color: white;
  }
  .service-content :global(> *:last-child) {
    margin-bottom: 0;
  }
</style>

<script>
  // Add listeners to inquiry triggers to pre-fill email client link subject
  const triggers = document.querySelectorAll('.inquiry-trigger');
  const directMailLink = document.getElementById('direct-mail-link') as HTMLAnchorElement | null;
  
  triggers.forEach(trigger => {
    trigger.addEventListener('click', () => {
      const subject = trigger.getAttribute('data-subject');
      if (directMailLink && subject) {
        directMailLink.href = `mailto:georg.hackenberg@fh-wels.at?subject=${encodeURIComponent(subject)}`;
      }
    });
  });

  // Copy Email Logic
  const copyBtn = document.getElementById('services-copy-email-btn');
  const emailText = document.getElementById('services-email-text');
  const copyBtnText = document.getElementById('services-copy-btn-text');

  if (copyBtn && emailText && copyBtnText) {
    copyBtn.addEventListener('click', () => {
      const email = emailText.textContent?.trim() || 'georg.hackenberg@fh-wels.at';
      
      navigator.clipboard.writeText(email).then(() => {
        copyBtnText.textContent = 'Copied!';
        copyBtn.classList.remove('bg-white/5', 'text-gray-300', 'border-white/10');
        copyBtn.classList.add('bg-brand-green/20', 'text-brand-green', 'border-brand-green/30');
        
        setTimeout(() => {
          copyBtnText.textContent = 'Copy Email';
          copyBtn.classList.remove('bg-brand-green/20', 'text-brand-green', 'border-brand-green/30');
          copyBtn.classList.add('bg-white/5', 'text-gray-300', 'border-white/10');
        }, 2500);
      }).catch(err => {
        console.error('Failed to copy: ', err);
      });
    });
  }
</script>
