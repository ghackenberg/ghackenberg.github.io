---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import { getCollection, getEntry, render } from "astro:content";
import { getImage } from "astro:assets";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);

const optimizedMainScreenshot = project.data.screenshot ? await getImage({
  src: project.data.screenshot,
  format: 'webp',
  width: 1200,
  quality: 85
}) : null;

const optimizedScreenshots = await Promise.all(
  (project.data.screenshots || []).map(async (shot) => {
    const opt = await getImage({
      src: shot.image,
      format: 'webp',
      width: 1000,
      quality: 85
    });
    return {
      src: opt.src,
      title: shot.title,
      description: shot.description
    };
  })
);

let repo = null;
let repoNameId = "";
const repoName = project.data.repoName;
if (repoName) {
  const repos = await getCollection("github-repos");
  const repoEntry = repos.find(r => r.id.toLowerCase() === repoName.toLowerCase());
  if (repoEntry) {
    repo = repoEntry.data;
    repoNameId = repoEntry.id;
  }
}

// Language colors for GitHub stats
const languageColors: Record<string, string> = {
  TypeScript: "bg-blue-400",
  JavaScript: "bg-yellow-400",
  HTML: "bg-orange-500",
  CSS: "bg-purple-400",
  Astro: "bg-rose-500",
  Python: "bg-blue-500",
  Vue: "bg-emerald-500",
  React: "bg-sky-400",
  C: "bg-gray-400",
  "C++": "bg-pink-500",
  Java: "bg-red-400",
  "C#": "bg-violet-500",
  TeX: "bg-emerald-600",
  Mermaid: "bg-teal-400",
  "Jupyter Notebook": "bg-amber-600"
};

const accentColor = project.data.accentColor || 'blue';

// Dynamically assign styling tokens matching the Strategic Focus Areas
const colorClasses = {
  blue: {
    text: 'text-brand-blue',
    border: 'border-brand-blue/20',
    bg: 'bg-brand-blue/10',
    btnBg: 'bg-brand-blue hover:bg-brand-blue/90 shadow-brand-blue/20 hover:shadow-brand-blue/30 text-slate-950 font-bold light:bg-blue-600 light:hover:bg-blue-700 light:text-white',
    hoverText: 'hover:text-brand-blue',
    glow: 'from-brand-blue to-indigo-500 light:to-indigo-600'
  },
  yellow: {
    text: 'text-brand-yellow',
    border: 'border-brand-yellow/20',
    bg: 'bg-brand-yellow/10',
    btnBg: 'bg-brand-yellow hover:bg-brand-yellow/90 shadow-brand-yellow/20 hover:shadow-brand-yellow/30 text-slate-950 font-bold light:bg-amber-800 light:hover:bg-amber-900 light:text-white',
    hoverText: 'hover:text-brand-yellow',
    glow: 'from-brand-yellow to-orange-500 light:to-orange-600'
  },
  purple: {
    text: 'text-brand-purple',
    border: 'border-brand-purple/20',
    bg: 'bg-brand-purple/10',
    btnBg: 'bg-brand-purple hover:bg-brand-purple/90 shadow-brand-purple/20 hover:shadow-brand-purple/30 text-slate-950 font-bold light:bg-purple-600 light:hover:bg-purple-700 light:text-white',
    hoverText: 'hover:text-brand-purple',
    glow: 'from-brand-purple to-pink-500 light:to-pink-600'
  },
  green: {
    text: 'text-brand-green',
    border: 'border-brand-green/20',
    bg: 'bg-brand-green/10',
    btnBg: 'bg-brand-green hover:bg-brand-green/90 shadow-brand-green/20 hover:shadow-brand-green/30 text-slate-950 font-bold light:bg-emerald-800 light:hover:bg-emerald-900 light:text-white',
    hoverText: 'hover:text-brand-green',
    glow: 'from-brand-green to-cyan-500 light:to-cyan-600'
  }
}[accentColor];

const tech = repo?.language ?? "Web";
const starCount = repo?.stars ?? 0;
const lastUpdated = repo?.pushDate;
const formattedDate = lastUpdated 
  ? new Date(lastUpdated).toLocaleDateString("en-US", { year: 'numeric', month: 'short', day: 'numeric' })
  : "";
---

<Layout 
  title={`${project.data.title} | Software Projects | Dr. Georg Hackenberg`} 
  description={project.data.description}
  image={optimizedMainScreenshot?.src}
>
  <Navbar />

  <main class="flex-grow max-w-5xl mx-auto px-4 md:px-8 py-12 md:py-20 w-full relative z-10">
    <!-- Back Button -->
    <a 
      href="/projects" 
      class={`inline-flex items-center space-x-2 text-xs font-semibold px-4 py-2 rounded-xl bg-brand-${accentColor}/10 border border-brand-${accentColor}/20 hover:border-brand-${accentColor}/30 text-brand-${accentColor} transition-all mb-8 cursor-pointer`}
    >
      <span>&larr;</span>
      <span>Back to Projects</span>
    </a>

    <!-- Title Header -->
    <header class="mb-12 pb-10 border-b border-element-border relative">
      <h1 class="text-3xl sm:text-4xl md:text-5xl font-extrabold tracking-tight mb-4 leading-tight">
        {project.data.title}
      </h1>
      <p class="text-gray-300 text-base sm:text-lg max-w-3xl leading-relaxed font-normal">
        {project.data.description}
      </p>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
      <!-- Main Content (Column 1 - Project details & Markdown text) -->
      <div class="lg:col-span-8 space-y-12">
        <!-- Detail / Content block -->
        <section class="glass-card p-8 md:p-10 rounded-3xl border border-element-border project-content prose-custom">
          <h2 class="text-xl font-bold mb-6 tracking-tight flex items-center space-x-2">
            <span>🚀</span>
            <span>Project Details & Focus</span>
          </h2>
          
          <!-- Render markdown body if there is one; otherwise show tagline description -->
          {project.body ? (
            <Content />
          ) : (
            <div class="space-y-4">
              <p>
                {project.data.title} is a dedicated solution designed with the core principles of reliability, usability, and modern architecture. It addresses critical needs in {project.data.tags.slice(0, 3).join(", ").toLowerCase()} systems.
              </p>
              <h3 class="font-bold mt-6 mb-2">Key Areas of Focus:</h3>
              <ul class="list-disc pl-5 space-y-2 text-gray-400">
                {project.data.tags.map(tag => (
                  <li><strong>{tag}</strong>: Implementation of standards, optimized performance, and interdisciplinary support.</li>
                ))}
              </ul>
            </div>
          )}
        </section>

        <!-- Screenshots Gallery Section -->
        {optimizedScreenshots && optimizedScreenshots.length > 0 && (
          <section class="space-y-6">
            <h2 class="text-2xl font-bold tracking-tight flex items-center space-x-2.5">
              <span>📸</span>
              <span>Screenshots & Interface</span>
            </h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              {optimizedScreenshots.map((shot, index) => (
                <div 
                  class={`glass-card rounded-2xl border border-element-border overflow-hidden group cursor-pointer relative transition-all duration-300 hover:scale-[1.02] hover:border-brand-${accentColor}/30 hover:shadow-lg hover:shadow-brand-${accentColor}/5 flex flex-col`}
                  data-screenshot-index={index}
                >
                  <!-- Image Area -->
                  <div class="aspect-video w-full overflow-hidden relative bg-black/40">
                    <img 
                      src={shot.src} 
                      alt={shot.title} 
                      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                      loading="lazy"
                    />
                    <!-- Hover Zoom Indicator -->
                    <div class="absolute inset-0 bg-black/50 backdrop-blur-[2px] opacity-0 group-hover:opacity-100 transition-all duration-300 flex items-center justify-center">
                      <div class="p-3 rounded-full bg-white/10 border border-white/20 text-white transform scale-90 group-hover:scale-100 transition-transform duration-300">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.604 10.604zM10.5 7.5v6m3-3h-6"></path>
                        </svg>
                      </div>
                    </div>
                  </div>
                  <!-- Title & Description Area -->
                  <div class="p-5 border-t border-element-border flex-grow flex flex-col justify-between">
                    <div>
                      <h3 class="font-bold text-sm text-gray-100 light:text-gray-100 mb-1 group-hover:text-white light:group-hover:text-gray-50 transition-colors font-sans">
                        {shot.title}
                      </h3>
                      {shot.description && (
                        <p class="text-xs text-gray-400 line-clamp-2 leading-relaxed font-sans">
                          {shot.description}
                        </p>
                      )}
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </section>
        )}
      </div>

      <!-- Sidebar Metadata & GitHub Repo (Column 2) -->
      <div class="lg:col-span-4 space-y-8 lg:sticky lg:top-24">
        <!-- Project Actions & Info Card -->
        <div class="glass-card p-6 rounded-2xl border border-element-border flex flex-col relative overflow-hidden">
          <div class={`absolute top-0 left-0 right-0 h-1 bg-gradient-to-r ${colorClasses.glow}`}></div>
          
          <h3 class="text-lg font-bold mb-4 flex items-center space-x-2">
            <span>ℹ️</span>
            <span>Project Info</span>
          </h3>

          <div class="mb-6 space-y-4">
            <div>
              <p class="text-[10px] text-gray-500 font-extrabold uppercase tracking-widest mb-1.5">Project Type</p>
              <div class="flex flex-wrap gap-1.5">
                {project.data.tags.map(tag => (
                  <span class={`text-[10px] px-2.5 py-0.5 rounded-full border ${colorClasses.bg} ${colorClasses.text} ${colorClasses.border} font-medium`}>
                    {tag}
                  </span>
                ))}
              </div>
            </div>
          </div>

          <a 
            href={project.data.href}
            target="_blank"
            rel="noopener noreferrer"
            class={`w-full py-3.5 px-4 rounded-xl text-center text-sm transition-all duration-300 hover:scale-[1.02] flex items-center justify-center space-x-2 cursor-pointer ${colorClasses.btnBg}`}
          >
            <span>Visit Website</span>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"></path>
            </svg>
          </a>
        </div>

        <!-- Linked GitHub Repository Card (if available) -->
        {repo ? (
          <div class="glass-card p-6 rounded-2xl border border-element-border flex flex-col group overflow-hidden relative">
            <div class={`absolute top-0 left-0 right-0 h-1 bg-brand-${accentColor} opacity-60`}></div>
            
            <h3 class="text-lg font-bold mb-4 flex items-center space-x-2">
              <svg class={`w-5 h-5 text-brand-${accentColor} shrink-0`} fill="currentColor" viewBox="0 0 24 24">
                <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
              </svg>
              <span>GitHub Repo</span>
            </h3>

            <p class="text-sm font-mono font-bold break-all leading-tight mb-2">
              {repoNameId}
            </p>
            
            <p class="text-gray-400 text-xs leading-normal mb-4 line-clamp-3">
              {repo.description}
            </p>

            <div class="space-y-2.5 border-t border-element-border pt-3.5 mb-4 text-xs text-gray-400">
              <div class="flex items-center justify-between">
                <span>Language:</span>
                <div class="flex items-center space-x-1.5">
                  <span class={`w-2.5 h-2.5 rounded-full ${languageColors[tech] || 'bg-gray-400'}`}></span>
                  <span class="font-semibold">{tech}</span>
                </div>
              </div>
              {starCount > 0 && (
                <div class="flex items-center justify-between">
                  <span>Stars:</span>
                  <span class="font-semibold">⭐ {starCount}</span>
                </div>
              )}
              {formattedDate && (
                <div class="flex items-center justify-between">
                  <span>Last Active:</span>
                  <span class="font-medium">{formattedDate}</span>
                </div>
              )}
            </div>

            <div class="border-t border-element-border pt-4 mt-auto">
              <a 
                href={repo.url}
                target="_blank"
                rel="noopener noreferrer"
                class={`inline-flex items-center text-sm font-bold transition-colors group/link cursor-pointer ${colorClasses.text} ${colorClasses.hoverText}`}
              >
                <span>Explore Repository</span>
                <svg class="w-4 h-4 ml-1.5 transform group-hover/link:translate-x-1 transition-transform duration-300" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"></path>
                </svg>
              </a>
            </div>
          </div>
        ) : (
          <div class="glass-card p-6 rounded-2xl border border-element-border text-center text-xs text-gray-500 py-8">
            ⚠️ Synced repository info not available.
          </div>
        )}
      </div>
    </div>
  </main>

  <!-- Lightbox Modal -->
  <div 
    id="lightbox-modal" 
    class="fixed inset-0 z-50 flex flex-col justify-between p-4 md:p-8 bg-black/95 backdrop-blur-md opacity-0 pointer-events-none transition-opacity duration-300 hidden"
    role="dialog"
    aria-modal="true"
  >
    <!-- Top bar (Close button & counter) -->
    <div class="flex justify-between items-center w-full z-10">
      <div id="lightbox-counter" class="text-xs font-mono text-gray-400">
        0 / 0
      </div>
      <button 
        id="lightbox-close" 
        class="p-2.5 rounded-full bg-white/5 border border-white/10 text-gray-400 hover:text-white hover:bg-white/10 transition-all cursor-pointer"
        aria-label="Close lightbox"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>

    <!-- Main View Area (Image container) -->
    <div class="flex items-center justify-center flex-grow w-full my-2 relative overflow-hidden">
      <div class="w-full h-full flex items-center justify-center select-none">
        <img 
          id="lightbox-image" 
          src="" 
          alt="" 
          class="max-w-[72vw] sm:max-w-[85vw] max-h-[60vh] md:max-h-[70vh] object-contain rounded-lg shadow-2xl scale-95 opacity-0 transition-all duration-300"
        />
      </div>
    </div>

    <!-- Navigation Buttons (Absolute children of the modal) -->
    <!-- Prev Button -->
    <button 
      id="lightbox-prev" 
      class="absolute left-4 md:left-8 top-1/2 -translate-y-1/2 z-30 p-3 rounded-full bg-black/60 hover:bg-black/80 md:bg-white/5 border border-white/10 text-gray-400 hover:text-white hover:bg-white/10 transition-all cursor-pointer"
      aria-label="Previous image"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5"></path>
      </svg>
    </button>

    <!-- Next Button -->
    <button 
      id="lightbox-next" 
      class="absolute right-4 md:right-8 top-1/2 -translate-y-1/2 z-30 p-3 rounded-full bg-black/60 hover:bg-black/80 md:bg-white/5 border border-white/10 text-gray-400 hover:text-white hover:bg-white/10 transition-all cursor-pointer"
      aria-label="Next image"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"></path>
      </svg>
    </button>

    <!-- Bottom Captions Area -->
    <div class="w-full text-center max-w-2xl mx-auto z-10 pb-4">
      <h4 id="lightbox-title" class="text-base md:text-lg font-bold mb-1 font-sans"></h4>
      <p id="lightbox-desc" class="text-xs md:text-sm text-gray-400 max-h-20 overflow-y-auto font-sans"></p>
    </div>
  </div>
</Layout>

<script define:vars={{ optimizedScreenshots }}>
  document.addEventListener("DOMContentLoaded", () => {
    let currentIndex = 0;
    const modal = document.getElementById("lightbox-modal");
    const img = document.getElementById("lightbox-image");
    const title = document.getElementById("lightbox-title");
    const desc = document.getElementById("lightbox-desc");
    const counter = document.getElementById("lightbox-counter");
    const closeBtn = document.getElementById("lightbox-close");
    const prevBtn = document.getElementById("lightbox-prev");
    const nextBtn = document.getElementById("lightbox-next");

    if (!modal || !img || !optimizedScreenshots || optimizedScreenshots.length === 0) return;

    function openLightbox(index) {
      currentIndex = index;
      updateLightbox();
      modal.classList.remove("hidden");
      setTimeout(() => {
        modal.classList.remove("opacity-0", "pointer-events-none");
        modal.classList.add("opacity-100", "pointer-events-auto");
      }, 10);
      document.body.style.overflow = "hidden";
    }

    function closeLightbox() {
      modal.classList.remove("opacity-100", "pointer-events-auto");
      modal.classList.add("opacity-0", "pointer-events-none");
      document.body.style.overflow = "";
      setTimeout(() => {
        modal.classList.add("hidden");
        img.src = "";
        img.classList.remove("scale-100", "opacity-100");
        img.classList.add("scale-95", "opacity-0");
      }, 300);
    }

    function updateLightbox() {
      const current = optimizedScreenshots[currentIndex];
      if (!current) return;

      img.classList.remove("scale-100", "opacity-100");
      img.classList.add("scale-95", "opacity-0");

      setTimeout(() => {
        img.src = current.src;
        img.alt = current.title;
        title.textContent = current.title;
        desc.textContent = current.description || "";
        counter.textContent = `${currentIndex + 1} / ${optimizedScreenshots.length}`;

        setTimeout(() => {
          img.classList.remove("scale-95", "opacity-0");
          img.classList.add("scale-100", "opacity-100");
        }, 50);
      }, 150);
    }

    function prevImage() {
      currentIndex = (currentIndex - 1 + optimizedScreenshots.length) % optimizedScreenshots.length;
      updateLightbox();
    }

    function nextImage() {
      currentIndex = (currentIndex + 1) % optimizedScreenshots.length;
      updateLightbox();
    }

    document.querySelectorAll("[data-screenshot-index]").forEach(card => {
      card.addEventListener("click", () => {
        const index = parseInt(card.getAttribute("data-screenshot-index") || "0", 10);
        openLightbox(index);
      });
    });

    closeBtn.addEventListener("click", closeLightbox);
    prevBtn.addEventListener("click", (e) => { e.stopPropagation(); prevImage(); });
    nextBtn.addEventListener("click", (e) => { e.stopPropagation(); nextImage(); });

    document.addEventListener("keydown", (e) => {
      if (modal.classList.contains("hidden")) return;
      if (e.key === "Escape") closeLightbox();
      else if (e.key === "ArrowLeft") prevImage();
      else if (e.key === "ArrowRight") nextImage();
    });

    modal.addEventListener("click", (e) => {
      if (!e.target.closest("img") && !e.target.closest("button") && !e.target.closest("#lightbox-desc")) {
        closeLightbox();
      }
    });
  });
</script>

<style>
  /* Markdown content layout styling */
  .project-content :global(h2) {
    font-size: 1.25rem;
    font-weight: 850;
    color: var(--color-text-heading);
    margin-top: 2.25rem;
    margin-bottom: 1.25rem;
    letter-spacing: -0.025em;
    border-bottom: 1px solid var(--color-border-subtle);
    padding-bottom: 0.5rem;
    transition: color 0.5s ease, border-color 0.5s ease;
  }
  .project-content :global(h2:first-child) {
    margin-top: 0;
  }
  .project-content :global(h3) {
    font-size: 1.1rem;
    font-weight: 750;
    color: var(--color-text-heading);
    margin-top: 1.75rem;
    margin-bottom: 0.85rem;
    transition: color 0.5s ease;
  }
  .project-content :global(p) {
    font-size: 0.875rem;
    line-height: 1.65;
    color: var(--color-text-main);
    margin-bottom: 1.5rem;
    transition: color 0.5s ease;
  }
  .project-content :global(ul) {
    list-style-type: disc;
    padding-left: 1.5rem;
    margin-bottom: 1.5rem;
    color: var(--color-text-main);
    transition: color 0.5s ease;
  }
  .project-content :global(li) {
    margin-bottom: 0.6rem;
    font-size: 0.875rem;
    line-height: 1.55;
  }
  .project-content :global(ol) {
    list-style-type: decimal;
    padding-left: 1.5rem;
    margin-bottom: 1.5rem;
    color: var(--color-text-main);
    transition: color 0.5s ease;
  }

  /* Lightbox styling */
  #lightbox-modal {
    transition: opacity 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }
  #lightbox-modal.opacity-0 {
    opacity: 0;
  }
  #lightbox-modal.opacity-100 {
    opacity: 1;
  }
  #lightbox-image {
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.35s ease;
  }
  #lightbox-image.scale-95 {
    transform: scale(0.95);
    opacity: 0;
  }
  #lightbox-image.scale-100 {
    transform: scale(1);
    opacity: 1;
  }

  /* Lightbox text and element readability in all modes */
  #lightbox-modal h4,
  #lightbox-modal #lightbox-title {
    color: #ffffff !important;
  }
  #lightbox-modal p,
  #lightbox-modal #lightbox-desc {
    color: #9ca3af !important;
  }
  #lightbox-modal #lightbox-counter {
    color: #9ca3af !important;
  }
  #lightbox-modal button {
    color: #9ca3af !important;
  }
  #lightbox-modal button:hover {
    color: #ffffff !important;
  }
  #lightbox-modal svg {
    color: inherit !important;
  }
</style>
