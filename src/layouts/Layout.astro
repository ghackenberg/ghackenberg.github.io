---
import "../styles/global.css";
import "@fontsource/inter/300.css";
import "@fontsource/inter/400.css";
import "@fontsource/inter/500.css";
import "@fontsource/inter/600.css";
import "@fontsource/inter/700.css";
import "@fontsource/outfit/300.css";
import "@fontsource/outfit/400.css";
import "@fontsource/outfit/500.css";
import "@fontsource/outfit/600.css";
import "@fontsource/outfit/700.css";
import "@fontsource/outfit/800.css";
import KaTeXStyles from "../components/KaTeXStyles.astro";
import { getImage } from "astro:assets";
import defaultOgImage from "../assets/images/og-share-preview.png";
import Background from "../components/Background.astro";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
  pubDate?: Date | string;
  tags?: string[];
  hasMath?: boolean;
  preloadImage?: string;
}

const { 
  title = "Dr. Georg Hackenberg | Professor & Software Engineer", 
  description = "Personal website of Dr. Georg Hackenberg, Professor for Industrial Informatics, software engineer, entrepreneur, and developer of CADdrive and Mentawise.",
  image,
  type = "website",
  pubDate,
  tags = [],
  hasMath = false,
  preloadImage
} = Astro.props;

// Build canonical URL
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

// Optimize default OG image at build time
const optimizedOgImage = await getImage({
  src: defaultOgImage,
  format: 'jpeg',
  width: 1200,
  height: 630,
  quality: 85
});

// Build absolute OG image URL
const resolvedImageURL = new URL(
  image || optimizedOgImage.src,
  Astro.site
);

// Format date for article metadata if available
let isoDate: string | undefined;
if (pubDate) {
  try {
    isoDate = pubDate instanceof Date ? pubDate.toISOString() : new Date(pubDate).toISOString();
  } catch (e) {
    console.error("Failed to parse pubDate for SEO metadata", e);
  }
}
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <script is:inline>
      // Add no-transitions class to prevent theme transition animation on load
      document.documentElement.classList.add('no-transitions');

      (function() {
        const urlParams = new URLSearchParams(window.location.search);
        const themeParam = urlParams.get('theme');
        let themeSetting = localStorage.getItem('theme') || 'system';

        if (themeParam === 'light' || themeParam === 'dark') {
          themeSetting = themeParam;
        }

        document.documentElement.setAttribute('data-theme-setting', themeSetting);

        function applyTheme(setting, trigger) {
          let activeTheme = setting;
          if (setting === 'system') {
            const systemIsLight = window.matchMedia && window.matchMedia('(prefers-color-scheme: light)').matches;
            activeTheme = systemIsLight ? 'light' : 'dark';
          }

          if (activeTheme === 'light') {
            document.documentElement.classList.add('light');
          } else {
            document.documentElement.classList.remove('light');
          }

          if (trigger) {
            window.dispatchEvent(new CustomEvent('theme-changed', { 
              detail: { 
                themeSetting: setting, 
                resolvedTheme: activeTheme, 
                trigger: trigger 
              } 
            }));
          }
        }

        applyTheme(themeSetting);

        // Listen to system preference changes
        if (window.matchMedia) {
          window.matchMedia('(prefers-color-scheme: light)').addEventListener('change', function() {
            const currentSetting = localStorage.getItem('theme') || 'system';
            if (currentSetting === 'system') {
              applyTheme('system', 'system');
            }
          });
        }
      })();
    </script>
    
    <!-- Favicons & App Icons -->
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <link rel="icon" type="image/png" sizes="32x32" href={`${import.meta.env.BASE_URL}favicon-32x32.png`} />
    <link rel="icon" type="image/png" sizes="16x16" href={`${import.meta.env.BASE_URL}favicon-16x16.png`} />
    <link rel="apple-touch-icon" sizes="180x180" href={`${import.meta.env.BASE_URL}apple-touch-icon.png`} />
    
    <!-- PWA Web App Manifest -->
    <link rel="manifest" href={`${import.meta.env.BASE_URL}manifest.json`} />
    
    <!-- Theme & Mobile Colors -->
    <meta name="theme-color" content="#030712" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    
    <!-- Meta Info -->
    <meta name="generator" content={Astro.generator} />
    <meta name="google-site-verification" content="Cp7mdJpXJfZMzl80PESVj2Xb1uG37nSQB1rW0IqYYYw" />
    
    <!-- Primary SEO Meta Tags -->
    {preloadImage && (
      <link rel="preload" as="image" href={preloadImage} fetchpriority="high" />
    )}
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={resolvedImageURL} />
    <meta property="og:site_name" content="Dr. Georg Hackenberg" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={resolvedImageURL} />
    
    <!-- Article Specific Metadata -->
    {type === "article" && (
      <>
        {isoDate && <meta property="article:published_time" content={isoDate} />}
        <meta property="article:author" content="Dr. Georg Hackenberg" />
        {tags.map((tag) => (
          <meta property="article:tag" content={tag} />
        ))}
      </>
    )}
    
    <!-- Plausible Analytics -->
    <script async src="https://analytics.mentawise.com/js/pa-O3_ufAliuDNy91yFk7qwQ.js"></script>
    <script is:inline>
      window.plausible=window.plausible||function(){(plausible.q=plausible.q||[]).push(arguments)},plausible.init=plausible.init||function(i){plausible.o=i||{}};
      plausible.init({
        outboundLinks: true,
        fileDownloads: true,
        formSubmissions: true,
        customProperties: {
          theme_setting: document.documentElement.getAttribute('data-theme-setting') || 'system',
          theme_resolved: document.documentElement.classList.contains('light') ? 'light' : 'dark'
        }
      });

      // Track theme toggle event when it changes dynamically
      window.addEventListener('theme-changed', function(e) {
        if (window.plausible) {
          plausible('theme-changed', { props: { 
            theme_setting: e.detail.themeSetting,
            theme_resolved: e.detail.resolvedTheme,
            theme_trigger: e.detail.trigger
          } });
        }
      });
    </script>

    <!-- Notification & Badge Tracking -->
    <script>
      import "../scripts/notifications.ts";
    </script>    <!-- KaTeX Math Styles -->
    {hasMath && <KaTeXStyles />}
    <script is:inline>
      // Remove no-transitions once the page is loaded, stylesheets are applied, and laid out
      (function() {
        function enableTransitions() {
          if (!document.documentElement.classList.contains('no-transitions')) return;
          requestAnimationFrame(() => {
            requestAnimationFrame(() => {
              document.documentElement.classList.remove('no-transitions');
            });
          });
        }

        // Wait for stylesheets to load
        const links = Array.from(document.querySelectorAll('link[rel="stylesheet"]'));
        let pending = links.length;

        if (pending === 0) {
          // If in development mode, style tags might be injected dynamically, so add a small delay
          setTimeout(enableTransitions, 100);
        } else {
          links.forEach(link => {
            try {
              if (link.sheet) {
                pending--;
                return;
              }
            } catch (e) {}

            link.addEventListener('load', () => {
              pending--;
              if (pending === 0) enableTransitions();
            });
            link.addEventListener('error', () => {
              pending--;
              if (pending === 0) enableTransitions();
            });
          });
          if (pending === 0) {
            enableTransitions();
          }
        }

        // Fallbacks to guarantee transition enablement
        window.addEventListener('load', enableTransitions);
        setTimeout(enableTransitions, 1500);
      })();
    </script>
  </head>

  <body class="text-gray-100 selection:bg-brand-blue selection:text-white min-h-screen flex flex-col relative antialiased">
    
    <!-- Parallax vector background with astronomical moon phases and day/night transitions -->
    <Background />

    <!-- Main site wrapper -->
    <div class="relative z-10 flex flex-col min-h-screen">
      <slot />

      <!-- Footer -->
      <footer class="w-full glass-panel border-t border-white/5 py-12 md:py-16 text-sm text-gray-400 mt-auto relative z-10">
        <div class="max-w-6xl mx-auto px-4 md:px-8">
          <div class="grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-12 pb-10 border-b border-white/5">
            
            <!-- Brand Column -->
            <div class="md:col-span-5 flex flex-col space-y-4">
              <a href="/" class="flex items-center space-x-2 group self-start">
                <span class="text-xl font-extrabold tracking-tight bg-clip-text text-transparent bg-gradient-to-r from-brand-blue via-brand-purple to-brand-yellow">
                  GH.
                </span>
                <span class="font-semibold text-sm text-gray-300 tracking-wide group-hover:text-white transition-colors">
                  Georg Hackenberg
                </span>
              </a>
              <p class="text-xs text-gray-500 leading-relaxed max-w-sm">
                Professor for Industrial Informatics, software engineer, and researcher passionate about knowledge graph architectures, model-based system validation, and engineering modern software platforms.
              </p>
            </div>
            
            <!-- Navigation Column -->
            <div class="md:col-span-3 flex flex-col space-y-3">
              <span class="text-xs font-bold text-gray-300 uppercase tracking-wider md:pt-[6px]">Navigation</span>
              <ul class="space-y-2 text-xs">
                <li>
                  <a href="/" class="hover:text-brand-blue hover:translate-x-1 transition-all inline-block">Home</a>
                </li>
                <li>
                  <a href="/posts" class="hover:text-brand-blue hover:translate-x-1 transition-all inline-block">Posts</a>
                </li>
                <li>
                  <a href="/courses" class="hover:text-brand-blue hover:translate-x-1 transition-all inline-block">Courses</a>
                </li>
                <li>
                  <a href="/projects" class="hover:text-brand-blue hover:translate-x-1 transition-all inline-block">Projects</a>
                </li>
                <li>
                  <a href="/services" class="hover:text-brand-blue hover:translate-x-1 transition-all inline-block">Services</a>
                </li>
                <li>
                  <a href="/publications" class="hover:text-brand-blue hover:translate-x-1 transition-all inline-block">Publications</a>
                </li>
                <li>
                  <a href="/visualizations" class="hover:text-brand-blue hover:translate-x-1 transition-all inline-block">Visualizations</a>
                </li>
              </ul>
            </div>
            
            <!-- Contact/Institution Column -->
            <div class="md:col-span-4 flex flex-col space-y-3">
              <span class="text-xs font-bold text-gray-300 uppercase tracking-wider md:pt-[6px]">Contact & Institution</span>
              <p class="text-xs text-gray-500 leading-relaxed">
                University of Applied Sciences Upper Austria<br />
                School of Engineering<br />
                Stelzhamerstrasse 23, 4600 Wels, Austria
              </p>
              <a 
                href="mailto:georg.hackenberg@fh-wels.at" 
                class="text-xs text-brand-blue hover:text-brand-blue/90 hover:underline select-all font-mono self-start"
              >
                georg.hackenberg@fh-wels.at
              </a>
            </div>
            
          </div>
          
          <!-- Footer Bottom -->
          <div class="pt-8 flex flex-col lg:flex-row items-center justify-between text-xs text-gray-500 gap-4">
            <div class="flex flex-col items-center lg:items-start gap-1">
              <p>&copy; {new Date().getFullYear()} Dr. Georg Hackenberg. All rights reserved.</p>
              <p class="text-[10px] text-gray-500/70 mt-0.5">
                Built with 
                <a href="https://astro.build" target="_blank" rel="noopener noreferrer" class="hover:text-brand-blue transition-colors font-medium">Astro</a>, 
                <a href="https://tailwindcss.com" target="_blank" rel="noopener noreferrer" class="hover:text-brand-blue transition-colors font-medium">Tailwind CSS</a> & 
                <span class="font-semibold bg-gradient-to-r from-brand-blue via-brand-purple to-brand-yellow bg-clip-text text-transparent">Antigravity</span>
              </p>
            </div>
            <div class="flex flex-wrap items-center justify-center lg:justify-end gap-x-6 gap-y-2">
              <a href="/impressum" class="hover:text-white transition-colors">Impressum</a>
              <a href="/datenschutz" class="hover:text-white transition-colors">Datenschutz</a>
              <a href="https://github.com/ghackenberg" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors" aria-label="GitHub">GitHub</a>
              <a href="https://www.linkedin.com/in/georghackenberg/" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors" aria-label="LinkedIn">LinkedIn</a>
              <a href="https://youtube.com/@georghackenberg" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors" aria-label="YouTube">YouTube</a>
              <a href="#" class="hover:text-white transition-colors">Back to top</a>
            </div>
          </div>
        </div>
      </footer>
    </div>

    <!-- Synchronous initialization of notifications to prevent badge/dot flickering -->
    <script is:inline>
      (function() {
        const STORAGE_KEY = 'gh_site_notifications_v1';
        const MANIFEST_CACHE_KEY = 'gh_content_manifest_cache';
        const SECTIONS = ['posts', 'courses', 'projects', 'services', 'publications', 'visualizations'];
        
        function normalizePath(path) {
          let n = path.replace(/\/$/, '');
          return n.startsWith('/') ? n : '/' + n;
        }
        
        let state = { lastVisitedSections: {}, visitedItems: {} };
        try {
          const stored = localStorage.getItem(STORAGE_KEY);
          if (stored) state = JSON.parse(stored);
        } catch(e) {}
        
        // 1. Update unread dots synchronously
        const unreadDots = document.querySelectorAll('.unread-dot');
        unreadDots.forEach(dot => {
          const rawUrl = dot.getAttribute('data-item-url');
          if (rawUrl) {
            const itemUrl = normalizePath(rawUrl);
            const isVisited = !!state.visitedItems[itemUrl];
            if (!isVisited) {
              dot.classList.remove('hidden');
            } else {
              dot.classList.add('hidden');
            }
          }
        });
        
        // 2. Update navbar badges synchronously using cached manifest
        let manifest = null;
        try {
          const cached = localStorage.getItem(MANIFEST_CACHE_KEY);
          if (cached) manifest = JSON.parse(cached);
        } catch(e) {}
        
        if (manifest) {
          SECTIONS.forEach(section => {
            const items = manifest[section] || [];
            const lastVisit = state.lastVisitedSections[section] !== undefined
              ? state.lastVisitedSections[section]
              : 0;
            
            const newItemsCount = items.filter(item => {
              const itemUrl = normalizePath(item.url);
              const isNew = lastVisit === 0 ? true : item.date > lastVisit;
              const isUnvisited = !state.visitedItems[itemUrl];
              return isNew && isUnvisited;
            }).length;
            
            const badges = document.querySelectorAll('.nav-badge[data-section="' + section + '"]');
            badges.forEach(badge => {
              if (newItemsCount > 0) {
                badge.textContent = String(newItemsCount);
                badge.classList.remove('hidden');
              } else {
                badge.classList.add('hidden');
              }
            });
          });
        }
      })();
    </script>
  </body>
</html>
