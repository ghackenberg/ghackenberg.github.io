---
import "../styles/global.css";
import { getImage } from "astro:assets";
import defaultOgImage from "../assets/images/og-share-preview.png";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
  pubDate?: Date | string;
  tags?: string[];
}

const { 
  title = "Dr. Georg Hackenberg | Professor & Software Engineer", 
  description = "Personal website of Dr. Georg Hackenberg, Professor for Industrial Informatics, software engineer, entrepreneur, and developer of CADdrive and Mentawise.",
  image,
  type = "website",
  pubDate,
  tags = []
} = Astro.props;

// Build canonical URL
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

// Optimize default OG image at build time
const optimizedOgImage = await getImage({
  src: defaultOgImage,
  format: 'jpeg',
  width: 1200,
  height: 630,
  quality: 85
});

// Build absolute OG image URL
const resolvedImageURL = new URL(
  image || optimizedOgImage.src,
  Astro.site
);

// Format date for article metadata if available
let isoDate: string | undefined;
if (pubDate) {
  try {
    isoDate = pubDate instanceof Date ? pubDate.toISOString() : new Date(pubDate).toISOString();
  } catch (e) {
    console.error("Failed to parse pubDate for SEO metadata", e);
  }
}
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <!-- Favicons & App Icons -->
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <link rel="icon" type="image/png" sizes="32x32" href={`${import.meta.env.BASE_URL}favicon-32x32.png`} />
    <link rel="icon" type="image/png" sizes="16x16" href={`${import.meta.env.BASE_URL}favicon-16x16.png`} />
    <link rel="apple-touch-icon" sizes="180x180" href={`${import.meta.env.BASE_URL}apple-touch-icon.png`} />
    
    <!-- PWA Web App Manifest -->
    <link rel="manifest" href={`${import.meta.env.BASE_URL}manifest.json`} />
    
    <!-- Theme & Mobile Colors -->
    <meta name="theme-color" content="#030712" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    
    <!-- Meta Info -->
    <meta name="generator" content={Astro.generator} />
    <meta name="google-site-verification" content="Cp7mdJpXJfZMzl80PESVj2Xb1uG37nSQB1rW0IqYYYw" />
    
    <!-- Primary SEO Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={resolvedImageURL} />
    <meta property="og:site_name" content="Dr. Georg Hackenberg" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={resolvedImageURL} />
    
    <!-- Article Specific Metadata -->
    {type === "article" && (
      <>
        {isoDate && <meta property="article:published_time" content={isoDate} />}
        <meta property="article:author" content="Dr. Georg Hackenberg" />
        {tags.map((tag) => (
          <meta property="article:tag" content={tag} />
        ))}
      </>
    )}
    
    <!-- Plausible Analytics -->
    <script defer data-domain="ghackenberg.github.io" src="https://analytics.mentawise.com/js/script.js"></script>

    <!-- Google Fonts: Outfit & Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  </head>

  <body class="text-gray-100 selection:bg-brand-blue selection:text-white min-h-screen flex flex-col relative antialiased">
    
    <!-- Background glowing orbs for premium dark mode visual aesthetic -->
    <div class="absolute top-0 left-0 w-full h-full overflow-hidden pointer-events-none z-0">
      <div class="bg-glow-orb bg-brand-blue w-[40vw] h-[40vw] top-[-10%] left-[-10%]"></div>
      <div class="bg-glow-orb bg-brand-purple w-[35vw] h-[35vw] top-[40%] right-[-10%]" style="animation-delay: -3s;"></div>
      <div class="bg-glow-orb bg-brand-yellow w-[30vw] h-[30vw] bottom-[10%] left-[10%]" style="animation-delay: -6s;"></div>
      <div class="bg-glow-orb bg-brand-green w-[30vw] h-[30vw] top-[20%] left-[50%]" style="animation-delay: -9s;"></div>
    </div>

    <!-- Main site wrapper -->
    <div class="relative z-10 flex flex-col min-h-screen">
      <slot />
    </div>

  </body>
</html>
