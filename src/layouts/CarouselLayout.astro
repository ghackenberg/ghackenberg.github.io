---
// CarouselLayout.astro
// Base layout for LinkedIn carousels, styled consistently with the website's brand aesthetics.

import "../styles/global.css";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <style is:global>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&family=Outfit:wght@500;700;800&display=swap');
    
    @page {
      size: 1080px 1080px;
      margin: 0;
    }

    body {
      margin: 0;
      padding: 0;
      font-family: 'Inter', sans-serif;
      background-color: #030712;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }

    .slide-page {
      width: 1080px;
      height: 1080px;
      page-break-after: always;
      box-sizing: border-box;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      padding: 90px;
      background: radial-gradient(circle at 85% 15%, var(--glow-1, rgba(16, 185, 129, 0.08)) 0%, rgba(3, 7, 18, 0) 70%),
                  radial-gradient(circle at 15% 85%, var(--glow-2, rgba(20, 184, 166, 0.05)) 0%, rgba(3, 7, 18, 0) 60%),
                  #030712;
      position: relative;
      overflow: hidden;
    }

    ::-webkit-scrollbar {
      display: none;
    }
  </style>
</head>
<body>
  <slot />
</body>
</html>
